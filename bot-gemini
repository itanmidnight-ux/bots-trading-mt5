enum ENUM_RISK_MODE
  {
   RISK_FIXED_LOT = 0, // Fixed Lot (Lote Fijo)
   RISK_PERCENTAGE = 1 // Equity Percentage (Porcentaje del Capital)
  };

enum ENUM_TRAILING_MODE
  {
   TRAIL_OFF = 0,      // No Trailing (Sin Trailing)
   TRAIL_SMART = 1,    // Smart Structure Trailing (Trailing por Estructura)
   TRAIL_ATR = 2       // ATR Volatility Trailing (Trailing por Volatilidad ATR)
  };

