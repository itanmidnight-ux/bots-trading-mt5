int OnInit()
  {
   Log.Info("Iniciando AdvancedIntelligentBot... Chequeando Sistemas.");
   
   Sym.Name(_Symbol);
   Trade.SetExpertMagicNumber(InpMagicNumber);
   
   if(!Ind.Init(_Symbol)) return INIT_FAILED;
   Risk.Init(_Symbol);
   Env.Init(_Symbol);
   PosMgr.Init(&Ind, _Symbol);
   Signals.Init(&Ind);
   
   LastDayTime = iTime(_Symbol, PERIOD_D1, 0);
   LastBarTime = iTime(_Symbol, InpMainTF, 0);
   
   Log.Info("Arquitectura cargada exitosamente.");
   return(INIT_SUCCEEDED);
  }

void OnDeinit(const int reason)
  {
   Ind.Release();
   Log.Info("Bot apagado.");
  }

//+------------------------------------------------------------------+
//| MAIN ALGORITHM LOOP (BUCLE PRINCIPAL DEL ALGORITMO)              |
//+------------------------------------------------------------------+
void OnTick()
  {
   // 1. Reset Daily Filters
   datetime currentDay = iTime(_Symbol, PERIOD_D1, 0);
   if(currentDay != LastDayTime) { Risk.ResetDaily(); LastDayTime = currentDay; }

   // 2. Continuous Safety & Drawdown Checks
   if(Risk.IsDrawdownExceeded()) return;
   
   // 3. Dynamic Management of Open Trades (Breakeven, Trailing, Partial Close)
   PosMgr.ManageExistingTrades();

   // 4. Check for New Bar to Execute Logic (Reduces Noise)
   datetime currentBar = iTime(_Symbol, InpMainTF, 0);
   if(currentBar == LastBarTime) return; // Wait for candle close (Esperar cierre de vela)
   
   // 5. Environment Check
   if(!Env.IsMarketSafe()) return;
   
   // 6. Only execute if no positions exist for this symbol/magic
   if(PositionsTotal() > 0)
     {
      bool hasPos = false;
      for(int i=0; i<PositionsTotal(); i++)
        {
         ulong t = PositionGetTicket(i);
         if(PositionGetString(POSITION_SYMBOL) == _Symbol && PositionGetInteger(POSITION_MAGIC) == InpMagicNumber) hasPos = true;
        }
      if(hasPos) return; // Wait until current trade finishes (Esperar fin del trade)
     }

   Sym.RefreshRates();
   double ask = Sym.Ask();
   double bid = Sym.Bid();
   double atr = Ind.GetATR(1);
   if(atr == 0) return;

   // 7. Intelligent Execution
   if(Signals.IsBuyValid(ask))
     {
      // Intelligent SL based on Structure + ATR Buffer
      double recentLow = Struct.GetRecentSwingLow(_Symbol, InpMainTF, InpSwingPeriod);
      if(recentLow == 0) recentLow = ask - (atr * 2); // Failsafe fallback
      
      double slPrice = recentLow - (atr * InpATRSafetyBuffer);
      double slDistance = ask - slPrice;
      
      // Intelligent TP based on Risk/Reward
      double tpPrice = ask + (slDistance * InpRiskRewardRatio);
      
      double lot = Risk.CalculateLotSize(slDistance);
      
      if(Trade.Buy(lot, _Symbol, ask, slPrice, tpPrice, InpBotComment))
        {
         Log.Info("Buy executed with Intelligent SL based on Structure.");
         LastBarTime = currentBar;
        }
     }
   else if(Signals.IsSellValid(bid))
     {
      // Intelligent SL based on Structure + ATR Buffer
      double recentHigh = Struct.GetRecentSwingHigh(_Symbol, InpMainTF, InpSwingPeriod);
      if(recentHigh == 0) recentHigh = bid + (atr * 2); // Failsafe fallback
      
      double slPrice = recentHigh + (atr * InpATRSafetyBuffer);
      double slDistance = slPrice - bid;
      
      // Intelligent TP based on Risk/Reward
      double tpPrice = bid - (slDistance * InpRiskRewardRatio);
      
      double lot = Risk.CalculateLotSize(slDistance);
      
      if(Trade.Sell(lot, _Symbol, bid, slPrice, tpPrice, InpBotComment))
        {
         Log.Info("Sell executed with Intelligent SL based on Structure.");
         LastBarTime = currentBar;
        }
     }
  }
