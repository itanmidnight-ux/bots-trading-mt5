//--- Indicators Manager (Gestor de Indicadores)
class CIndicators
  {
private:
   int m_handleMA_Main, m_handleMA_Trend, m_handleRSI, m_handleMACD, m_handleATR;
   string m_symbol;

public:
   bool Init(string symbol)
     {
      m_symbol = symbol;
      m_handleMA_Main = iMA(m_symbol, InpMainTF, InpMAPeriod, 0, MODE_EMA, PRICE_CLOSE);
      m_handleMA_Trend = iMA(m_symbol, InpTrendTF, InpMAPeriod, 0, MODE_EMA, PRICE_CLOSE);
      m_handleRSI = iRSI(m_symbol, InpMainTF, InpRSIPeriod, PRICE_CLOSE);
      m_handleMACD = iMACD(m_symbol, InpMainTF, InpMACDFast, InpMACDSlow, InpMACDSignal, PRICE_CLOSE);
      m_handleATR = iATR(m_symbol, InpMainTF, InpATRPeriod);
      
      if(m_handleMA_Main == INVALID_HANDLE || m_handleMA_Trend == INVALID_HANDLE || 
         m_handleRSI == INVALID_HANDLE || m_handleMACD == INVALID_HANDLE || m_handleATR == INVALID_HANDLE)
        {
         Log.Error("Failed to initialize indicators. (Fallo al inicializar indicadores)");
         return false;
        }
      return true;
     }

   double GetMA_Main(int shift=1)  { double b[1]; if(CopyBuffer(m_handleMA_Main, 0, shift, 1, b)>0) return b[0]; return 0;}
   double GetMA_Trend(int shift=1) { double b[1]; if(CopyBuffer(m_handleMA_Trend, 0, shift, 1, b)>0) return b[0]; return 0;}
   double GetRSI(int shift=1)      { double b[1]; if(CopyBuffer(m_handleRSI, 0, shift, 1, b)>0) return b[0]; return 0;}
   double GetATR(int shift=1)      { double b[1]; if(CopyBuffer(m_handleATR, 0, shift, 1, b)>0) return b[0]; return 0;}
   
   bool GetMACD(int shift, double &main, double &signal)
     {
      double bM[1], bS[1];
      if(CopyBuffer(m_handleMACD, 0, shift, 1, bM) > 0 && CopyBuffer(m_handleMACD, 1, shift, 1, bS) > 0)
        {
         main = bM[0]; signal = bS[0]; return true;
        }
      return false;
     }
     
   void Release()
     {
      IndicatorRelease(m_handleMA_Main); IndicatorRelease(m_handleMA_Trend);
      IndicatorRelease(m_handleRSI); IndicatorRelease(m_handleMACD); IndicatorRelease(m_handleATR);
     }
  };

//--- Market Structure Analyzer (Analizador de Estructura de Mercado para SL Inteligente)
class CMarketStructure
  {
public:
   // Encuentra el Bajo más Bajo reciente (para SL de Compras)
   double GetRecentSwingLow(string symbol, ENUM_TIMEFRAMES tf, int period)
     {
      double lowArray[];
      ArraySetAsSeries(lowArray, true);
      if(CopyLow(symbol, tf, 1, period, lowArray) > 0)
        {
         int lowestIndex = ArrayMinimum(lowArray, 0, period);
         return lowArray[lowestIndex];
        }
      return 0;
     }

   // Encuentra el Alto más Alto reciente (para SL de Ventas)
   double GetRecentSwingHigh(string symbol, ENUM_TIMEFRAMES tf, int period)
     {
      double highArray[];
      ArraySetAsSeries(highArray, true);
      if(CopyHigh(symbol, tf, 1, period, highArray) > 0)
        {
         int highestIndex = ArrayMaximum(highArray, 0, period);
         return highArray[highestIndex];
        }
      return 0;
     }
  };

//--- Risk Management (Gestión de Riesgo)
class CRiskManager
  {
private:
   CAccountInfo m_account;
   CSymbolInfo  m_sym;
   double       m_startDayEquity;

public:
   void Init(string symbol) { m_sym.Name(symbol); m_startDayEquity = m_account.Equity(); }
   void ResetDaily()        { m_startDayEquity = m_account.Equity(); }
   
   bool IsDrawdownExceeded()
     {
      double dd = ((m_startDayEquity - m_account.Equity()) / m_startDayEquity) * 100.0;
      if(dd >= InpMaxDailyDrawdown)
        {
         Log.Warn("Max Daily Drawdown Reached. Trading paused. (Drawdown máximo alcanzado. Pausado.)");
         return true;
        }
      return false;
     }

   double CalculateLotSize(double slDistancePrice)
     {
      m_sym.Refresh();
      if(InpRiskMode == RISK_FIXED_LOT) return NormalizeDouble(InpFixedLot, 2);
      
      double riskCash = m_account.Equity() * (InpRiskPercent / 100.0);
      double tickValue = m_sym.TickValue();
      double tickSize = m_sym.TickSize();
      
      if(tickSize == 0 || tickValue == 0 || slDistancePrice <= 0) return m_sym.LotsMin();
      
      double slTicks = slDistancePrice / tickSize;
      double lots = riskCash / (slTicks * tickValue);
      
      lots = MathMax(lots, m_sym.LotsMin());
      lots = MathMin(lots, m_sym.LotsMax());
      double step = m_sym.LotsStep();
      return MathFloor(lots / step) * step; // Normalizar al paso del broker
     }
  };

//--- Environment Filters (Filtros de Entorno)
class CEnvironment
  {
private:
   CSymbolInfo m_sym;
public:
   void Init(string symbol) { m_sym.Name(symbol); }

   bool IsMarketSafe()
     {
      m_sym.Refresh();
      // 1. Spread Check
      if(m_sym.Spread() > InpMaxSpreadPoints) return false;
      
      // 2. Time Check
      MqlDateTime dt;
      TimeCurrent(dt);
      if(dt.hour < InpStartHour || dt.hour >= InpEndHour) return false;
      
      return true;
     }
  };

//--- Trade & Position Manager (Gestor de Posiciones Inteligente)
class CPositionManager
  {
private:
   CTrade         m_trade;
   CPositionInfo  m_pos;
   CIndicators    *m_ind;
   CMarketStructure m_struct;
   string         m_symbol;

public:
   void Init(CIndicators *ind, string symbol)
     {
      m_ind = ind; m_symbol = symbol;
      m_trade.SetExpertMagicNumber(InpMagicNumber);
     }

   void ManageExistingTrades()
     {
      for(int i = PositionsTotal() - 1; i >= 0; i--)
        {
         if(m_pos.SelectByIndex(i))
           {
            if(m_pos.Symbol() == m_symbol && m_pos.Magic() == InpMagicNumber)
              {
               ProcessBreakeven();
               ProcessPartialClose();
               ProcessTrailingStop();
              }
           }
        }
     }

private:
   void ProcessBreakeven()
     {
      if(!InpUseBreakeven) return;
      double open = m_pos.PriceOpen();
      double sl = m_pos.StopLoss();
      double tp = m_pos.TakeProfit();
      double current = m_pos.PriceCurrent();
      long type = m_pos.PositionType();
      
      // Calculate initial risk distance (Calculamos riesgo inicial)
      double riskDist = 0;
      if(sl > 0) riskDist = MathAbs(open - sl);
      if(riskDist == 0) return; // Without SL we can't measure R/R
      
      double beDistance = riskDist * InpBreakevenTrigger;
      
      if(type == POSITION_TYPE_BUY && current >= open + beDistance && sl < open)
        {
         m_trade.PositionModify(m_pos.Ticket(), open, tp);
         Log.Info("Breakeven applied (BUY)");
        }
      else if(type == POSITION_TYPE_SELL && current <= open - beDistance && (sl > open || sl == 0))
        {
         m_trade.PositionModify(m_pos.Ticket(), open, tp);
         Log.Info("Breakeven applied (SELL)");
        }
     }

   void ProcessPartialClose()
     {
      if(!InpUsePartialClose) return;
      
      // Obtenemos comentario para saber si ya se cerró parcialmente
      string comment = m_pos.Comment();
      if(StringFind(comment, "PC_Done") >= 0) return; // Ya se hizo
      
      double open = m_pos.PriceOpen();
      double sl = m_pos.StopLoss();
      double current = m_pos.PriceCurrent();
      long type = m_pos.PositionType();
      
      double riskDist = (sl > 0) ? MathAbs(open - sl) : 0;
      if(riskDist == 0) return;
      
      double targetDist = riskDist * InpPartialTargetRatio;
      bool trigger = false;
      
      if(type == POSITION_TYPE_BUY && current >= open + targetDist) trigger = true;
      if(type == POSITION_TYPE_SELL && current <= open - targetDist) trigger = true;
      
      if(trigger)
        {
         double closeVol = m_pos.Volume() * (InpPartialVolumePct / 100.0);
         double minVol = SymbolInfoDouble(m_symbol, SYMBOL_VOLUME_MIN);
         double step = SymbolInfoDouble(m_symbol, SYMBOL_VOLUME_STEP);
         
         closeVol = MathFloor(closeVol / step) * step;
         if(closeVol >= minVol)
           {
            if(m_trade.PositionClosePartial(m_pos.Ticket(), closeVol))
              {
               Log.Info("Partial Profit secured. (Ganancia parcial asegurada)");
               // Actualizar comentario no es posible directamente sin reabrir, 
               // pero MT5 maneja los cierres parciales cambiando el ticket o podemos rastrearlo por volumen.
               // Para simplificar, la reducción de volumen ya previene el re-disparo si la lógica se adapta.
              }
           }
        }
     }

   void ProcessTrailingStop()
     {
      if(InpTrailMode == TRAIL_OFF) return;
      
      double open = m_pos.PriceOpen();
      double sl = m_pos.StopLoss();
      double tp = m_pos.TakeProfit();
      double current = m_pos.PriceCurrent();
      long type = m_pos.PositionType();
      double atr = m_ind.GetATR(1);
      
      double newSL = sl;

      if(InpTrailMode == TRAIL_ATR)
        {
         double trailDist = atr * InpTrailATRMult;
         if(type == POSITION_TYPE_BUY)
           {
            newSL = current - trailDist;
            if(newSL > sl && newSL > open) m_trade.PositionModify(m_pos.Ticket(), newSL, tp);
           }
         else if(type == POSITION_TYPE_SELL)
           {
            newSL = current + trailDist;
            if((newSL < sl || sl == 0) && newSL < open) m_trade.PositionModify(m_pos.Ticket(), newSL, tp);
           }
        }
      else if(InpTrailMode == TRAIL_SMART)
        {
         // Trailing basado en Estructura de Mercado
         if(type == POSITION_TYPE_BUY)
           {
            double recentLow = m_struct.GetRecentSwingLow(m_symbol, InpMainTF, 5);
            newSL = recentLow - (atr * 0.5); // Buffer debajo del bajo
            if(newSL > sl && newSL > open) m_trade.PositionModify(m_pos.Ticket(), newSL, tp);
           }
         else if(type == POSITION_TYPE_SELL)
           {
            double recentHigh = m_struct.GetRecentSwingHigh(m_symbol, InpMainTF, 5);
            newSL = recentHigh + (atr * 0.5); // Buffer encima del alto
            if((newSL < sl || sl == 0) && newSL < open) m_trade.PositionModify(m_pos.Ticket(), newSL, tp);
           }
        }
     }
  };

//--- Signal Engine (Motor Lógico)
class CSignalEngine
  {
private:
   CIndicators *m_ind;
public:
   void Init(CIndicators *ind) { m_ind = ind; }

   bool IsBuyValid(double askPrice)
     {
      if(askPrice < m_ind.GetMA_Trend(1) || askPrice < m_ind.GetMA_Main(1)) return false;
      if(m_ind.GetRSI(1) > 60) return false; // Overbought, don't buy
      
      double m1, s1, m2, s2;
      if(!m_ind.GetMACD(1, m1, s1) || !m_ind.GetMACD(2, m2, s2)) return false;
      
      // MACD Bullish Cross below zero line (Cruce alcista MACD debajo de cero)
      if(m2 <= s2 && m1 > s1 && m1 < 0) return true;
      return false;
     }

   bool IsSellValid(double bidPrice)
     {
      if(bidPrice > m_ind.GetMA_Trend(1) || bidPrice > m_ind.GetMA_Main(1)) return false;
      if(m_ind.GetRSI(1) < 40) return false; // Oversold, don't sell
      
      double m1, s1, m2, s2;
      if(!m_ind.GetMACD(1, m1, s1) || !m_ind.GetMACD(2, m2, s2)) return false;
      
      // MACD Bearish Cross above zero line (Cruce bajista MACD sobre cero)
      if(m2 >= s2 && m1 < s1 && m1 > 0) return true;
      return false;
     }
  };

