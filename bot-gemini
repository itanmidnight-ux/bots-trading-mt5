//| INPUT PARAMETERS (PARÁMETROS DE ENTRADA)                         |
//+------------------------------------------------------------------+
input group "=== 1. General Configuration ==="
input ulong    InpMagicNumber       = 101010;      // Magic Number (Número Mágico)
input string   InpBotComment        = "IntelliBot"; // Trade Comment (Comentario)

input group "=== 2. Advanced Risk Management ==="
input ENUM_RISK_MODE InpRiskMode    = RISK_PERCENTAGE; // Risk Mode (Modo de Riesgo)
input double   InpRiskPercent       = 2.0;         // Risk % per Trade (% Riesgo por Trade)
input double   InpFixedLot          = 0.1;         // Fixed Lot (Lote Fijo)
input double   InpMaxDailyDrawdown  = 5.0;         // Max Daily Loss % (% Pérdida Máxima Diaria)

input group "=== 3. Intelligent SL & TP ==="
input int      InpSwingPeriod       = 10;          // Bars to check for Swing High/Low (Barras para Estructura)
input double   InpATRSafetyBuffer   = 1.5;         // ATR Multiplier for SL Buffer (Búfer ATR para SL)
input double   InpRiskRewardRatio   = 2.5;         // Target Risk/Reward Ratio (Ratio Riesgo/Beneficio)

input group "=== 4. Partial Profit System ==="
input bool     InpUsePartialClose   = true;        // Use Partial Close? (¿Usar Cierre Parcial?)
input double   InpPartialTargetRatio= 1.0;         // R/R to trigger partial close (R/R para activar cierre)
input double   InpPartialVolumePct  = 50.0;        // % of volume to close (% de volumen a cerrar)

input group "=== 5. Trailing Stop & Breakeven ==="
input ENUM_TRAILING_MODE InpTrailMode = TRAIL_ATR; // Trailing Mode (Modo Trailing)
input double   InpTrailATRMult      = 2.0;         // ATR Multiplier for Trailing
input bool     InpUseBreakeven      = true;        // Use Breakeven? (¿Usar Breakeven?)
input double   InpBreakevenTrigger  = 1.0;         // R/R to trigger Breakeven (R/R para Breakeven)

input group "=== 6. Filters (Time & Market) ==="
input int      InpMaxSpreadPoints   = 30;          // Max Allowed Spread in Points (Spread Máximo permitido)
input int      InpStartHour         = 2;           // Start Trading Hour (Hora de Inicio)
input int      InpEndHour           = 22;          // End Trading Hour (Hora de Fin)

input group "=== 7. Indicators Configuration ==="
input ENUM_TIMEFRAMES InpMainTF     = PERIOD_H1;   // Main Timeframe (Temporalidad Principal)
input ENUM_TIMEFRAMES InpTrendTF    = PERIOD_D1;   // Trend Timeframe (Temporalidad de Tendencia)
input int      InpMAPeriod          = 200;         // Moving Average Period
input int      InpRSIPeriod         = 14;          // RSI Period
input int      InpMACDFast          = 12;          // MACD Fast
input int      InpMACDSlow          = 26;          // MACD Slow
input int      InpMACDSignal        = 9;           // MACD Signal
input int      InpATRPeriod         = 14;          // ATR Period

