//+------------------------------------------------------------------+
//| Profitability optimizer and edge quality engine                  |
//+------------------------------------------------------------------+
void QQBuildCapitalTuning()
{
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   g_tune.mode = mode;
   g_tune.name = QQCapitalModeName();
   g_tune.scoreDiscount = 0.0;
   g_tune.scorePremium = 0.0;
   if(mode == CAP_LOW || g_capital.tier <= TIER_SMALL)
   {
      g_tune.minEdgeScore = InpLowCapitalMinEdgeScore;
      g_tune.maxNewsRisk = InpLowCapitalMaxNewsRisk;
      g_tune.minReadiness = MathMax(66.0, InpMicroMinProfessionalReadiness - 4.0);
      g_tune.minMatrixScore = 7.2;
      g_tune.targetPct = 0.32;
      g_tune.breakEvenTrigger = 66.0;
      g_tune.maxCyclesPerDay = MathMax(1, MathMin(3, InpLowCapitalTargetTradesWeek / 2));
      g_tune.maxGridLevels = 0;
      g_tune.cooldownMinutes = 150;
      g_tune.scorePremium = 0.45;
   }
   else if(mode == CAP_MEDIAN || g_capital.tier == TIER_LOW || g_capital.tier == TIER_STANDARD)
   {
      g_tune.minEdgeScore = InpMedianCapitalMinEdgeScore;
      g_tune.maxNewsRisk = InpMedianCapitalMaxNewsRisk;
      g_tune.minReadiness = MathMax(54.0, InpMinProfessionalReadiness - 2.0);
      g_tune.minMatrixScore = 6.0;
      g_tune.targetPct = 0.22;
      g_tune.breakEvenTrigger = 52.0;
      g_tune.maxCyclesPerDay = MathMax(3, MathMin(6, InpMedianCapitalTargetTradesWeek / 2));
      g_tune.maxGridLevels = 1;
      g_tune.cooldownMinutes = 75;
      g_tune.scoreDiscount = 0.15;
   }
   else
   {
      g_tune.minEdgeScore = InpHighCapitalMinEdgeScore;
      g_tune.maxNewsRisk = InpHighCapitalMaxNewsRisk;
      g_tune.minReadiness = MathMax(48.0, InpMinProfessionalReadiness - 6.0);
      g_tune.minMatrixScore = 5.2;
      g_tune.targetPct = 0.18;
      g_tune.breakEvenTrigger = 42.0;
      g_tune.maxCyclesPerDay = MathMax(5, MathMin(10, InpHighCapitalTargetTradesWeek / 2));
      g_tune.maxGridLevels = 3;
      g_tune.cooldownMinutes = 35;
      g_tune.scoreDiscount = 0.35;
   }
   if(g_opt.lossAvoidanceScore < 45.0)
   {
      g_tune.scorePremium += 0.50;
      g_tune.maxGridLevels = MathMin(g_tune.maxGridLevels, 1);
   }
   if(g_opt.optimizerScore > 76.0 && g_opt.expectedValueScore > 70.0)
      g_tune.scoreDiscount += 0.25;
}

void QQRefreshProfitabilityOptimizer()
{
   if(InpUseProfitabilityOptimizer == QQ_OFF)
      return;
   g_opt.lastRefresh = TimeCurrent();
   g_opt.mtfConsensusScore = QQMTFConsensusScore();
   g_opt.volatilityTimeScore = QQVolatilityTimeSweetSpotScore();
   g_opt.entryPrecisionScore = QQEntryPrecisionScore();
   g_opt.lossAvoidanceScore = QQLossAvoidanceScore();
   g_opt.edgeQualityScore = QQCompositeEdgeQualityScore();
   g_opt.expectedValueScore = QQExpectedValueScore();
   QQRunProfitabilityOptimizerRules();
   g_opt.recommendedMinScore = g_tune.minMatrixScore;
   g_opt.recommendedTargetPct = g_tune.targetPct;
   g_opt.recommendedCooldownMin = g_tune.cooldownMinutes;
   g_opt.lastReport = StringFormat("edge=%.1f ev=%.1f mtf=%.1f vtime=%.1f precision=%.1f lossAvoid=%.1f opt=%.1f",
                                   g_opt.edgeQualityScore, g_opt.expectedValueScore, g_opt.mtfConsensusScore,
                                   g_opt.volatilityTimeScore, g_opt.entryPrecisionScore, g_opt.lossAvoidanceScore, g_opt.optimizerScore);
}

double QQStrategyEdgeScore(const int id, const int dir)
{
   double score = QQCompositeEdgeQualityScore();
   score += QQStrategySpecificEdge(id, dir);
   score += QQDirectionQualityScore(dir) * 0.18;
   score -= QQNewsRiskScore() * 0.18;
   if(id == 4 || id == 5) score += (QQHighRiskStrategiesAllowed() ? 6.0 : -20.0);
   if(g_capital.tier <= TIER_SMALL && id != 1 && id != 6 && id != 11) score -= 12.0;
   return MathMax(0.0, MathMin(100.0, score));
}

bool QQEdgeQualityAllowsEntry(const int id, const int dir, const double edgeScore, string &block)
{
   block = "";
   double minEdge = g_tune.minEdgeScore;
   if(id == 11 && (QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_SMALL)) minEdge -= 4.0;
   if(id == 4 || id == 5) minEdge += 3.0;
   if(edgeScore < minEdge)
   {
      block = "edge";
      g_opt.qualityBlocks++;
      g_opt.lastBlock = StringFormat("S%02d edge %.1f < %.1f", id, edgeScore, minEdge);
      return false;
   }
   if(QQNewsRiskScore() > g_tune.maxNewsRisk)
   {
      block = "news edge";
      g_opt.qualityBlocks++;
      return false;
   }
   if(g_opt.lossAvoidanceScore < 38.0)
   {
      block = "loss avoidance";
      g_opt.qualityBlocks++;
      return false;
   }
   return true;
}

double QQEdgeScoreToMatrixBoost(const double edgeScore)
{
   if(edgeScore >= 86.0) return 1.15;
   if(edgeScore >= 76.0) return 0.75;
   if(edgeScore >= 66.0) return 0.35;
   if(edgeScore < 45.0) return -1.20;
   return 0.0;
}

double QQMTFConsensusScore()
{
   double score = 50.0;
   if(g_matrix.macroDir != 0) score += 12.0;
   if(g_matrix.setupDir != 0) score += 10.0;
   if(g_matrix.timingDir != 0) score += 8.0;
   if(g_matrix.macroDir != 0 && g_matrix.macroDir == g_matrix.setupDir) score += 12.0;
   if(g_matrix.setupDir != 0 && g_matrix.setupDir == g_matrix.timingDir) score += 8.0;
   if(g_matrix.macroDir != 0 && g_matrix.macroDir == g_matrix.setupDir && g_matrix.setupDir == g_matrix.timingDir) score += 10.0;
   if(MathAbs(g_matrix.macroScore) < 2.0) score -= 12.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQVolatilityTimeSweetSpotScore()
{
   double score = 50.0;
   if(snap.session == 2 || snap.session == 3) score += 16.0;
   if(snap.volVelocity >= 0.75 && snap.volVelocity <= 1.75) score += 18.0;
   if(snap.volVelocity > 2.20) score -= 24.0;
   if(snap.m5AtrPoints >= InpMinATRPointsM5 && snap.m5AtrPoints <= InpMinATRPointsM5 * 3.2) score += 12.0;
   if(QQNewsRiskScore() > 35.0) score -= 22.0;
   if(snap.spread < QQEffectiveSpreadCap() * 0.55) score += 10.0;
   return MathMax(0.0, MathMin(100.0, score));
}

bool IsCandleConfirming(const int dir)
{
   if(InpRequireCandleConfirm == QQ_OFF)
      return true;
   double open1 = iOpen(_Symbol, PERIOD_M1, 1);
   double close1 = iClose(_Symbol, PERIOD_M1, 1);
   double high1 = iHigh(_Symbol, PERIOD_M1, 1);
   double low1 = iLow(_Symbol, PERIOD_M1, 1);
   double range = high1 - low1;
   if(range <= 0.0)
      return false;
   double bodyPct = MathAbs(close1 - open1) / range * 100.0;
   if(bodyPct < InpMinCandleBodyPct)
      return false;
   if(dir == 1 && close1 <= open1)
      return false;
   if(dir == -1 && close1 >= open1)
      return false;
   return true;
}

bool HasBullishDivergence(const int tfIdx, const int lookback)
{
   if(tfIdx < 0 || tfIdx >= TF_TOTAL || lookback < 2)
      return false;
   double rsiBuffer[];
   ArraySetAsSeries(rsiBuffer, true);
   if(CopyBuffer(tf[tfIdx].hRSI, 0, 0, lookback + 1, rsiBuffer) < lookback + 1)
      return false;
   double price1 = iLow(_Symbol, tf[tfIdx].period, 1);
   double priceN = iLow(_Symbol, tf[tfIdx].period, lookback);
   return (price1 < priceN && rsiBuffer[1] > rsiBuffer[lookback]);
}

bool HasBearishDivergence(const int tfIdx, const int lookback)
{
   if(tfIdx < 0 || tfIdx >= TF_TOTAL || lookback < 2)
      return false;
   double rsiBuffer[];
   ArraySetAsSeries(rsiBuffer, true);
   if(CopyBuffer(tf[tfIdx].hRSI, 0, 0, lookback + 1, rsiBuffer) < lookback + 1)
      return false;
   double price1 = iHigh(_Symbol, tf[tfIdx].period, 1);
   double priceN = iHigh(_Symbol, tf[tfIdx].period, lookback);
   return (price1 > priceN && rsiBuffer[1] < rsiBuffer[lookback]);
}

bool QQPreRolloverExit(const double totalProfit)
{
   if(InpCloseBeforeRollover == QQ_OFF || !basket.active)
      return false;
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   if(dt.hour == InpRolloverHour && dt.min >= 60 - InpRolloverBufferMin)
   {
      if(totalProfit >= 0.0)
      {
         CloseBasket("Pre-rollover close", true);
         return true;
      }
   }
   return false;
}

bool QQLowVolatilityOpportunity()
{
   if(snap.regime != REGIME_LOW_VOL)
      return true;
   if(QQNewsRiskScore() > g_tune.maxNewsRisk * 0.75)
      return false;
   bool squeeze = (snap.bbWidthM20 > 0.0 && snap.bbWidthM20 < 0.0042);
   double macroScore = 0.0;
   double setupScore = 0.0;
   int macroDir = QQMatrixMacroDirection(macroScore);
   int setupDir = QQMatrixSetupDirection(setupScore);
   bool aligned = (macroDir != 0 && macroDir == setupDir);
   bool liquid = (snap.session == 2 || snap.session == 3);
   bool precise = (QQEntryPrecisionScore() >= 64.0);
   if(QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_SMALL)
      return (squeeze && aligned && liquid && precise && QQLossAvoidanceScore() >= 78.0);
   return (squeeze && liquid && QQCompositeEdgeQualityScore() >= 68.0);
}

double QQEntryPrecisionScore()
{
   double score = 50.0;
   if(tf[TF_M1].candleBodyPct > 35.0 && tf[TF_M1].candleBodyPct < 78.0) score += 10.0;
   if(tf[TF_M5].rsi > 42.0 && tf[TF_M5].rsi < 68.0) score += 10.0;
   if(MathAbs(tf[TF_M5].close0 - tf[TF_M5].emaFast) <= MathMax(tf[TF_M5].atr * 1.3, 90.0 * _Point)) score += 12.0;
   if(tf[TF_M5].adx > 18.0) score += 8.0;
   if(snap.spread > QQEffectiveSpreadCap() * 0.75) score -= 18.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQLossAvoidanceScore()
{
   double score = 100.0;
   score -= GetDrawdownPct() * 3.2;
   score -= MathMax(0.0, snap.spread - QQEffectiveSpreadCap() * 0.55) * 1.8;
   score -= QQNewsRiskScore() * 0.38;
   if(basket.lossStreak > 0) score -= MathMin(36.0, basket.lossStreak * 9.0);
   if(g_capital.projectedDepositLoad > g_capital.maxDepositLoad * 0.70) score -= 22.0;
   if(g_capital.tier <= TIER_SMALL && !g_capital.canTradeMinLot) score -= 45.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQCompositeEdgeQualityScore()
{
   double score = 0.0;
   score += QQMTFConsensusScore() * 0.28;
   score += QQVolatilityTimeSweetSpotScore() * 0.22;
   score += QQEntryPrecisionScore() * 0.20;
   score += QQLossAvoidanceScore() * 0.18;
   score += g_pro.liquidityScore * 0.12;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQExpectedValueScore()
{
   double score = QQCompositeEdgeQualityScore();
   score += (g_opt.mtfConsensusScore - 50.0) * 0.18;
   score += (g_pro.brokerMicroScore - 50.0) * 0.12;
   score += (g_pro.adaptiveExposureScore - 50.0) * 0.10;
   score -= GetDrawdownPct() * 1.5;
   if(g_capital.tier <= TIER_SMALL) score += (QQLossAvoidanceScore() - 60.0) * 0.20;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQDirectionQualityScore(const int dir)
{
   if(dir == 0) return 0.0;
   double score = 50.0;
   if(g_matrix.macroDir == dir) score += 16.0;
   if(g_matrix.setupDir == dir) score += 12.0;
   if(g_matrix.timingDir == dir) score += 8.0;
   if(dir == 1 && g_profile.preferLongs) score += 8.0;
   if(dir == -1 && IsDangerousShortSetup()) score -= 24.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQStrategySpecificEdge(const int id, const int dir)
{
   double score = 0.0;
   if(id == 1 || id == 6) score += QQMTFConsensusScore() * 0.10;
   if(id == 2 || id == 7 || id == 9) score += QQEntryPrecisionScore() * 0.08;
   if(id == 4 || id == 8) score += QQVolatilityTimeSweetSpotScore() * 0.08;
   if(id == 5) score += QQSessionQualityScore() * 0.08;
   if(id == 11) score += QQLossAvoidanceScore() * 0.12;
   if(id == 12) score += QQCycleMemoryScore() * 0.08;
   if(dir != 0 && tf[g_strategyProfile[id].leaderTF].bias == dir) score += 6.0;
   return score;
}

void QQRunProfitabilityOptimizerRules()
{
   int count = (int)MathMin(1500.0, MathMax(1.0, InpOptimizerRules));
   double total = 0.0;
   int warnings = 0;
   int blocks = 0;
   for(int i=1; i<=count; i++)
   {
      double v = QQOptimizerRuleValue(i);
      total += v;
      if(v < 0.45) warnings++;
      if(v < 0.25) blocks++;
   }
   g_opt.rulesEvaluated = count;
   g_opt.qualityWarnings = warnings;
   g_opt.qualityBlocks = blocks;
   g_opt.optimizerScore = (count > 0 ? MathMax(0.0, MathMin(100.0, total / count * 100.0)) : 0.0);
}

double QQOptimizerRuleValue(const int ruleId)
{
   switch(ruleId)
   {
      case 1:
      {
         double v = 0.50;
         v += (tf[0].bias == g_matrix.macroDir && g_matrix.macroDir != 0 ? 0.16 : -0.06);
         v += (tf[0].adx > 18.0 ? 0.08 : -0.03);
         v += (g_opt.mtfConsensusScore / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 2:
      {
         double v = 0.50;
         v += (QQNewsRiskScore() <= g_tune.maxNewsRisk ? 0.16 : -0.20);
         v += (g_pro.timeHealthScore > 55.0 ? 0.08 : -0.10);
         v += (g_opt.volatilityTimeScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 3:
      {
         double v = 0.50;
         v += (snap.spread <= QQEffectiveSpreadCap() * 0.60 ? 0.15 : -0.16);
         v += (g_pro.liquidityScore / 100.0) * 0.12;
         v += (g_diag.executionHealthScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 4:
      {
