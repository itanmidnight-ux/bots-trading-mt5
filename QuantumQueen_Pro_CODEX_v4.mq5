int      g_tradesToday        = 0;
int      g_dayOfYear          = -1;
int      g_recoveryMagic      = 0;
double   g_dayStartBalance    = 0.0;
QQProfileState     g_profile;
QQCapitalState     g_capital;
QQEnvironmentState g_env;
QQDiagnosticsState g_diag;
QQMatrixState      g_matrix;
QQStrategyProfile  g_strategyProfile[STRATEGY_TOTAL + 1];
QQStrategyAudit    g_strategyAudit[STRATEGY_TOTAL + 1];
QQProfessionalSuiteState g_pro;
QQStrategyPerformanceState g_strategyPerf[STRATEGY_TOTAL + 1];
QQCapitalTuningState g_tune;
QQProfitabilityOptimizerState g_opt;
QQIndicatorEnsembleState g_ens;
datetime g_lastPersistTime    = 0;
datetime g_lastLogTime        = 0;
datetime g_lastNotifyTime     = 0;
datetime g_firstSeenTime       = 0;
long     g_nextCycleId        = 1;
string   g_lastBlockReason    = "Booting";
string   g_lastPanelExtra     = "";

//+------------------------------------------------------------------+
//| Initialization                                                    |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(InpMagicNumber);
   trade.SetDeviationInPoints(InpSlippage);
   trade.SetTypeFillingBySymbol(_Symbol);

   g_recoveryMagic = InpMagicNumber + RECOVERY_MAGIC_OFFSET;
   g_isHedging = ((ENUM_ACCOUNT_MARGIN_MODE)AccountInfoInteger(ACCOUNT_MARGIN_MODE) == ACCOUNT_MARGIN_MODE_RETAIL_HEDGING);

   if(!ValidateSymbolSetup())
      return INIT_FAILED;

   QQInitializeEngines();

   if(!InitTimeframes())
      return INIT_FAILED;

   ResetBasket(false);
   QQRestorePersistentState();
   DetectExistingBasket();
   ResetDailyCounterIfNeeded();
   EventSetTimer(30);

   g_initOk = true;
   Print("QuantumQueen MicroSafe Pro v6 Behavioral Twin loaded. Hedging=", (g_isHedging ? "YES" : "NO"), ", Symbol=", _Symbol, ", Profile=", g_profile.name, ", Tier=", g_capital.tierName);
   return INIT_SUCCEEDED;
}

void OnDeinit(const int reason)
{
   QQSavePersistentState("deinit");
   EventKillTimer();
   QQDeleteRealPanel();
   ReleaseIndicators();
   Comment("");
}

void OnChartEvent(const int id,
                  const long &lparam,
                  const double &dparam,
                  const string &sparam)
{
   if(id != CHARTEVENT_OBJECT_CLICK)
      return;

   if(sparam == QQ_PANEL_PREFIX + "pause_btn")
   {
      g_emergencyPaused = !g_emergencyPaused;
      QQSetBlockReason(g_emergencyPaused ? "Panel pause enabled" : "Panel pause disabled");
      ObjectSetInteger(0, sparam, OBJPROP_STATE, false);
      UpdatePanel();
   }
   else if(sparam == QQ_PANEL_PREFIX + "close_btn")
   {
      ClosePositionsByMagic(InpMagicNumber, 0);
      ClosePositionsByMagic(g_recoveryMagic, 0);
      ResetBasket(true);
      QQSetBlockReason("Panel close all trades");
      ObjectSetInteger(0, sparam, OBJPROP_STATE, false);
      UpdatePanel();
   }
}

//+------------------------------------------------------------------+
//| Main tick                                                         |
//+------------------------------------------------------------------+
void OnTick()
{
   if(!g_initOk)
      return;

   ResetDailyCounterIfNeeded();

   if(!FillSnapshot())
      return;

   if(HandleEmergencyDD())
   {
      UpdatePanel();
      return;
   }

   DetectExistingBasket();

   if(basket.active)
   {
      ManageActiveBasket();
      if(basket.active)
      {
         ManageRecoveryHedge();
         if(ShouldAddGridPosition(false))
            ExecuteGridTrade(false);
         else if(basket.cycleHealth >= CYCLE_HEALTH_DANGER && ShouldAddGridPosition(true))
            ExecuteGridTrade(true);
      }
      UpdatePanel();
      return;
   }

   CloseOrphanRecoveryIfNeeded();

   if(IsNewM1Bar() && CanOpenNewCycle())
   {
      StrategySignal sig = SelectBestStrategy();
      if(sig.direction != 0 && sig.score >= QQEffectiveMinEntryScore(sig.strategyId))
         StartNewCycle(sig);
   }

   UpdatePanel();
}


void OnTimer()
{
   if(!g_initOk)
      return;

   QQRefreshControlState();
   QQUpdateDiagnostics();
   if(InpUseCalibrationAudit == QQ_ON)
      QQRunCalibrationAudit();
   QQSavePersistentState("timer");
   UpdatePanel();
}

//+------------------------------------------------------------------+
//| Setup                                                             |
//+------------------------------------------------------------------+
bool ValidateSymbolSetup()
{
   if(InpStrictXAUUSD == QQ_ON)
   {
      string s = _Symbol;
      StringToUpper(s);
      if(StringFind(s, "XAU") < 0 && StringFind(s, "GOLD") < 0)
      {
         Print("ERROR: This build is restricted to XAUUSD/GOLD symbols. Current symbol: ", _Symbol);
         return false;
      }
   }

   if(InpRequire2Digits == QQ_ON)
   {
      int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
      if(digits != 2)
      {
         Print("ERROR: 2-decimal GOLD quote required. Current digits: ", digits);
         return false;
      }
   }

   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double step   = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   if(minLot <= 0 || step <= 0)
   {
      Print("ERROR: Invalid symbol volume settings.");
      return false;
   }

   return true;
}

bool InitTimeframes()
{
   ConfigureTF(TF_M1,  "M1",  PERIOD_M1,  8,  21,  55);
   ConfigureTF(TF_M5,  "M5",  PERIOD_M5,  20, 50,  100);
   ConfigureTF(TF_M6,  "M6",  PERIOD_M6,  10, 30,  80);
   ConfigureTF(TF_M12, "M12", PERIOD_M12, 20, 50,  100);
   ConfigureTF(TF_M15, "M15", PERIOD_M15, 20, 50,  100);
   ConfigureTF(TF_M20, "M20", PERIOD_M20, 20, 60,  120);
   ConfigureTF(TF_H1,  "H1",  PERIOD_H1,  50, 100, 200);
   ConfigureTF(TF_D1,  "D1",  PERIOD_D1,  10, 20,  50);

   for(int i=0; i<TF_TOTAL; i++)
   {
      if(tf[i].hFast == INVALID_HANDLE || tf[i].hSlow == INVALID_HANDLE ||
         tf[i].hTrend == INVALID_HANDLE || tf[i].hRSI == INVALID_HANDLE ||
         tf[i].hATR == INVALID_HANDLE || tf[i].hMACD == INVALID_HANDLE ||
         tf[i].hBands == INVALID_HANDLE || tf[i].hStoch == INVALID_HANDLE || tf[i].hADX == INVALID_HANDLE)
      {
         Print("ERROR: Failed to create indicator handles for ", tf[i].name);
         return false;
      }
   }

   return true;
}

void ConfigureTF(const int idx, const string name, const ENUM_TIMEFRAMES period,
                 const int fastPeriod, const int slowPeriod, const int trendPeriod)
{
   tf[idx].name      = name;
   tf[idx].period    = period;
   tf[idx].hFast     = iMA(_Symbol, period, fastPeriod, 0, MODE_EMA, PRICE_CLOSE);
   tf[idx].hSlow     = iMA(_Symbol, period, slowPeriod, 0, MODE_EMA, PRICE_CLOSE);
   tf[idx].hTrend    = iMA(_Symbol, period, trendPeriod, 0, MODE_SMA, PRICE_CLOSE);
   tf[idx].hRSI      = iRSI(_Symbol, period, 14, PRICE_CLOSE);
   tf[idx].hATR      = iATR(_Symbol, period, 14);
   tf[idx].hMACD     = iMACD(_Symbol, period, 12, 26, 9, PRICE_CLOSE);
   tf[idx].hBands    = iBands(_Symbol, period, 20, 0, 2.0, PRICE_CLOSE);
   tf[idx].hStoch    = iStochastic(_Symbol, period, 14, 3, 3, MODE_SMA, STO_LOWHIGH);
   tf[idx].hADX      = iADX(_Symbol, period, 14);
   tf[idx].ready     = false;
}

void ReleaseIndicators()
{
   for(int i=0; i<TF_TOTAL; i++)
   {
      if(tf[i].hFast  != INVALID_HANDLE) IndicatorRelease(tf[i].hFast);
      if(tf[i].hSlow  != INVALID_HANDLE) IndicatorRelease(tf[i].hSlow);
      if(tf[i].hTrend != INVALID_HANDLE) IndicatorRelease(tf[i].hTrend);
      if(tf[i].hRSI   != INVALID_HANDLE) IndicatorRelease(tf[i].hRSI);
      if(tf[i].hATR   != INVALID_HANDLE) IndicatorRelease(tf[i].hATR);
      if(tf[i].hMACD  != INVALID_HANDLE) IndicatorRelease(tf[i].hMACD);
      if(tf[i].hBands != INVALID_HANDLE) IndicatorRelease(tf[i].hBands);
      if(tf[i].hStoch != INVALID_HANDLE) IndicatorRelease(tf[i].hStoch);
      if(tf[i].hADX   != INVALID_HANDLE) IndicatorRelease(tf[i].hADX);
   }
}

//+------------------------------------------------------------------+
//| Snapshot                                                          |
//+------------------------------------------------------------------+
bool FillSnapshot()
{
   MqlTick tick;
   if(!SymbolInfoTick(_Symbol, tick))
      return false;

   snap.bid = tick.bid;
   snap.ask = tick.ask;
   snap.spread = (tick.ask - tick.bid) / _Point;

   bool allReady = true;
   for(int i=0; i<TF_TOTAL; i++)
   {
      if(!UpdateTF(i))
         allReady = false;
   }

   if(!allReady)
      return false;

   snap.m5AtrPoints = SafePoints(tf[TF_M5].atr);
   snap.m1RangePoints = SafePoints(tf[TF_M1].high0 - tf[TF_M1].low0);
   snap.volVelocity = (tf[TF_M5].atrPrev > 0.0 ? tf[TF_M5].atr / tf[TF_M5].atrPrev : 1.0);
   snap.bbWidthM20 = (tf[TF_M20].bbMiddle > 0.0 ? (tf[TF_M20].bbUpper - tf[TF_M20].bbLower) / tf[TF_M20].bbMiddle : 0.0);
   snap.session = GetSession();
   snap.macroBias = CalculateMacroBias();
   snap.localBias = CalculateLocalBias();
   snap.spreadWarn = (snap.spread > InpSoftSpreadCap);
   snap.spreadBlocked = IsSpreadBlocked();
   snap.extremeBlocked = IsExtremeVolatility();
   snap.regime = DetectRegime();
   QQRefreshControlState();
   QQProfessionalSuiteRefresh();

   return true;
}

bool UpdateTF(const int idx)
{
   TFState state = tf[idx];
   int sigShift = (InpUseClosedBarSignals == QQ_ON ? 1 : 0);
   int prevShift = sigShift + 1;

   bool ok = true;
   ok = ok && CopyOne(state.hFast, 0, sigShift, state.emaFast);
   ok = ok && CopyOne(state.hSlow, 0, sigShift, state.emaSlow);
   ok = ok && CopyOne(state.hTrend, 0, sigShift, state.emaTrend);
   ok = ok && CopyOne(state.hRSI, 0, sigShift, state.rsi);
   ok = ok && CopyOne(state.hATR, 0, sigShift, state.atr);
   ok = ok && CopyOne(state.hATR, 0, prevShift, state.atrPrev);
   ok = ok && CopyOne(state.hMACD, 0, sigShift, state.macdMain);
   ok = ok && CopyOne(state.hMACD, 1, sigShift, state.macdSignal);
   ok = ok && CopyOne(state.hBands, 0, sigShift, state.bbUpper);
   ok = ok && CopyOne(state.hBands, 1, sigShift, state.bbMiddle);
   ok = ok && CopyOne(state.hBands, 2, sigShift, state.bbLower);
   ok = ok && CopyOne(state.hStoch, 0, sigShift, state.stochMain);
   ok = ok && CopyOne(state.hStoch, 1, sigShift, state.stochSignal);
   ok = ok && CopyOne(state.hADX, 0, sigShift, state.adx);

   state.close0 = iClose(_Symbol, state.period, sigShift);
   state.close1 = iClose(_Symbol, state.period, prevShift);
   state.high0  = iHigh(_Symbol, state.period, sigShift);
   state.low0   = iLow(_Symbol, state.period, sigShift);
   state.atrSlope = (state.atrPrev > 0.0 ? (state.atr - state.atrPrev) / state.atrPrev : 0.0);
   state.bbWidthPct = (state.bbMiddle > 0.0 ? (state.bbUpper - state.bbLower) / state.bbMiddle * 100.0 : 0.0);
   state.macdSlope = state.macdMain - state.macdSignal;
   double range0 = MathMax(state.high0 - state.low0, _Point);
   state.candleBodyPct = MathAbs(state.close0 - state.close1) / range0 * 100.0;
   state.swingScore = QQSwingStructureScore(idx);

   if(state.close0 <= 0.0 || state.atr <= 0.0)
      ok = false;

   state.bias = 0;
   if(ok)
   {
      int score = 0;
      if(state.emaFast > state.emaSlow) score++;
      if(state.close0 > state.emaTrend) score++;
      if(state.rsi > 52.0) score++;
      if(state.macdMain > state.macdSignal) score++;
      if(state.adx > 18.0 && state.emaFast > state.emaSlow) score++;  // ENHANCED: ADX strength bonus LONG
      if(state.emaFast < state.emaSlow) score--;
      if(state.close0 < state.emaTrend) score--;
      if(state.rsi < 48.0) score--;
      if(state.macdMain < state.macdSignal) score--;
      if(state.adx > 18.0 && state.emaFast < state.emaSlow) score--;  // ENHANCED: ADX strength bonus SHORT

      // ENHANCED: Require 3 agreeing indicators (was 2) for cleaner bias detection
      if(score >= 3) state.bias = 1;
      else if(score <= -3) state.bias = -1;
      else state.bias = 0;
   }

   state.ready = ok;
   tf[idx] = state;
   return ok;
}

bool CopyOne(const int handle, const int buffer, const int shift, double &value)
{
   if(handle == INVALID_HANDLE)
      return false;

   double temp[];
   ArraySetAsSeries(temp, true);
   int copied = CopyBuffer(handle, buffer, shift, 1, temp);
   if(copied <= 0)
      return false;

   value = temp[0];
   if(value != value)
      return false;

   return true;
}

ENUM_MARKET_REGIME DetectRegime()
{
   if(snap.spreadBlocked || snap.extremeBlocked)
      return REGIME_EXTREME_VOL;

   if(snap.m5AtrPoints < InpMinATRPointsM5 || snap.volVelocity < InpLowVelocity)
      return REGIME_LOW_VOL;

   double trendStrengthM5 = MathAbs(tf[TF_M5].emaFast - tf[TF_M5].emaSlow) / MathMax(tf[TF_M5].atr, _Point);
   double trendStrengthH1 = MathAbs(tf[TF_H1].emaFast - tf[TF_H1].emaSlow) / MathMax(tf[TF_H1].atr, _Point);
   double trendStrengthD1 = MathAbs(tf[TF_D1].emaFast - tf[TF_D1].emaSlow) / MathMax(tf[TF_D1].atr, _Point);
   bool aligned = (snap.macroBias != 0 && snap.macroBias == snap.localBias);

   // ENHANCED: Extreme velocity block (was 2.1, now 1.8 for earlier protection)
   if(snap.volVelocity > 1.8)
      return REGIME_HIGH_VOL;

   // ENHANCED: Require D1 alignment for TREND classification (more rigorous)
   if(aligned && trendStrengthH1 > 0.45 && trendStrengthD1 > 0.25 &&
      (trendStrengthM5 > 0.55 || trendStrengthH1 > 0.50))
      return REGIME_TREND;

   if(snap.bbWidthM20 > 0.0 && snap.bbWidthM20 < 0.0040 && MathAbs(tf[TF_M20].rsi - 50.0) < 10.0)
      return REGIME_RANGE;

   return REGIME_TRANSITION;
}

int CalculateMacroBias()
{
   // ENHANCED: Multi-layer macro bias with RSI/MACD confirmations
   int score = 0;
   score += tf[TF_D1].bias * 2;
   score += tf[TF_H1].bias * 2;
   score += tf[TF_M20].bias;
   score += tf[TF_M15].bias;

   // ENHANCED: RSI/MACD dual confirmation for macro layer
   if(tf[TF_D1].rsi > 54.0 && tf[TF_H1].rsi > 52.0) score++;
   if(tf[TF_D1].rsi < 46.0 && tf[TF_H1].rsi < 48.0) score--;
   if(tf[TF_H1].macdMain > tf[TF_H1].macdSignal && tf[TF_D1].macdMain > tf[TF_D1].macdSignal) score++;
   if(tf[TF_H1].macdMain < tf[TF_H1].macdSignal && tf[TF_D1].macdMain < tf[TF_D1].macdSignal) score--;

   // ENHANCED: Require stronger consensus (4 vs 3 previously) for lower false macro reads
   if(score >= 4) return 1;
   if(score <= -4) return -1;
   return 0;
}

int CalculateLocalBias()
{
   int score = 0;
   score += tf[TF_M1].bias;
   score += tf[TF_M5].bias * 2;
   score += tf[TF_M6].bias;
   score += tf[TF_M12].bias;

   if(score >= 3) return 1;
   if(score <= -3) return -1;
   return 0;
}

bool IsExtremeVolatility()
{
   if(InpFilterVolatility == QQ_OFF)
      return false;

   if(snap.volVelocity > InpExtremeVelocity)
      return true;

   if(tf[TF_M1].atr > 0.0 && snap.m1RangePoints > SafePoints(tf[TF_M1].atr) * 3.5)
      return true;

   return false;
}

bool IsSpreadBlocked()
{
   int cap = QQEffectiveSpreadCap();
   return (snap.spread > cap);
}

double SafePoints(const double priceDistance)
{
   if(_Point <= 0.0)
      return 0.0;
   return priceDistance / _Point;
}

//+------------------------------------------------------------------+
//| Entry control                                                     |
//+------------------------------------------------------------------+
bool CanOpenNewCycle()
{
   QQRefreshControlState();
   if(!QQGateNewCycle())
      return false;

   if(InpPause == QQ_ON || g_emergencyPaused)
      return false;

   if(AccountInfoDouble(ACCOUNT_BALANCE) < InpMinBalance)
      return false;

   if(IsMicroSurvivalAccount() && IsMicroDailyLossBreached())
      return false;

   if(g_tradesToday >= QQEffectiveMaxCyclesPerDay())
   {
      QQSetBlockReason("Daily cycle limit reached");
      return false;
   }

   if(TimeCurrent() - basket.lastExitTime < InpMinMinutesBetweenCycles * 60)
      return false;

   if(CountMainPositions(0) > 0 || CountRecoveryPositions(0) > 0)
      return false;

   if(snap.session == 0)
      return false;

   if(InpHolidayFilter == QQ_ON && IsHolidayBlock())
      return false;

   if(snap.spreadBlocked || snap.extremeBlocked)
      return false;

   if(snap.regime == REGIME_LOW_VOL && !QQLowVolatilityOpportunity())
      return false;

   if(snap.regime == REGIME_EXTREME_VOL || snap.regime == REGIME_BLOCKED)
      return false;

   if(InpFilterCorrelation == QQ_ON && IsCorrelationBlocked())
      return false;

   if(GetDrawdownPct() > QQEffectiveDDLimit() * 0.50)
      return false;

   if(GetMarginLevelPct() > 0.0 && GetMarginLevelPct() < InpMarginWarnPct)
      return false;

   return true;
}

StrategySignal SelectBestStrategy()
{
   return QQSelectMatrixStrategy();
}

void QQInitializeStrategyMatrix()
{
   for(int i=0; i<=STRATEGY_TOTAL; i++)
   {
      g_strategyProfile[i].id = i;
      g_strategyProfile[i].family = FAMILY_CORE;
      g_strategyProfile[i].leaderTF = TF_M15;
      g_strategyProfile[i].baseMinScore = 5.0;
      g_strategyProfile[i].cooldownSec = 45 * 60;
      g_strategyProfile[i].highRiskOnly = false;
      g_strategyProfile[i].microOnly = false;
      g_strategyProfile[i].standardPlusOnly = false;
      g_strategyProfile[i].entryAllowed = true;
      g_strategyProfile[i].requiresSession = false;
      g_strategyProfile[i].allowsRange = false;
      g_strategyProfile[i].allowsHighVol = false;
      g_strategyProfile[i].name = "";
      g_strategyAudit[i].status = "OFF | Awaiting signals ...";
      g_strategyAudit[i].lastReason = "";
      g_strategyAudit[i].lastBlock = "";
   }

   QQSetStrategyProfile(1,  FAMILY_CORE,      TF_M15, 5.0,  60, false, false, false, true,  false, false, false, "Trend Continuation");
   QQSetStrategyProfile(2,  FAMILY_PULLBACK,  TF_M12, 5.4,  90, false, false, false, true,  false, false, false, "Trend Pullback");
   QQSetStrategyProfile(3,  FAMILY_RANGE,     TF_M5,  6.0, 120, false, false, false, true,  false, true,  false, "Range Reversal");
   QQSetStrategyProfile(4,  FAMILY_VOLATILE,  TF_M5,  6.5, 180, true,  false, false, true,  false, false, true,  "Volatility Breakout");
   QQSetStrategyProfile(5,  FAMILY_SESSION,   TF_M5,  6.3, 180, true,  false, false, true,  true,  false, true,  "Session Impulse");
   QQSetStrategyProfile(6,  FAMILY_CORE,      TF_M20, 5.2,  75, false, false, false, true,  false, false, false, "MTF Alignment");
   QQSetStrategyProfile(7,  FAMILY_PULLBACK,  TF_M12, 5.7, 100, false, false, false, true,  false, false, false, "M12/M15 Momentum");
   QQSetStrategyProfile(8,  FAMILY_VOLATILE,  TF_M20, 6.0, 150, false, false, false, true,  false, false, true,  "M20 Squeeze");
   QQSetStrategyProfile(9,  FAMILY_MACRO,     TF_H1,  5.8, 135, false, false, false, true,  false, false, false, "H1 Retest");
   QQSetStrategyProfile(10, FAMILY_MACRO,     TF_D1,  6.4, 240, false, false, true,  true,  false, false, false, "D1 Continuation");
   QQSetStrategyProfile(11, FAMILY_DEFENSIVE, TF_M5,  5.9, 120, false, true,  false, true,  false, false, false, "Defensive Micro Entry");
   QQSetStrategyProfile(12, FAMILY_RECOVERY,  TF_H1,  6.2, 240, false, false, true,  true,  false, false, false, "Recovery-Ready Trend");
}

void QQSetStrategyProfile(const int id,
                          const ENUM_QQ_STRATEGY_FAMILY family,
                          const int leaderTF,
                          const double minScore,
                          const int cooldownMinutes,
                          const bool highRiskOnly,
                          const bool microOnly,
                          const bool standardPlusOnly,
                          const bool entryAllowed,
                          const bool requiresSession,
                          const bool allowsRange,
                          const bool allowsHighVol,
                          const string name)
{
   if(id < 1 || id > STRATEGY_TOTAL)
      return;
   g_strategyProfile[id].id = id;
   g_strategyProfile[id].family = family;
   g_strategyProfile[id].leaderTF = leaderTF;
   g_strategyProfile[id].baseMinScore = minScore;
   g_strategyProfile[id].cooldownSec = MathMax(30, cooldownMinutes) * 60;
   g_strategyProfile[id].highRiskOnly = highRiskOnly;
   g_strategyProfile[id].microOnly = microOnly;
   g_strategyProfile[id].standardPlusOnly = standardPlusOnly;
   g_strategyProfile[id].entryAllowed = entryAllowed;
   g_strategyProfile[id].requiresSession = requiresSession;
   g_strategyProfile[id].allowsRange = allowsRange;
   g_strategyProfile[id].allowsHighVol = allowsHighVol;
   g_strategyProfile[id].name = name;
}

StrategySignal QQSelectMatrixStrategy()
{
   StrategySignal best;
   best.direction = 0;
   best.strategyId = 0;
   best.score = 0.0;
   best.reason = "";

   QQBuildMatrixState();
   QQResetStrategyStatuses();

   if(g_matrix.blockReason != "")
   {
      QQSetBlockReason(g_matrix.blockReason);
      return best;
   }

   for(int id=1; id<=STRATEGY_TOTAL; id++)
   {
      string block = "";
      if(!QQMatrixAllowsStrategy(id, block))
      {
         QQMarkStrategyBlocked(id, block);
         continue;
      }

      StrategySignal s = EvaluateStrategy(id);
      if(s.direction == 0)
      {
         QQMarkStrategyBlocked(id, "setup");
         continue;
      }

      if(!QQMatrixDirectionAllowed(id, s.direction, block))
      {
         QQMarkStrategyBlocked(id, block);
         continue;
      }

      double matrixScore = QQMatrixConfluenceScore(id, s.direction);
      double edgeScore = QQStrategyEdgeScore(id, s.direction);
      if(InpUseEdgeQualityGate == QQ_ON && !QQEdgeQualityAllowsEntry(id, s.direction, edgeScore, block))
      {
         QQMarkStrategyBlocked(id, block);
         continue;
      }
      double patiencePenalty = QQNoTradePatiencePenalty(id);
      s.score += matrixScore;
      s.score += QQEdgeScoreToMatrixBoost(edgeScore);
      s.score -= patiencePenalty;
      g_matrix.patiencePenalty = patiencePenalty;
      g_matrix.entryScore = MathMax(g_matrix.entryScore, s.score);

      QQMarkStrategyCandidate(id, s);

      double minScore = QQMatrixMinScore(id);
      if(s.direction != 0 && s.score >= minScore && s.score > best.score)
         best = s;
   }

   if(best.direction != 0)
   {
      g_matrix.bestStrategy = best.strategyId;
      g_matrix.phase = "entry";
      g_strategyAudit[best.strategyId].status = StringFormat("ON | Candidate score: %.1f", best.score);
      g_strategyAudit[best.strategyId].lastReason = best.reason;
   }
   else
   {
      g_matrix.phase = "waiting";
      if(g_lastBlockReason == "" || g_lastBlockReason == "Initialized")
         QQSetBlockReason("Matrix waiting for clean MTF confluence");
   }

   return best;
}

void QQBuildMatrixState()
{
   g_matrix.lastUpdate = TimeCurrent();
   g_matrix.macroDir = QQMatrixMacroDirection(g_matrix.macroScore);
   g_matrix.setupDir = QQMatrixSetupDirection(g_matrix.setupScore);
   g_matrix.timingDir = QQMatrixTimingDirection(g_matrix.timingScore);
   g_matrix.regimeScore = QQMatrixRegimeScore();
   g_matrix.newsRiskScore = QQNewsRiskScore();
   g_matrix.brokerHealthScore = QQBrokerHealthScore();
   g_matrix.entryScore = 0.0;
   g_matrix.bestStrategy = 0;
   g_matrix.blockReason = "";
   g_matrix.phase = "scan";

   if(g_matrix.newsRiskScore >= 70.0)
      g_matrix.blockReason = "Matrix news/shock risk";
   else if(InpUseBrokerHealth == QQ_ON && g_matrix.brokerHealthScore < 35.0)
      g_matrix.blockReason = "Matrix broker health";
   else if(snap.spreadBlocked)
      g_matrix.blockReason = "Matrix spread";
   else if(snap.extremeBlocked || snap.regime == REGIME_EXTREME_VOL || snap.regime == REGIME_BLOCKED)
      g_matrix.blockReason = "Matrix volatility shock";
   else if(snap.regime == REGIME_LOW_VOL && !QQLowVolatilityOpportunity())
      g_matrix.blockReason = "Matrix low volatility";
   // ENHANCED: Require at least 2 of 3 matrix layers to agree on direction
   else if(g_matrix.macroDir != 0 || g_matrix.setupDir != 0 || g_matrix.timingDir != 0)
   {
      int longVotes  = (g_matrix.macroDir == 1 ? 1 : 0) + (g_matrix.setupDir == 1 ? 1 : 0) + (g_matrix.timingDir == 1 ? 1 : 0);
      int shortVotes = (g_matrix.macroDir == -1 ? 1 : 0) + (g_matrix.setupDir == -1 ? 1 : 0) + (g_matrix.timingDir == -1 ? 1 : 0);
      if(longVotes < 2 && shortVotes < 2 && g_matrix.macroDir != 0)
         g_matrix.blockReason = "Matrix layers divergent";
   }
   // ENHANCED: Block if news risk exceeds 50% on small/low capital accounts
   if(g_matrix.blockReason == "" && g_matrix.newsRiskScore >= 50.0 &&
      (g_capital.tier <= TIER_SMALL || QQEffectiveCapitalMode() == CAP_LOW))
      g_matrix.blockReason = "News risk elevated (low capital protection)";
}

void QQResetStrategyStatuses()
{
   for(int i=1; i<=STRATEGY_TOTAL; i++)
   {
      if(!QQStrategyEnabled(i))
         g_strategyAudit[i].status = "OFF | Awaiting signals ...";
      else
         g_strategyAudit[i].status = "ON | Awaiting signals ...";
      g_strategyAudit[i].lastScore = 0.0;
      g_strategyAudit[i].lastDirection = 0;
   }
}

int QQMatrixMacroDirection(double &scoreOut)
{
   double score = 0.0;
   score += tf[TF_D1].bias * 2.5;
   score += tf[TF_H1].bias * 2.2;
   score += tf[TF_M20].bias * 1.4;
   score += tf[TF_M15].bias * 1.1;
   score += (tf[TF_D1].swingScore + tf[TF_H1].swingScore) * 0.45;
   if(tf[TF_H1].adx > 22.0) score += tf[TF_H1].bias * 0.6;
   if(tf[TF_M20].adx > 20.0) score += tf[TF_M20].bias * 0.4;
   scoreOut = score;
   if(score >= 3.0) return 1;
   if(score <= -3.0) return -1;
   return 0;
}

int QQMatrixSetupDirection(double &scoreOut)
{
   double score = 0.0;
   score += tf[TF_M20].bias * 1.6;
   score += tf[TF_M15].bias * 1.4;
   score += tf[TF_M12].bias * 1.2;
   score += tf[TF_M5].bias * 0.8;
   if(tf[TF_M15].macdMain > tf[TF_M15].macdSignal) score += 0.5;
   if(tf[TF_M15].macdMain < tf[TF_M15].macdSignal) score -= 0.5;
   if(tf[TF_M12].rsi > 53.0) score += 0.4;
   if(tf[TF_M12].rsi < 47.0) score -= 0.4;
   scoreOut = score;
   if(score >= 2.2) return 1;
   if(score <= -2.2) return -1;
   return 0;
}

int QQMatrixTimingDirection(double &scoreOut)
{
   double score = 0.0;
   score += tf[TF_M5].bias * 1.4;
   score += tf[TF_M6].bias * 1.0;
   score += tf[TF_M1].bias * 0.8;
   if(tf[TF_M1].close0 > tf[TF_M1].emaFast) score += 0.3;
   if(tf[TF_M1].close0 < tf[TF_M1].emaFast) score -= 0.3;
   if(tf[TF_M5].rsi > 52.0) score += 0.3;
   if(tf[TF_M5].rsi < 48.0) score -= 0.3;
   scoreOut = score;
   if(score >= 1.8) return 1;
   if(score <= -1.8) return -1;
   return 0;
}

double QQMatrixRegimeScore()
{
   if(snap.regime == REGIME_TREND)      return 2.2;
   if(snap.regime == REGIME_TRANSITION) return 1.1;
   if(snap.regime == REGIME_RANGE)      return 0.7;
   if(snap.regime == REGIME_HIGH_VOL)   return 0.9;
   return -2.0;
}

bool QQMatrixAllowsStrategy(const int id, string &block)
{
   block = "";
   if(id < 1 || id > STRATEGY_TOTAL)
   {
      block = "invalid";
      return false;
   }
   if(!QQStrategyEnabled(id))
   {
      block = "disabled";
      return false;
   }

   QQStrategyProfile p = g_strategyProfile[id];
   if(!p.entryAllowed)
   {
      block = "not entry";
      return false;
   }
   if(p.highRiskOnly && !QQHighRiskStrategiesAllowed())
   {
      block = "risk set";
      return false;
   }
   if(p.microOnly && QQEffectiveCapitalMode() != CAP_LOW && g_capital.tier > TIER_LOW)
   {
      block = "micro only";
      return false;
   }
   if(p.standardPlusOnly && g_capital.tier < TIER_STANDARD && QQEffectiveCapitalMode() != CAP_HIGH)
   {
      block = "capital";
      return false;
   }
   if(p.requiresSession && snap.session == 0)
   {
      block = "session";
      return false;
   }
   if(QQStrategyOnCooldown(id))
   {
      block = "cooldown";
      return false;
   }
   if(!QQMatrixStageAllowsStrategy(id))
   {
      block = "matrix stage";
      return false;
   }
   return true;
}

bool QQHighRiskStrategiesAllowed()
{
   if(InpSets == SET_RAW_HIGH)
      return true;
   if(g_profile.allowHighRisk || g_profile.allowStrategy4 || g_profile.allowStrategy5)
      return true;
   if(g_profile.profile == QQ_PROFILE_VT_FAST && QQEffectiveCapitalMode() == CAP_HIGH)
      return true;
   return false;
}

bool QQMatrixStageAllowsStrategy(const int id)
{
   ENUM_QQ_STRATEGY_FAMILY f = g_strategyProfile[id].family;
   if(QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_MICRO)
      return (id == 1 || id == 6 || id == 11);

   if(snap.regime == REGIME_TREND)
      return (f == FAMILY_CORE || f == FAMILY_PULLBACK || f == FAMILY_MACRO || f == FAMILY_DEFENSIVE || f == FAMILY_RECOVERY);
   if(snap.regime == REGIME_RANGE)
      return (f == FAMILY_RANGE || id == 11);
   if(snap.regime == REGIME_TRANSITION)
      return (f == FAMILY_PULLBACK || f == FAMILY_CORE || f == FAMILY_VOLATILE || f == FAMILY_MACRO || id == 11);
   if(snap.regime == REGIME_HIGH_VOL)
      return (f == FAMILY_VOLATILE || f == FAMILY_SESSION || id == 1 || id == 6);
   if(snap.regime == REGIME_LOW_VOL)
      return (id == 8 || id == 11);
   return false;
}

bool QQMatrixDirectionAllowed(const int id, const int dir, string &block)
{
   block = "";
   if(dir == 0)
   {
      block = "direction";
      return false;
   }

   if(g_strategyProfile[id].family == FAMILY_RANGE)
   {
      if(MathAbs(g_matrix.macroScore) > 4.2 && g_matrix.macroDir != 0 && g_matrix.macroDir != dir)
      {
         block = "macro";
         return false;
      }
      return true;
   }

   if(g_matrix.macroDir != 0 && dir != g_matrix.macroDir)
   {
      block = "macro";
      return false;
   }
   if(g_matrix.setupDir != 0 && dir != g_matrix.setupDir && id != 2 && id != 9 && id != 11)
   {
      block = "setup";
      return false;
   }
   if(g_matrix.timingDir != 0 && dir != g_matrix.timingDir && id != 10 && id != 12)
   {
      block = "timing";
      return false;
   }
   if(dir == -1 && InpStrictShorts == QQ_ON && !QQStrictShortMatrixAllowed(id))
   {
      block = "short filter";
      return false;
   }
   return true;
}

bool QQStrictShortMatrixAllowed(const int id)
{
   if(id == 3 && snap.regime == REGIME_RANGE)
      return true;
   int bearish = 0;
   if(tf[TF_D1].bias < 0) bearish++;
   if(tf[TF_H1].bias < 0) bearish++;
   if(tf[TF_M20].bias < 0) bearish++;
   if(tf[TF_M15].bias < 0) bearish++;
   if(tf[TF_M5].bias < 0) bearish++;
   return (bearish >= 4 && !IsDangerousShortSetup());
}

double QQMatrixConfluenceScore(const int id, const int dir)
{
   double score = 0.0;
   if(g_matrix.macroDir == dir) score += 1.6;    // Was 1.4 - higher macro weight
   if(g_matrix.setupDir == dir) score += 1.2;    // Was 1.1
   if(g_matrix.timingDir == dir) score += 0.9;   // Was 0.8
   if(tf[g_strategyProfile[id].leaderTF].bias == dir) score += 0.9; // Was 0.8
   if(tf[g_strategyProfile[id].leaderTF].adx > 20.0) score += 0.40; // Was 0.35
   if(tf[g_strategyProfile[id].leaderTF].atrSlope > -0.08) score += 0.25;
   if(g_matrix.regimeScore > 0.0) score += g_matrix.regimeScore * 0.38; // Was 0.35
   if(dir == 1 && g_profile.preferLongs) score += 0.30;   // Was 0.25 - gold is naturally bullish biased
   if(dir == -1 && g_profile.preferLongs) score -= 0.50;  // Was -0.35 - stronger short penalty

   // ENHANCED: Stronger news penalty applied earlier
   if(g_matrix.newsRiskScore > 35.0) score -= 1.5;  // Was -1.2 at 45
   else if(g_matrix.newsRiskScore > 25.0) score -= 0.8;
   if(g_matrix.brokerHealthScore < 55.0) score -= 0.9;   // Was -0.8

   if(g_capital.tier <= TIER_SMALL && id != 1 && id != 6 && id != 11) score -= 1.3; // Was -1.1
   if(id == 4 || id == 5) score += (QQHighRiskStrategiesAllowed() ? 0.5 : -3.0);
   if(id == 12 && !g_profile.allowRecovery) score -= 2.0;

   if(InpUseProfitabilityOptimizer == QQ_ON)
   {
      score += (g_opt.edgeQualityScore - 50.0) / 35.0;
      score += (g_opt.expectedValueScore - 50.0) / 45.0;
      score += g_tune.scoreDiscount;
      score -= g_tune.scorePremium;
   }

   // ENHANCED: Triple layer confirmation bonus
   if(g_matrix.macroDir == dir && g_matrix.setupDir == dir && g_matrix.timingDir == dir)
      score += 1.0;  // Full 3-layer alignment = quality premium

   return score;
}

double QQMatrixMinScore(const int id)
{
   double minScore = MathMax((double)QQEffectiveMinEntryScore(id), g_strategyProfile[id].baseMinScore);
   if(QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_MICRO)
      minScore = MathMax(minScore, 8.0);
   if(QQEffectiveCapitalMode() == CAP_MEDIAN)
      minScore = MathMax(minScore, 6.6);
   if(id == 4 || id == 5)
      minScore += 0.8;
   if(g_diag.brokerHealthScore < 55.0)
      minScore += 0.5;
   if(basket.lossStreak > 0)
      minScore += MathMin(1.5, basket.lossStreak * 0.35);
   if(InpUseCapitalAutoTune == QQ_ON)
   {
      minScore = MathMax(minScore, g_tune.minMatrixScore);
      minScore += g_tune.scorePremium;
      minScore -= g_tune.scoreDiscount;
      if(g_opt.optimizerScore > 72.0 && g_opt.expectedValueScore > 68.0)
         minScore -= 0.35;
      if(g_opt.lossAvoidanceScore < 50.0)
         minScore += 0.55;
   }
   return minScore;
}

double QQNoTradePatiencePenalty(const int id)
{
   double penalty = 0.0;
   if(g_capital.tier <= TIER_SMALL || QQEffectiveCapitalMode() == CAP_LOW)
      penalty += 0.45;
   if(g_diag.blockedCycles > 0 && g_diag.blockedCycles < 4)
      penalty += 0.10;
   if(basket.lossStreak > 0)
      penalty += MathMin(0.9, basket.lossStreak * 0.25);
   if(snap.spread > QQEffectiveSpreadCap() * 0.70)
      penalty += 0.55;
   if(g_matrix.newsRiskScore > 35.0)
      penalty += 0.45;
   if(id == 4 || id == 5)
      penalty += 0.20;
   return penalty;
}

bool QQStrategyOnCooldown(const int id)
{
   datetime last = g_strategyAudit[id].lastEntryTime;
   if(id == 4 || id == 5)
   {
      if(g_strategyAudit[id].lastSignalTime > last)
         last = g_strategyAudit[id].lastSignalTime;
   }
   if(last <= 0)
      return false;
   int cooldown = g_strategyProfile[id].cooldownSec;
   if(id == 4 || id == 5)
      cooldown = MathMax(cooldown, 240 * 60);
   if(QQEffectiveCapitalMode() == CAP_LOW)
      cooldown = MathMax(cooldown, 180 * 60);
   return (TimeCurrent() - last < cooldown);
}

void QQMarkStrategyBlocked(const int id, const string block)
{
   if(id < 1 || id > STRATEGY_TOTAL)
      return;
   if(!QQStrategyEnabled(id))
      g_strategyAudit[id].status = "OFF | Awaiting signals ...";
   else
      g_strategyAudit[id].status = "ON | Blocked: " + block;
   g_strategyAudit[id].lastBlock = block;
   g_strategyAudit[id].lastBlockTime = TimeCurrent();
   g_strategyAudit[id].blockedCount++;
}

void QQMarkStrategyCandidate(const int id, const StrategySignal &s)
{
   if(id < 1 || id > STRATEGY_TOTAL)
      return;
   g_strategyAudit[id].status = StringFormat("ON | Candidate score: %.1f", s.score);
   g_strategyAudit[id].lastSignalTime = TimeCurrent();
   g_strategyAudit[id].lastDirection = s.direction;
   g_strategyAudit[id].lastScore = s.score;
   g_strategyAudit[id].lastReason = s.reason;
   g_strategyAudit[id].candidateCount++;
}

void QQStrategyMarkEntry(const int id)
{
   if(id < 1 || id > STRATEGY_TOTAL)
      return;
   g_strategyAudit[id].lastEntryTime = TimeCurrent();
   g_strategyAudit[id].lastSignalTime = TimeCurrent();
   g_strategyAudit[id].entryCount++;
   g_strategyAudit[id].status = "ON | Active cycle ...";
}

StrategySignal EvaluateStrategy(const int id)
{
   StrategySignal s;
   s.direction = 0;
   s.strategyId = id;
   s.score = 0.0;
   s.reason = "";

   if(!QQStrategyEnabled(id))
      return s;

   switch(id)
   {
      case 1:  StrategyTrendContinuation(s); break;
      case 2:  StrategyTrendPullback(s);     break;
      case 3:  StrategyRangeReversal(s);     break;
      case 4:  StrategyVolBreakout(s);       break;
      case 5:  StrategySessionImpulse(s);    break;
      case 6:  StrategyMTFAlignment(s);      break;
      case 7:  StrategyM12M15Momentum(s);    break;
      case 8:  StrategyM20Squeeze(s);        break;
      case 9:  StrategyH1Retest(s);          break;
      case 10: StrategyD1Continuation(s);    break;
      case 11: StrategyDefensiveEntry(s);    break;
      case 12: StrategyRecoveryReady(s);     break;
   }

   if(s.direction != 0)
   {
      if(!IsDirectionAllowedForStrategy(s.direction, id))
      {
         s.direction = 0;
         s.score = 0.0;
         return s;
      }

      int cascadeScore = CascadeScore(s.direction);
      s.score += cascadeScore;
      // ENHANCED: Minimum cascade threshold raised to 7 (was 4) for higher quality entries
      int minCascade = (g_capital.tier <= TIER_SMALL ? 8 : 7);
      if(snap.regime == REGIME_HIGH_VOL) minCascade++;
      if(!IsCandleConfirming(s.direction) || cascadeScore < minCascade)
      {
         s.direction = 0;
         s.score = 0.0;
      }
      else if(InpUseFullIndicatorEnsemble == QQ_ON)
      {
         double ensembleScore = QQIndicatorEnsembleScore(id, s.direction);
         if(!QQIndicatorEnsembleAllowsEntry(id, s.direction, ensembleScore))
         {
            s.direction = 0;
            s.score = 0.0;
         }
         else
         {
            s.score += QQEnsembleBoost(ensembleScore);
         }
      }

      if(s.direction != 0 && InpUseMTFStructureGate == QQ_ON)
      {
         string structureBlock = "";
         double structureScore = QQMTFStructureScore(id, s.direction, structureBlock);
         if(!QQMTFStructureAllowsEntry(id, s.direction, structureScore, structureBlock))
         {
            s.direction = 0;
            s.score = 0.0;
         }
         else
         {
            s.score += QQStructureBoost(structureScore);
            s.reason = s.reason + StringFormat(" | MTF structure %.1f", structureScore);
         }
      }
   }

   return s;
}

void StrategyTrendContinuation(StrategySignal &s)
{
   if(snap.regime != REGIME_TREND)
      return;

   int dir = snap.macroBias;
   if(dir == 0 || dir != snap.localBias)
      return;

   if(tf[TF_M15].adx < 22.0)
      return;

   bool macdBuy = (tf[TF_M15].macdMain > tf[TF_M15].macdSignal && tf[TF_M5].macdMain > tf[TF_M5].macdSignal);
   bool macdSell = (tf[TF_M15].macdMain < tf[TF_M15].macdSignal && tf[TF_M5].macdMain < tf[TF_M5].macdSignal);

   if(dir == 1 && tf[TF_M5].rsi > 52.0 && tf[TF_M5].rsi < 72.0 && tf[TF_M1].close0 > tf[TF_M1].emaFast && macdBuy)
   {
      s.direction = 1;
      s.score = 5.0;
      s.reason = "S01 Trend cont BUY";
   }
   else if(dir == -1 && tf[TF_M5].rsi < 48.0 && tf[TF_M5].rsi > 28.0 && tf[TF_M1].close0 < tf[TF_M1].emaFast && macdSell)
   {
      s.direction = -1;
      s.score = 5.0;
      s.reason = "S01 Trend cont SELL";
   }
}

void StrategyTrendPullback(StrategySignal &s)
{
   if(snap.regime != REGIME_TREND && snap.regime != REGIME_TRANSITION)
      return;

   int dir = snap.macroBias;
   if(dir == 0)
      return;

   bool pullbackBuy = (dir == 1 && tf[TF_M1].low0 <= tf[TF_M5].emaFast && tf[TF_M1].rsi > 45.0 && tf[TF_M6].bias >= 0);
   bool pullbackSell = (dir == -1 && tf[TF_M1].high0 >= tf[TF_M5].emaFast && tf[TF_M1].rsi < 55.0 && tf[TF_M6].bias <= 0);

   if(pullbackBuy)
   {
      s.direction = 1;
      s.score = 3.7;
      if(HasBullishDivergence(TF_M5, 5)) s.score += 0.8;
      s.reason = "S02 Trend pullback BUY";
   }
   else if(pullbackSell)
   {
      s.direction = -1;
      s.score = 3.7;
      if(HasBearishDivergence(TF_M5, 5)) s.score += 0.8;
      s.reason = "S02 Trend pullback SELL";
   }
}

void StrategyRangeReversal(StrategySignal &s)
{
   if(snap.regime != REGIME_RANGE)
      return;

   bool buy = (tf[TF_M5].close0 < tf[TF_M5].bbLower && tf[TF_M5].rsi < 36.0 && tf[TF_M1].stochMain > tf[TF_M1].stochSignal);
   bool sell = (tf[TF_M5].close0 > tf[TF_M5].bbUpper && tf[TF_M5].rsi > 64.0 && tf[TF_M1].stochMain < tf[TF_M1].stochSignal);

   if(buy && snap.macroBias >= 0)
   {
      s.direction = 1;
      s.score = 3.4;
      if(HasBullishDivergence(TF_M5, 5)) s.score += 0.9;
      s.reason = "S03 Range reversal BUY";
   }
   else if(sell && snap.macroBias <= 0)
   {
      s.direction = -1;
      s.score = 3.4;
      if(HasBearishDivergence(TF_M5, 5)) s.score += 0.9;
      s.reason = "S03 Range reversal SELL";
   }
}

void StrategyVolBreakout(StrategySignal &s)
{
   if(snap.regime != REGIME_HIGH_VOL && snap.regime != REGIME_TRANSITION)
      return;

   bool buy = (tf[TF_M1].close0 > tf[TF_M5].bbUpper && tf[TF_M5].macdMain > tf[TF_M5].macdSignal && snap.localBias == 1);
   bool sell = (tf[TF_M1].close0 < tf[TF_M5].bbLower && tf[TF_M5].macdMain < tf[TF_M5].macdSignal && snap.localBias == -1);

   if(buy && snap.macroBias >= 0 && snap.volVelocity < InpExtremeVelocity)
   {
      s.direction = 1;
      s.score = 3.6;
      s.reason = "S04 Volatility breakout BUY";
   }
   else if(sell && !IsDangerousShortSetup() && snap.macroBias == -1 && snap.volVelocity < InpExtremeVelocity)
   {
      s.direction = -1;
      s.score = 3.2;
      s.reason = "S04 Volatility breakout SELL";
   }
}

void StrategySessionImpulse(StrategySignal &s)
{
   if(snap.session == 0 || snap.regime == REGIME_RANGE)
      return;

   double body = MathAbs(tf[TF_M1].close0 - tf[TF_M1].close1);
   double prevBody = MathAbs(iClose(_Symbol, PERIOD_M1, 1) - iOpen(_Symbol, PERIOD_M1, 1));
   bool impulse = (SafePoints(body) > MathMax(50.0, SafePoints(tf[TF_M1].atr) * 0.70) && body > prevBody * 1.4);
   if(!impulse)
      return;

   bool m5Confirms = (tf[TF_M5].adx > 18.0);
   if(tf[TF_M1].close0 > tf[TF_M1].close1 && snap.localBias == 1 && snap.macroBias >= 0 && m5Confirms)
   {
      s.direction = 1;
      s.score = 4.0;
      s.reason = "S05 Session impulse BUY";
   }
   else if(tf[TF_M1].close0 < tf[TF_M1].close1 && snap.localBias == -1 && snap.macroBias <= 0 && m5Confirms && !IsDangerousShortSetup())
   {
      s.direction = -1;
      s.score = 3.8;
      s.reason = "S05 Session impulse SELL";
   }
}

void StrategyMTFAlignment(StrategySignal &s)
{
   int buyVotes = 0;
   int sellVotes = 0;
   for(int i=0; i<TF_TOTAL; i++)
   {
      if(tf[i].bias == 1) buyVotes++;
      if(tf[i].bias == -1) sellVotes++;
   }

   if(snap.regime == REGIME_LOW_VOL)
      return;

   bool macroStrong = (tf[TF_H1].adx > 20.0 && tf[TF_M15].adx > 18.0);

   if(buyVotes >= 6 && macroStrong)
   {
      s.direction = 1;
      s.score = 5.2;
      s.reason = StringFormat("S06 MTF align BUY %d/8 TFs", buyVotes);
   }
   else if(sellVotes >= 6 && macroStrong)
   {
      s.direction = -1;
      s.score = 5.2;
      s.reason = StringFormat("S06 MTF align SELL %d/8 TFs", sellVotes);
   }
}

void StrategyM12M15Momentum(StrategySignal &s)
{
   bool buy = (tf[TF_M12].bias == 1 && tf[TF_M15].bias == 1 && tf[TF_M12].macdMain > tf[TF_M12].macdSignal && tf[TF_M15].rsi > 52.0);
   bool sell = (tf[TF_M12].bias == -1 && tf[TF_M15].bias == -1 && tf[TF_M12].macdMain < tf[TF_M12].macdSignal && tf[TF_M15].rsi < 48.0);

   if(buy && snap.macroBias >= 0)
   {
      s.direction = 1;
      s.score = 3.5;
      s.reason = "S07 M12/M15 momentum BUY";
   }
   else if(sell && snap.macroBias <= 0)
   {
      s.direction = -1;
      s.score = 3.5;
      s.reason = "S07 M12/M15 momentum SELL";
   }
}

void StrategyM20Squeeze(StrategySignal &s)
{
   bool squeeze = (snap.bbWidthM20 > 0.0 && snap.bbWidthM20 < 0.0038);
   if(!squeeze || snap.volVelocity > 2.2)
      return;

   if(tf[TF_M20].close0 > tf[TF_M20].emaFast && tf[TF_M5].bias == 1 && snap.macroBias >= 0)
   {
      s.direction = 1;
      s.score = 3.1;
      s.reason = "S08 M20 squeeze BUY";
   }
   else if(tf[TF_M20].close0 < tf[TF_M20].emaFast && tf[TF_M5].bias == -1 && snap.macroBias <= 0)
   {
      s.direction = -1;
      s.score = 3.1;
      s.reason = "S08 M20 squeeze SELL";
   }
}

void StrategyH1Retest(StrategySignal &s)
{
   double distance = MathAbs(tf[TF_M5].close0 - tf[TF_H1].emaFast);
   bool nearH1 = (distance <= MathMax(tf[TF_M5].atr * 1.2, 100.0 * _Point));

   if(!nearH1 || snap.regime == REGIME_RANGE)
      return;

   if(snap.macroBias == 1 && tf[TF_M5].close0 > tf[TF_H1].emaFast && tf[TF_M5].rsi > 50.0)
   {
      s.direction = 1;
      s.score = 3.4;
      s.reason = "S09 H1 retest BUY";
   }
   else if(snap.macroBias == -1 && tf[TF_M5].close0 < tf[TF_H1].emaFast && tf[TF_M5].rsi < 50.0)
   {
      s.direction = -1;
      s.score = 3.4;
      s.reason = "S09 H1 retest SELL";
   }
}

void StrategyD1Continuation(StrategySignal &s)
{
   if(tf[TF_D1].bias == 0 || snap.regime == REGIME_RANGE || snap.regime == REGIME_LOW_VOL)
      return;

   if(tf[TF_D1].bias == 1 && tf[TF_H1].bias >= 0 && tf[TF_M15].bias == 1)
   {
      s.direction = 1;
      s.score = 3.8;
      s.reason = "S10 D1 continuation BUY";
   }
   else if(tf[TF_D1].bias == -1 && tf[TF_H1].bias <= 0 && tf[TF_M15].bias == -1)
   {
      s.direction = -1;
      s.score = 3.8;
      s.reason = "S10 D1 continuation SELL";
   }
}

void StrategyDefensiveEntry(StrategySignal &s)
{
   double spreadLimit = (IsMicroAccount() ? InpMicroHardSpreadCap * 0.80 : InpSoftSpreadCap * 0.90);
   if(snap.regime != REGIME_TREND || snap.spread > spreadLimit)
      return;

   if(snap.macroBias == 1 && snap.localBias == 1 && tf[TF_M5].rsi > 53.0 && tf[TF_M5].rsi < 68.0 && tf[TF_H1].bias == 1)
   {
      s.direction = 1;
      s.score = (IsMicroAccount() ? 4.4 : 4.2);
      s.reason = "S11 Defensive entry BUY";
   }
   else if(snap.macroBias == -1 && snap.localBias == -1 && tf[TF_M5].rsi < 47.0 && tf[TF_M5].rsi > 32.0 && tf[TF_H1].bias == -1)
   {
      s.direction = -1;
      s.score = (IsMicroAccount() ? 4.4 : 4.2);
      s.reason = "S11 Defensive entry SELL";
   }
}

void StrategyRecoveryReady(StrategySignal &s)
{
   if(IsMicroAccount() || snap.regime == REGIME_EXTREME_VOL || snap.spreadWarn || !g_profile.allowRecovery)
      return;

   if(snap.regime != REGIME_TREND || snap.macroBias == 0 || snap.macroBias != snap.localBias)
      return;
   if(tf[TF_H1].adx < 20.0 || basket.lossStreak > 2)
      return;

   double h1High1 = iHigh(_Symbol, PERIOD_H1, 1);
   double h1Low1  = iLow(_Symbol, PERIOD_H1, 1);
   double h1High2 = iHigh(_Symbol, PERIOD_H1, 2);
   double h1Low2  = iLow(_Symbol, PERIOD_H1, 2);
   bool bullishStructure = (snap.macroBias == 1 && h1High1 > h1High2 && h1Low1 > h1Low2);
   bool bearishStructure = (snap.macroBias == -1 && h1High1 < h1High2 && h1Low1 < h1Low2);
   if(bullishStructure || bearishStructure)
   {
      s.direction = snap.macroBias;
      s.score = 4.0;
      s.reason = "S12 Recovery-ready trend H1";
   }
}

int CascadeScore(const int dir)
{
   // ENHANCED: Stronger multi-layer confirmation required for high win rate
   int score = 0;

   // Layer 1 - Environment quality (max 3)
   if(!snap.spreadBlocked) score++;
   if(!snap.extremeBlocked) score++;
   if(snap.regime == REGIME_TREND || snap.regime == REGIME_TRANSITION) score++;
   else if(snap.regime == REGIME_RANGE || snap.regime == REGIME_HIGH_VOL) score++;

   // Layer 2 - Macro alignment (max 3, weighted)
   if(snap.macroBias == dir) score += 2;
   if(tf[TF_D1].bias == dir) score++;

   // Layer 3 - Structural alignment (max 3)
   if(snap.localBias == dir) score++;
   if(tf[TF_H1].bias == dir) score++;
   if(tf[TF_M5].bias == dir) score++;

   // Layer 4 - Momentum confirmation (max 3, ENHANCED)
   bool macdH1 = (dir == 1 ? tf[TF_H1].macdMain > tf[TF_H1].macdSignal : tf[TF_H1].macdMain < tf[TF_H1].macdSignal);
   bool macdM5 = (dir == 1 ? tf[TF_M5].macdMain > tf[TF_M5].macdSignal : tf[TF_M5].macdMain < tf[TF_M5].macdSignal);
   bool adxStrong = (tf[TF_H1].adx > 20.0 && tf[TF_M5].adx > 16.0);
   bool stochOk = (dir == 1 ? (tf[TF_M5].stochMain < 75.0 && tf[TF_M15].stochMain > 25.0)
                             : (tf[TF_M5].stochMain > 25.0 && tf[TF_M15].stochMain < 75.0));
   if(macdH1) score++;
   if(macdM5 && macdH1) score++;   // Double MACD alignment is worth extra
   if(adxStrong) score++;
   if(stochOk) score++;

   // Layer 5 - Correlation safety
   if(!IsCorrelationBlocked()) score++;

   // Penalty for counter-macro or dangerous short
   if(snap.macroBias != 0 && snap.macroBias != dir) score -= 3;
   if(dir == -1 && IsDangerousShortSetup()) score -= 4;

   return score;
}

double QQMTFStructureScore(const int strategyId, const int dir, string &block)
{
   block = "";
   if(dir == 0)
   {
      block = "no direction";
      return 0.0;
   }

   double score = 0.0;
   int macroVotes = 0;
   int setupVotes = 0;
   int timingVotes = 0;

   if(tf[TF_D1].bias == dir) macroVotes++;
   if(tf[TF_H1].bias == dir) macroVotes++;
   if(tf[TF_M20].bias == dir) macroVotes++;
   if(tf[TF_M20].bias == dir) setupVotes++;
   if(tf[TF_M15].bias == dir) setupVotes++;
   if(tf[TF_M12].bias == dir) setupVotes++;
   if(tf[TF_M5].bias == dir) timingVotes++;
   if(tf[TF_M6].bias == dir) timingVotes++;
   if(tf[TF_M1].bias == dir) timingVotes++;

   score += macroVotes * 12.0;
   score += setupVotes * 10.0;
   score += timingVotes * 8.0;

   if(g_matrix.macroDir == dir) score += 10.0;
   if(g_matrix.setupDir == dir) score += 8.0;
   if(g_matrix.timingDir == dir) score += 6.0;
   if(tf[TF_H1].adx >= 20.0) score += 5.0;
   if(tf[TF_M15].adx >= 18.0) score += 4.0;
   if(tf[TF_M5].adx >= 16.0) score += 3.0;

   bool macdAligned = ((dir == 1 && tf[TF_M5].macdMain > tf[TF_M5].macdSignal && tf[TF_M15].macdMain > tf[TF_M15].macdSignal) ||
                       (dir == -1 && tf[TF_M5].macdMain < tf[TF_M5].macdSignal && tf[TF_M15].macdMain < tf[TF_M15].macdSignal));
   if(macdAligned) score += 7.0;

   bool rsiClean = (dir == 1 ? (tf[TF_M5].rsi >= 50.0 && tf[TF_M15].rsi >= 48.0 && tf[TF_M5].rsi <= 74.0)
                            : (tf[TF_M5].rsi <= 50.0 && tf[TF_M15].rsi <= 52.0 && tf[TF_M5].rsi >= 26.0));
   if(rsiClean) score += 6.0;

   double distM5 = MathAbs(tf[TF_M5].close0 - tf[TF_M5].emaFast) / MathMax(tf[TF_M5].atr, _Point);
   double distM15 = MathAbs(tf[TF_M15].close0 - tf[TF_M15].emaFast) / MathMax(tf[TF_M15].atr, _Point);
   bool breakoutFamily = (strategyId == 4 || strategyId == 5 || strategyId == 8);
   if(!breakoutFamily && (distM5 > InpMaxEntryExtensionATR || distM15 > InpMaxEntryExtensionATR * 1.15))
   {
      score -= 22.0;
      block = "overextended";
   }
   else if(distM5 <= 1.35)
      score += 5.0;

   if(strategyId != 3 && macroVotes < 2)
   {
      score -= 38.0;   // Was 30 - stronger penalty for macro misalignment
      block = "macro votes";
   }
   if(strategyId != 10 && setupVotes < 2)
   {
      score -= 30.0;   // Was 22 - stronger penalty for setup misalignment
      block = "setup votes";
   }
   if(strategyId != 10 && strategyId != 12 && timingVotes < 2)
   {
      score -= 24.0;   // Was 18 - stronger timing penalty
      block = "timing votes";
   }

   if(dir == -1 && IsDangerousShortSetup())
   {
      score -= 35.0;   // Was 26 - enhanced short danger penalty
      block = "dangerous short";
   }
   if(QQNewsRiskScore() > QQEffectiveMaxNewsRiskForEntry())
   {
      score -= 30.0;   // Was 25 - stronger news block
      block = "news risk";
   }
   if(snap.spread > QQEffectiveSpreadCap() * 0.72)
   {
      score -= 14.0;   // Was 12
      block = "spread quality";
   }

   if(QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_SMALL)
   {
      if(!(strategyId == 1 || strategyId == 6 || strategyId == 11))
      {
         score -= 55.0;   // Was 50 - stricter on small capital
         block = "low capital strategy";
      }
      if(macroVotes < 2 || setupVotes < 2 || timingVotes < 2)
      {
         score -= 32.0;   // Was 28
         block = "low capital MTF";
      }
      // ENHANCED: On low capital, never allow shorts without full macro bearish alignment
      if(dir == -1 && (macroVotes < 2 || tf[TF_D1].bias != -1))
      {
         score -= 60.0;
         block = "low capital short blocked";
      }
   }

   return MathMax(0.0, MathMin(100.0, score));
}

double QQEffectiveMaxNewsRiskForEntry()
{
   if(QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_SMALL)
      return InpLowCapitalMaxNewsRisk;
   if(QQEffectiveCapitalMode() == CAP_MEDIAN || g_capital.tier <= TIER_STANDARD)
      return InpMedianCapitalMaxNewsRisk;
   return InpHighCapitalMaxNewsRisk;
}

double QQMinStructureScore()
{
   if(QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_SMALL)
      return InpLowCapitalMinStructureScore;
   if(QQEffectiveCapitalMode() == CAP_MEDIAN || g_capital.tier <= TIER_STANDARD)
      return InpMedianCapitalMinStructureScore;
   return InpHighCapitalMinStructureScore;
}

bool QQMTFStructureAllowsEntry(const int strategyId, const int dir, const double score, string &block)
{
   double minScore = QQMinStructureScore();
   if(strategyId == 11)
      minScore -= 4.0;
   if(strategyId == 4 || strategyId == 5)
      minScore += 3.0;
   if(strategyId == 3 && snap.regime == REGIME_RANGE)
      minScore -= 5.0;

   if(score < minScore)
   {
      if(block == "")
         block = StringFormat("MTF structure %.1f < %.1f", score, minScore);
      g_ens.lastBlock = block;
      return false;
   }
   return true;
}

double QQStructureBoost(const double score)
{
   if(score >= 94.0) return 1.10;
   if(score >= 86.0) return 0.70;
   if(score >= 78.0) return 0.35;
   return 0.0;
}

bool IsDirectionAllowedForStrategy(const int dir, const int strategyId)
{
   if(dir == 1)
      return true;

   if(InpStrictShorts == QQ_OFF)
      return true;

   if(strategyId == 4 && InpBlockCounterTrendS04 == QQ_ON && IsDangerousShortSetup())
      return false;

   int bearishVotes = 0;
   if(tf[TF_D1].bias == -1) bearishVotes++;
   if(tf[TF_H1].bias == -1) bearishVotes++;
   if(tf[TF_M20].bias == -1) bearishVotes++;
   if(tf[TF_M15].bias == -1) bearishVotes++;
   if(tf[TF_M5].bias == -1) bearishVotes++;

   if(snap.macroBias != -1)
      return false;

   if(bearishVotes < 3)
      return false;

   if(tf[TF_H1].rsi > 52.0 || tf[TF_M15].rsi > 54.0)
      return false;

   return true;
}

bool IsDangerousShortSetup()
{
   if(tf[TF_D1].bias == 1 || tf[TF_H1].bias == 1)
      return true;

   if(tf[TF_M20].bias == 1 && tf[TF_M15].bias == 1)
      return true;

   if(tf[TF_M5].rsi > 50.0 && tf[TF_M15].rsi > 50.0)
      return true;

   if(tf[TF_M5].close0 > tf[TF_H1].emaFast && tf[TF_H1].emaFast > tf[TF_H1].emaSlow)
      return true;

   // ENHANCED: Strong bullish ADX + RSI above midpoint = dangerous to short
   if(tf[TF_H1].adx > 25.0 && tf[TF_H1].rsi > 55.0)
      return true;

   // ENHANCED: D1 RSI above 55 = macro bullish momentum
   if(tf[TF_D1].rsi > 55.0)
      return true;

   // ENHANCED: MACD bullish on both H1 and M15 = dangerous short context
   if(tf[TF_H1].macdMain > tf[TF_H1].macdSignal && tf[TF_M15].macdMain > tf[TF_M15].macdSignal)
      return true;

   return false;
}

//+------------------------------------------------------------------+
//| Cycle and trade execution                                         |
//+------------------------------------------------------------------+
void StartNewCycle(const StrategySignal &sig)
{
   ResetBasket(false);

   basket.active = true;
   basket.direction = sig.direction;
   basket.strategyId = sig.strategyId;
   basket.session = snap.session;
   basket.firstTradeTime = TimeCurrent();
   basket.lastGridTime = 0;
   basket.peakProfit = 0.0;
   basket.lockProfit = 0.0;
   basket.cycleMAE = 0.0;
   basket.cycleMFE = 0.0;
   basket.maxFloatingLoss = 0.0;
   basket.gridCount = 0;
   basket.partialClosed = false;
   basket.defensivePartialDone = false;
   basket.trailingActive = false;
   basket.recoveryActive = false;
   basket.baseLot = CalculateDynamicLot(0, false);
   basket.cycleId = g_nextCycleId++;
   basket.firstPrice = (basket.direction == 1 ? snap.ask : snap.bid);
   basket.projectedDD = QQProjectedCycleDD(basket.direction, basket.baseLot, 0);
   basket.cycleHealth = CYCLE_HEALTH_HEALTHY;
   basket.entryReason = sig.reason;
   basket.basketTP = CalculateBasketTarget(basket.baseLot);

   string comment = QQBuildOrderComment("CYCLE", basket.session, basket.strategyId, 1, sig.reason);

   if(OpenMarketTrade(basket.direction, basket.baseLot, InpMagicNumber, comment))
   {
      g_tradesToday++;
      QQStrategyMarkEntry(sig.strategyId);
      QQStrategyPerformanceMarkEntry(sig.strategyId);
      QQNotify("Cycle opened", sig.reason);
      QQLogEvent("CYCLE_OPEN", sig.reason, basket.direction, basket.baseLot, 0.0);
      QQSavePersistentState("cycle_open");
      Print(StringFormat("New cycle opened: dir=%d lot=%.2f target=%.2f score=%.2f reason=%s",
                         basket.direction, basket.baseLot, basket.basketTP, sig.score, sig.reason));
   }
   else
   {
      Print("New cycle failed. Retcode=", trade.ResultRetcode(), " ", trade.ResultRetcodeDescription());
      ResetBasket(false);
   }
}

bool OpenMarketTrade(const int dir, const double rawLot, const int magic, const string comment)
{
   double lot = NormalizeLot(rawLot);
   if(lot <= 0.0)
      return false;

   string guardReason = "";
   if(!QQPreTradeGuard(dir, lot, magic, guardReason))
   {
      QQSetBlockReason(guardReason);
      Print("Trade blocked: ", guardReason, " lot=", lot);
      QQLogEvent("TRADE_BLOCK", guardReason, dir, lot, 0.0);
      return false;
   }

   if(!HasEnoughMargin(dir, lot))
   {
      Print("Trade blocked: insufficient margin for lot ", lot);
      QQSetBlockReason("Insufficient margin");
      return false;
   }

   trade.SetExpertMagicNumber(magic);
   trade.SetDeviationInPoints(InpSlippage);
   trade.SetTypeFillingBySymbol(_Symbol);

   double hardSL = 0.0;
   if(InpUseHardSL == QQ_ON && InpHardSLPoints > 0.0)
      hardSL = (dir == 1 ? snap.ask - InpHardSLPoints * _Point : snap.bid + InpHardSLPoints * _Point);

   bool ok = false;
   if(dir == 1)
      ok = trade.Buy(lot, _Symbol, snap.ask, hardSL, 0.0, QQSanitizeOrderComment(comment));
   else if(dir == -1)
      ok = trade.Sell(lot, _Symbol, snap.bid, hardSL, 0.0, QQSanitizeOrderComment(comment));

   if(!ok)
      Print("Order failed: ", trade.ResultRetcode(), " ", trade.ResultRetcodeDescription());

   return ok;
}

double CalculateDynamicLot(const int gridLevel, const bool rescue)
{
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW)
      return NormalizeLot(SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN));
   if(mode == CAP_MEDIAN && gridLevel > 0)
      return NormalizeLot(SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN));

   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double freeMargin = AccountInfoDouble(ACCOUNT_MARGIN_FREE);
   double lot = InpLotsFixed;

   if(InpLotsCalc == LOT_DYNAMIC_CYCLE)
   {
      double divisor = RiskDivisor();
      lot = (balance / divisor) * 0.01;
      if(basket.lastCycleProfit < 0.0 || basket.lossStreak > 0)
         lot *= 0.85;
   }
   else if(InpLotsCalc == LOT_FIXED_BALANCE)
   {
      lot = (balance / MathMax(InpLotsFixedBalance, 1.0)) * 0.01;
   }
   else if(InpLotsCalc == LOT_PERCENT_MARGIN)
   {
      lot = (freeMargin * (InpPctOfFreeMargin / 100.0)) / 10000.0;
   }
   else
   {
      lot = InpLotsFixed;
   }

   if(gridLevel > 0)
      lot *= MathPow(MathMax(1.0, InpGridLotMultiplier), gridLevel);

   if(rescue)
      lot *= InpRescueLotFactor;

   if(IsMicroAccount())
      lot = MathMin(lot, InpMicroMaxLot);

   lot = QQCapitalAdjustedLot(lot, gridLevel, rescue);

   double maxLots = MaxBasketLotsAllowed();
   double currentLots = GetBasketVolume(InpMagicNumber, basket.direction);
   lot = MathMin(lot, MathMax(0.0, maxLots - currentLots));

   return NormalizeLot(lot);
}

double RiskDivisor()
{
   // ENHANCED: Refined risk table - balances frequency vs safety by risk level
   double table[5] = {3000.0, 2200.0, 1500.0, 1050.0, 800.0};
   int idx = (int)InpAutoLotsValue - 1;
   idx = MathMax(0, MathMin(4, idx));

   double divisor = table[idx];

   if(InpSets == SET_RAW_LOW)
      divisor *= 1.30;   // Was 1.25 - more conservative on RAW LOW
   else if(InpSets == SET_RAW_HIGH)
      divisor *= 0.85;
   else if(InpSets == SET_ROBO_ECN)
      divisor *= 1.10;
   else if(InpSets == SET_FUSION_ZERO)
      divisor *= 1.05;

   divisor *= MathMax(0.50, g_profile.lotDivisorScale);

   // ENHANCED: Capital mode stricter minimum divisors to prevent over-leveraging
   if(QQEffectiveCapitalMode() == CAP_LOW)
      divisor = MathMax(divisor, 3000.0);  // Was 2500 - more conservative for small accounts
   else if(QQEffectiveCapitalMode() == CAP_MEDIAN)
      divisor = MathMax(divisor, 2000.0);  // Was 1800
   else if(QQEffectiveCapitalMode() == CAP_HIGH)
      divisor = MathMin(divisor, 1250.0);

   // ENHANCED: Apply loss streak reduction to lot size
   if(basket.lossStreak >= 1)
      divisor *= (1.0 + basket.lossStreak * 0.15);  // More conservative after losses

   return divisor;
}

double CalculateBasketTarget(const double lot)
{
   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double pct = QQEffectiveBasketTargetPct() * MathMax(0.50, g_profile.targetScale);
   double target = balance * (pct / 100.0);

   double tickVal = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSz  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickVal > 0.0 && tickSz > 0.0)
   {
      double profitPerPoint = lot * (tickVal / tickSz) * _Point;
      double atrTarget = MathMax(80.0, SafePoints(tf[TF_M5].atr) * 0.30) * profitPerPoint;
      target = MathMax(target, atrTarget);
      target = MathMax(target, QQSpreadCostTargetFloor(lot));
   }

   if(snap.regime == REGIME_HIGH_VOL)
      target *= 1.20;
   else if(snap.regime == REGIME_RANGE)
      target *= 0.85;

   return MathMax(target, QQEffectiveMinBasketTarget());
}

//+------------------------------------------------------------------+
//| Grid                                                              |
//+------------------------------------------------------------------+
bool ShouldAddGridPosition(const bool rescue)
{
   if(!basket.active || basket.direction == 0)
      return false;

   if(InpEnableGrid == QQ_OFF)
      return false;

   if(IsMicroAccount() && InpMicroBlockGrid == QQ_ON)
   {
      if(QQEffectiveCapitalMode() != CAP_MEDIAN && QQEffectiveCapitalMode() != CAP_HIGH)
         return false;
   }

   if(!g_capital.gridAllowed)
   {
      QQSetBlockReason("Capital tier blocks grid");
      return false;
   }

   if(rescue && InpUseRescueGrid == QQ_OFF)
      return false;

   if(GetDrawdownPct() > InpGridMaxDD)
      return false;

   if(snap.spreadBlocked || snap.extremeBlocked || snap.regime == REGIME_LOW_VOL)
      return false;

   if(GetMarginLevelPct() > 0.0 && GetMarginLevelPct() < InpMarginWarnPct)
      return false;

   int count = CountMainPositions(basket.direction);
   int maxLevels = EffectiveMaxGridLevels();
   if(count <= 0 || count >= maxLevels)
      return false;

   if(TimeCurrent() - basket.lastGridTime < InpMinMinutesBetweenGrid * 60)
      return false;

   double worst = GetWorstPrice(basket.direction);
   if(worst <= 0.0)
      return false;

   if(!QQTrendThesisAlive(basket.direction))
   {
      QQSetBlockReason("Trend thesis invalidated for grid");
      return false;
   }

   if(!QQGridCompressionGuard(count, rescue))
      return false;

   double spacing = CalculateGridSpacingPoints(count, rescue);
   double price = (basket.direction == 1 ? snap.bid : snap.ask);

   if(basket.direction == 1 && price <= worst - spacing * _Point)
      return true;

   if(basket.direction == -1 && price >= worst + spacing * _Point)
      return true;

   return false;
}

double CalculateGridSpacingPoints(const int level, const bool rescue)
{
   // ENHANCED: Fully dynamic ATR-based spacing - replaces fixed 250 pts hardcode
   double atrM5   = SafePoints(tf[TF_M5].atr);
   double atrH1   = SafePoints(tf[TF_H1].atr);
   double atrBase = MathMax(atrM5 * 2.2, atrH1 * 0.55);  // Adaptive ATR blend

   double base = MathMax(atrBase, InpBaseGridSpacing) * MathMax(0.50, g_profile.gridSpacingScale);
   double nonLinear = base * MathPow(InpGridMultiplier, MathMax(0, level - 1));

   // ENHANCED: Use maximum of non-linear and ATR-based for safety
   double atrPart = atrBase * InpGridATRMult * MathMax(0.50, g_profile.gridAtrScale);
   double spacing = MathMax(nonLinear, atrPart);

   // ENHANCED: Regime-specific multipliers (more conservative in adverse conditions)
   if(snap.regime == REGIME_HIGH_VOL)
      spacing *= 2.00;   // Was 1.65 - wider spacing in volatile market
   else if(snap.regime == REGIME_TREND && snap.macroBias == basket.direction)
      spacing *= 1.10;   // Slightly wider even in aligned trend
   else if(snap.regime == REGIME_RANGE)
      spacing *= 1.40;   // Was 1.25 - range grids need more room
   else if(snap.regime == REGIME_TRANSITION)
      spacing *= 1.65;   // ENHANCED: Transition = uncertain, wider

   // ENHANCED: Short direction always wider - asymmetric gold behavior
   if(basket.direction == -1)
      spacing *= 1.30;

   if(IsDangerousShortSetup() && basket.direction == -1)
      spacing *= 2.00;   // Was 1.80 - dangerous short needs maximum spacing

   // ENHANCED: Loss streak penalty - widen spacing after consecutive losses
   if(basket.lossStreak >= 2)
      spacing *= (1.0 + basket.lossStreak * 0.12);

   if(rescue)
      spacing *= InpRescueSpacingMult;

   return MathMax(spacing, 100.0);  // Was 80.0 - higher floor for safety
}

void ExecuteGridTrade(const bool rescue)
{
   int level = CountMainPositions(basket.direction);
   double lot = CalculateDynamicLot(level, rescue);
   if(lot <= 0.0)
      return;

   string label = (rescue ? "RESCUE" : "GRID");
   string comment = QQBuildOrderComment(label, basket.session, basket.strategyId, level + 1, "grid");

   if(OpenMarketTrade(basket.direction, lot, InpMagicNumber, comment))
   {
      basket.lastGridTime = TimeCurrent();
      basket.gridCount++;
      basket.basketTP = MathMax(basket.basketTP, CalculateBasketTarget(basket.baseLot));
      QQNotify(label + " grid opened", comment);
      QQLogEvent("GRID_OPEN", label, basket.direction, lot, 0.0);
      QQSavePersistentState("grid_open");
      Print(StringFormat("%s grid opened: level=%d lot=%.2f spacing=%.1f",
                         label, level + 1, lot, CalculateGridSpacingPoints(level, rescue)));
   }
}

int EffectiveMaxGridLevels()
{
   int quickGrid = QQEffectiveCapitalGridLevels();
   if(quickGrid <= 0)
      return 0;

   int maxLevels = MathMax(1, MathMin(MathMin(InpMaxGridLevels, g_profile.maxGridLevels), quickGrid));

   // ENHANCED: More conservative limits by market condition
   if(snap.regime == REGIME_HIGH_VOL || snap.regime == REGIME_TRANSITION)
      maxLevels = MathMin(maxLevels, 1);   // Was 2 - single level in uncertain markets

   if(snap.regime == REGIME_RANGE)
      maxLevels = MathMin(maxLevels, 2);

   // ENHANCED: Shorts always capped lower (gold has asymmetric upside risk)
   if(basket.strategyId == 4 || basket.direction == -1)
      maxLevels = MathMin(maxLevels, 1);   // Was 2 - shorts limited to 1 grid level

   if(GetDrawdownPct() > InpGridMaxDD * 0.65)
      maxLevels = MathMin(maxLevels, 1);

   // ENHANCED: Loss streak reduces grid aggressiveness
   if(basket.lossStreak >= 2)
      maxLevels = MathMin(maxLevels, 1);

   // ENHANCED: Disable grid when cycle health is DANGER or worse
   if(basket.cycleHealth >= CYCLE_HEALTH_DANGER)
      maxLevels = 0;

   return maxLevels;
}

//+------------------------------------------------------------------+
//| Basket management                                                 |
//+------------------------------------------------------------------+
void ManageActiveBasket()
{
   double mainProfit = GetBasketProfit(InpMagicNumber, basket.direction);
   double recoveryProfit = GetBasketProfit(g_recoveryMagic, -basket.direction);
   double totalProfit = mainProfit + recoveryProfit;

   if(QQPreRolloverExit(totalProfit))
      return;

   UpdateCycleExcursion(totalProfit);

   basket.cycleHealth = QQCycleHealth(totalProfit);

   if(totalProfit > basket.peakProfit)
      basket.peakProfit = totalProfit;

   if(QQProfitGivebackExit(totalProfit))
      return;

   if(QQTrendInvalidationExit(totalProfit))
   {
      CloseBasket("Trend invalidation exit", true);
      return;
   }

   if(ShouldForceCycleLossExit(totalProfit))
   {
      CloseBasket("Cycle loss guard", true);
      return;
   }

   if(ShouldEarlyAdverseExit(totalProfit))
   {
      CloseBasket("Adverse acceleration exit", true);
      return;
   }

   if(QQQualityDecayExit(totalProfit))
      return;

   if(totalProfit >= basket.basketTP && basket.basketTP > 0.0)
   {
      CloseBasket("Basket TP reached", true);
      return;
   }

   ManageStagedDefense(totalProfit);
   if(!basket.active)
      return;

   if(InpUsePartials == QQ_ON)
      TryPartialClose(mainProfit);

   if(InpUseBreakEven == QQ_ON)
      ManageBreakEven(totalProfit);

   if(InpUseBasketTrail == QQ_ON)
      ManageBasketTrail(totalProfit);

   if(InpUseVolatilityExit == QQ_ON && snap.extremeBlocked)
   {
      if(totalProfit >= 0.0 || GetDrawdownPct() >= InpRecoveryDDLevel)
      {
         CloseBasket("Volatility shock exit", true);
         return;
      }
   }

   if(InpUseTimeExit == QQ_ON && basket.firstTradeTime > 0)
   {
      if(TimeCurrent() - basket.firstTradeTime >= InpMaxBasketHours * 3600)
      {
         if(totalProfit >= -MathMax(basket.basketTP * 0.35, 1.0) || snap.regime == REGIME_EXTREME_VOL)
            CloseBasket("Time/quality exit", true);
      }
   }
}

void UpdateCycleExcursion(const double totalProfit)
{
   basket.cycleMFE = MathMax(basket.cycleMFE, totalProfit);
   basket.cycleMAE = MathMin(basket.cycleMAE, totalProfit);
   basket.maxFloatingLoss = MathMax(basket.maxFloatingLoss, MathMax(0.0, -totalProfit));
}

bool ShouldForceCycleLossExit(const double totalProfit)
{
   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   if(balance <= 0.0)
      return false;

   double pct = (IsMicroSurvivalAccount() ? InpMicroCycleLossPct : InpCycleLossPct);
   if(g_capital.tier <= TIER_MICRO)
      pct = MathMin(pct, InpLowMaxCycleLossPct);
   else if(g_capital.tier <= TIER_LOW)
      pct = MathMin(pct, InpMedianMaxCycleLossPct);
   else
      pct = MathMin(pct, InpHighMaxCycleLossPct);

   double balanceLimit = balance * (pct / 100.0);
   double targetLimit = MathMax(QQEffectiveMinBasketTarget(), basket.basketTP) * InpMaxCycleLossTargetMult;
   double lossLimit = MathMin(balanceLimit, targetLimit);

   if(totalProfit <= -lossLimit)
      return true;

   if(IsMicroSurvivalAccount() && CountMainPositions(0) > 1)
      return true;

   return false;
}

bool QQProfitGivebackExit(const double totalProfit)
{
   if(InpUseProfitGivebackGuard == QQ_OFF || !basket.active)
      return false;

   double target = MathMax(QQEffectiveMinBasketTarget(), basket.basketTP);
   double peak = MathMax(basket.peakProfit, basket.cycleMFE);
   if(peak < MathMax(target * (InpPeakLockAfterTargetPct / 100.0), 1.0))
      return false;

   double keepPct = 1.0 - MathMax(5.0, MathMin(85.0, InpPeakGivebackClosePct)) / 100.0;
   double lockedProfit = MathMax(0.05, peak * keepPct);

   if(peak >= target && totalProfit <= MathMax(lockedProfit, target * 0.35))
   {
      CloseBasket("Peak profit giveback guard", true);
      return true;
   }

   if(peak >= target * 0.60 && totalProfit <= 0.05)
   {
      CloseBasket("No-giveback scratch exit", true);
      return true;
   }

   return false;
}

double QQCycleQualityScore()
{
   double q = 50.0;
   if(basket.direction != 0 && snap.macroBias == basket.direction) q += 12.0;
   if(basket.direction != 0 && snap.localBias == basket.direction) q += 10.0;
   if(basket.direction != 0 && tf[TF_M5].bias == basket.direction) q += 8.0;
   if(basket.direction != 0 && tf[TF_H1].bias == basket.direction) q += 8.0;
   if(snap.spreadWarn) q -= 12.0;
   if(snap.extremeBlocked) q -= 18.0;
   if(IsCorrelationBlocked()) q -= 10.0;
   if(basket.direction == -1 && IsDangerousShortSetup()) q -= 18.0;
   if(basket.lossStreak > 0) q -= MathMin(12.0, basket.lossStreak * 4.0);
   return MathMax(0.0, MathMin(100.0, q));
}

bool QQQualityDecayExit(const double totalProfit)
{
   if(InpUseQualityDecayExit == QQ_OFF || !basket.active || basket.firstTradeTime <= 0)
      return false;

   int ageMin = (int)((TimeCurrent() - basket.firstTradeTime) / 60);
   double target = MathMax(QQEffectiveMinBasketTarget(), basket.basketTP);
   double quality = QQCycleQualityScore();

   if(ageMin >= 45 && quality < 42.0 && totalProfit >= -target * 0.35)
   {
      CloseBasket("Quality decay scratch exit", true);
      return true;
   }

   if(ageMin >= 120 && quality < 55.0 && totalProfit >= -target * 0.65)
   {
      CloseBasket("Aged low-quality exit", true);
      return true;
   }

   return false;
}

bool ShouldEarlyAdverseExit(const double totalProfit)
{
   if(!basket.active || basket.direction == 0)
      return false;

   if(InpUseMAEExit == QQ_OFF)
      return false;

   double target = MathMax(basket.basketTP, InpMinBasketTarget);
   if(totalProfit <= -target * InpMAEExitTargetMult)
      return true;

   if(basket.direction == -1 && IsDangerousShortSetup() && totalProfit < 0.0)
      return true;

   if(snap.volVelocity > 2.4 && totalProfit < -target * 0.75)
      return true;

   return false;
}

void ManageStagedDefense(const double totalProfit)
{
   if(totalProfit >= 0.0)
      return;

   double dd = GetDrawdownPct();
   if(!basket.defensivePartialDone && dd >= InpDefensePartialDD)
   {
      if(TryReduceExposure())
         basket.defensivePartialDone = true;
   }

   bool dangerousBasket = (basket.direction == -1 && IsDangerousShortSetup());
   if(dd >= InpDefenseCloseDD && (snap.extremeBlocked || dangerousBasket || snap.volVelocity > 2.2))
      CloseBasket("Staged defense close", true);
}

void TryPartialClose(const double mainProfit)
{
   if(basket.partialClosed)
      return;

   if(basket.basketTP <= 0.0)
      return;

   if(mainProfit < basket.basketTP * (InpPartialTriggerPct / 100.0))
      return;

   ulong ticket = 0;
   double volume = 0.0;
   if(!FindHeaviestPosition(InpMagicNumber, basket.direction, ticket, volume))
      return;

   double closeVol = NormalizeLot(volume * (InpPartialVolumePct / 100.0));
   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double step = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);

   if(closeVol < minLot || volume - closeVol < minLot)
   {
      if(volume > minLot + step)
         closeVol = NormalizeLot(volume - minLot);
      else
         return;
   }

   trade.SetExpertMagicNumber(InpMagicNumber);
   bool done = false;
   if(g_isHedging && volume - closeVol >= minLot && closeVol >= minLot)
      done = trade.PositionClosePartial(ticket, closeVol, InpSlippage);
   else if(CountMainPositions(basket.direction) > 1)
      done = trade.PositionClose(ticket, InpSlippage);

   if(done)
   {
      basket.partialClosed = true;
      basket.lockProfit = MathMax(basket.lockProfit, mainProfit * 0.35);
      Print(StringFormat("Partial/secure close done: ticket=%I64u volume=%.2f", ticket, closeVol));
   }
   else
   {
      Print("Partial close failed: ", trade.ResultRetcode(), " ", trade.ResultRetcodeDescription());
   }
}

bool TryReduceExposure()
{
   ulong ticket = 0;
   double volume = 0.0;
   if(!FindHeaviestPosition(InpMagicNumber, basket.direction, ticket, volume))
      return false;

   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double closeVol = NormalizeLot(volume * 0.50);

   trade.SetExpertMagicNumber(InpMagicNumber);

   if(g_isHedging && volume - closeVol >= minLot && closeVol >= minLot)
   {
      if(trade.PositionClosePartial(ticket, closeVol, InpSlippage))
      {
         Print(StringFormat("Defense partial reduction: ticket=%I64u volume=%.2f", ticket, closeVol));
         return true;
      }
   }

   if(CountMainPositions(basket.direction) > 1)
   {
      if(trade.PositionClose(ticket, InpSlippage))
      {
         Print(StringFormat("Defense closed heaviest grid ticket=%I64u", ticket));
         return true;
      }
   }

   return false;
}

void ManageBreakEven(const double totalProfit)
{
   if(basket.basketTP <= 0.0)
      return;

   double trigger = basket.basketTP * (QQEffectiveBreakEvenTriggerPct() / 100.0);
   if(totalProfit >= trigger)
   {
      double tickVal = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
      double tickSz = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
      double spreadCost = 0.0;
      if(tickVal > 0.0 && tickSz > 0.0)
         spreadCost = snap.spread * _Point / tickSz * tickVal * MathMax(basket.baseLot, SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN));
      basket.lockProfit = MathMax(basket.lockProfit, MathMax(spreadCost * 2.5, basket.basketTP * 0.08));
   }

   if(basket.lockProfit > 0.0 && basket.peakProfit > trigger && totalProfit <= basket.lockProfit)
      CloseBasket("Break-even lock", true);
}

void ManageBasketTrail(const double totalProfit)
{
   if(basket.basketTP <= 0.0)
      return;

   if(!basket.trailingActive && totalProfit >= basket.basketTP * (InpTrailTriggerPct / 100.0))
      basket.trailingActive = true;

   if(basket.trailingActive)
   {
      double lock = basket.peakProfit * (InpTrailLockPct / 100.0);
      basket.lockProfit = MathMax(basket.lockProfit, lock);
      if(totalProfit <= basket.lockProfit && basket.peakProfit > 0.0)
         CloseBasket("Basket trailing lock", true);
   }
}

void CloseBasket(const string reason, const bool includeRecovery)
{
   double before = GetBasketProfit(InpMagicNumber, basket.direction);
   if(includeRecovery)
      before += GetBasketProfit(g_recoveryMagic, -basket.direction);

   ClosePositionsByMagic(InpMagicNumber, 0);
   if(includeRecovery)
      ClosePositionsByMagic(g_recoveryMagic, 0);

   basket.lastCycleProfit = before;
   QQStrategyPerformanceMarkExit(basket.strategyId, before);
   if(before < 0.0)
      basket.lossStreak++;
   else
      basket.lossStreak = 0;

   g_diag.lastExitReason = reason;
   QQNotify("Basket closed", reason);
   QQLogEvent("BASKET_CLOSE", reason, basket.direction, GetBasketVolume(InpMagicNumber, 0), before);
   QQSavePersistentState("basket_close");

   Print(StringFormat("Basket closed: %s | profit=%.2f | S%02d | grid=%d | MFE=%.2f | MAE=%.2f | maxFloatingLoss=%.2f | minutes=%d",
                      reason, before, basket.strategyId, basket.gridCount, basket.cycleMFE, basket.cycleMAE,
                      basket.maxFloatingLoss, (int)((TimeCurrent() - basket.firstTradeTime) / 60)));
   ResetBasket(true);
}

void ResetBasket(const bool keepStats)
{
   double lastProfit = basket.lastCycleProfit;
   int losses = basket.lossStreak;
   datetime lastExit = basket.lastExitTime;

   basket.active = false;
   basket.direction = 0;
   basket.strategyId = 0;
   basket.session = 0;
   basket.firstTradeTime = 0;
   basket.lastGridTime = 0;
   basket.basketTP = 0.0;
   basket.peakProfit = 0.0;
   basket.lockProfit = 0.0;
   basket.baseLot = 0.0;
   basket.cycleId = 0;
   basket.firstPrice = 0.0;
   basket.projectedDD = 0.0;
   basket.cycleHealth = CYCLE_HEALTH_NONE;
   basket.entryReason = "";
   basket.cycleMAE = 0.0;
   basket.cycleMFE = 0.0;
   basket.maxFloatingLoss = 0.0;
   basket.gridCount = 0;
   basket.partialClosed = false;
   basket.defensivePartialDone = false;
   basket.trailingActive = false;
   basket.recoveryActive = false;

   if(keepStats)
   {
      basket.lastCycleProfit = lastProfit;
      basket.lossStreak = losses;
      basket.lastExitTime = TimeCurrent();
   }
   else
   {
      basket.lastCycleProfit = 0.0;
      basket.lossStreak = 0;
      basket.lastExitTime = lastExit;
   }
}

//+------------------------------------------------------------------+
//| Recovery hedge                                                    |
//+------------------------------------------------------------------+
void ManageRecoveryHedge()
{
   if(InpUseRecovery == QQ_OFF)
      return;

   if(QQEffectiveRecoveryLotPct() <= 0.0)
      return;

   if(!g_isHedging)
      return;

   if(!g_capital.recoveryAllowed)
      return;

   if(IsMicroAccount() && InpMicroBlockRecovery == QQ_ON)
      return;

   if(AccountInfoDouble(ACCOUNT_BALANCE) < InpMicroLimit)
      return;

   if(GetMarginLevelPct() > 0.0 && GetMarginLevelPct() < InpMarginWarnPct)
      return;

   if(TimeCurrent() - g_lastRecoveryClose < InpRecoveryCooldownMin * 60)
      return;

   int recoveryCount = CountRecoveryPositions(0);
   basket.recoveryActive = (recoveryCount > 0);

   double dd = GetDrawdownPct();
   double totalProfit = GetBasketProfit(InpMagicNumber, basket.direction) + GetBasketProfit(g_recoveryMagic, -basket.direction);

   // ENHANCED: Emergency close if DD grows 1.5% after opening recovery - prevents chain losses
   if(basket.recoveryActive && basket.maxFloatingLoss > 0.0)
   {
      double ddSinceOpen = dd - InpRecoveryDDLevel;
      if(ddSinceOpen > 1.5)
      {
         ClosePositionsByMagic(g_recoveryMagic, 0);
         basket.recoveryActive = false;
         g_lastRecoveryClose = TimeCurrent();
         Print(StringFormat("Recovery emergency close: DD grew %.2f%% after hedge open", ddSinceOpen));
         return;
      }
   }

   if(!basket.recoveryActive && dd >= InpRecoveryDDLevel && !snap.extremeBlocked && !snap.spreadBlocked)
   {
      int hedgeDir = -basket.direction;

      // ENHANCED: Require 3+ confirmation votes (was 2) for recovery direction
      if(!IsRecoveryDirectionConfirmed(hedgeDir))
         return;

      // ENHANCED: Extra validation - check if momentum genuinely reversed on M5
      bool momentumReversed = false;
      if(hedgeDir == 1)
         momentumReversed = (tf[TF_M5].bias == 1 && tf[TF_M5].macdMain > tf[TF_M5].macdSignal);
      else
         momentumReversed = (tf[TF_M5].bias == -1 && tf[TF_M5].macdMain < tf[TF_M5].macdSignal);
      if(!momentumReversed)
         return;

      double basketVol = GetBasketVolume(InpMagicNumber, basket.direction);
      // ENHANCED: Limit recovery lot to 20% of basket volume (was 35%) for safety
      double safeLotPct = MathMin(QQEffectiveRecoveryLotPct(), 20.0);
      double hedgeLot = NormalizeLot(basketVol * (safeLotPct / 100.0));
      hedgeLot = MathMin(hedgeLot, NormalizeLot(MaxBasketLotsAllowed() * 0.35));

      if(hedgeLot > 0.0)
      {
         string comment = StringFormat("QQv6[RECOVERY/T%d/S%02d]", basket.session, basket.strategyId);
         if(OpenMarketTrade(hedgeDir, hedgeLot, g_recoveryMagic, comment))
         {
            basket.recoveryActive = true;
            basket.maxFloatingLoss = MathAbs(totalProfit);  // Record DD at hedge open
            Print(StringFormat("Recovery hedge opened: dir=%d lot=%.2f dd=%.2f (defensive, 20%% of basket)", hedgeDir, hedgeLot, dd));
         }
      }
      return;
   }

   if(basket.recoveryActive)
   {
      double closeTrigger = basket.basketTP * (InpRecoveryClosePct / 100.0);
      if(totalProfit >= closeTrigger || dd <= InpRecoveryDDLevel * 0.50)
      {
         ClosePositionsByMagic(g_recoveryMagic, 0);
         basket.recoveryActive = false;
         g_lastRecoveryClose = TimeCurrent();
         basket.lockProfit = MathMax(basket.lockProfit, totalProfit * 0.50);
         Print(StringFormat("Recovery hedge closed: totalProfit=%.2f dd=%.2f", totalProfit, dd));
      }
   }
}

void CloseOrphanRecoveryIfNeeded()
{
   if(CountMainPositions(0) == 0 && CountRecoveryPositions(0) > 0)
   {
      ClosePositionsByMagic(g_recoveryMagic, 0);
      g_lastRecoveryClose = TimeCurrent();
      Print("Orphan recovery positions closed.");
   }
}

bool IsRecoveryDirectionConfirmed(const int dir)
{
   // ENHANCED: Require 3+ votes (was 2) to prevent false recovery opens
   if(dir == 1)
   {
      int votes = 0;
      if(snap.localBias == 1) votes++;
      if(tf[TF_M5].bias == 1) votes++;
      if(tf[TF_M15].bias == 1) votes++;          // ENHANCED: Added M15 confirmation
      if(tf[TF_H1].bias >= 0) votes++;
      if(tf[TF_M5].macdMain > tf[TF_M5].macdSignal) votes++;  // ENHANCED: MACD confirmation
      if(tf[TF_M5].rsi > 48.0 && tf[TF_M5].rsi < 72.0) votes++; // ENHANCED: RSI in valid LONG zone
      return (votes >= 3);
   }

   if(dir == -1)
   {
      int votes = 0;
      if(snap.macroBias <= 0) votes++;
      if(tf[TF_M5].bias == -1) votes++;
      if(tf[TF_M15].bias == -1) votes++;         // ENHANCED: Added M15 confirmation
      if(tf[TF_H1].bias <= 0) votes++;
      if(tf[TF_M5].macdMain < tf[TF_M5].macdSignal) votes++;  // ENHANCED: MACD confirmation
      if(tf[TF_M5].rsi < 52.0 && tf[TF_M5].rsi > 28.0) votes++; // ENHANCED: RSI in valid SHORT zone
      return (votes >= 3 && !IsDangerousShortSetup());
   }

   return false;
}

//+------------------------------------------------------------------+
//| Risk management                                                   |
//+------------------------------------------------------------------+
bool HandleEmergencyDD()
{
   if(InpDDMode == DD_OFF)
      return false;

   double limit = QQEffectiveDDLimit();
   if(limit <= 0.0)
      return false;

   if(IsMicroSurvivalAccount() && IsMicroDailyLossBreached())
   {
      ClosePositionsByMagic(InpMagicNumber, 0);
      ClosePositionsByMagic(g_recoveryMagic, 0);
      g_emergencyPaused = true;
      Print("Emergency close executed: micro daily loss guard");
      ResetBasket(true);
      return true;
   }

   double dd = GetDrawdownPct();
   double marginLevel = GetMarginLevelPct();
   bool marginStop = (marginLevel > 0.0 && marginLevel < InpMarginStopPct);

   if(dd < limit && !marginStop)
      return false;

   string reason = StringFormat("Emergency DD %.2f / margin %.1f", dd, marginLevel);

   if(InpDDMode == DD_ALERT)
   {
      Print("DD alert: ", reason);
      return false;
   }

   if(InpDDMode == DD_PAUSE_NEW)
   {
      g_emergencyPaused = true;
      Print("New trades paused: ", reason);
      return true;
   }

   if(InpDDMode == DD_CLOSE_BASKET || InpDDMode == DD_CLOSE_AND_PAUSE)
   {
      ClosePositionsByMagic(InpMagicNumber, 0);
      ClosePositionsByMagic(g_recoveryMagic, 0);
      if(InpDDMode == DD_CLOSE_AND_PAUSE)
         g_emergencyPaused = true;

      Print("Emergency close executed: ", reason);
      ResetBasket(true);
      return true;
   }

   return false;
}

double GetDrawdownPct()
{
   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   if(balance <= 0.0)
      return 0.0;
   return MathMax(0.0, (balance - equity) / balance * 100.0);
}

double GetMarginLevelPct()
{
   double margin = AccountInfoDouble(ACCOUNT_MARGIN);
   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   if(margin <= 0.0)
      return 0.0;
   return equity / margin * 100.0;
}

bool HasEnoughMargin(const int dir, const double lot)
{
   double price = (dir == 1 ? snap.ask : snap.bid);
   double margin = 0.0;
   ENUM_ORDER_TYPE type = (dir == 1 ? ORDER_TYPE_BUY : ORDER_TYPE_SELL);

   if(!OrderCalcMargin(type, _Symbol, lot, price, margin))
      return false;

   double freeMargin = AccountInfoDouble(ACCOUNT_MARGIN_FREE);
   if(freeMargin <= margin * 1.25)
      return false;

   return true;
}

double MaxBasketLotsAllowed()
{
   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double maxLots = (balance / 1000.0) * InpMaxBasketLotsPct;
   if(IsMicroAccount())
      maxLots = InpMicroMaxLot;

   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double hardMax = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   return MathMax(minLot, MathMin(hardMax, maxLots));
}

//+------------------------------------------------------------------+
//| Filters                                                           |
//+------------------------------------------------------------------+
bool IsCorrelationBlocked()
{
   if(InpFilterCorrelation == QQ_OFF)
      return false;

   double corrRsi = 0.0;
   int corrDir = GetCorrelationProxyDirection(corrRsi);

   if(corrDir != 0)
   {
      if(snap.macroBias == 1 && corrDir == 1 && corrRsi > 62.0)
         return true;
      if(snap.macroBias == -1 && corrDir == -1 && corrRsi < 38.0)
         return true;
   }

   if(MathAbs(tf[TF_D1].rsi - tf[TF_M5].rsi) > InpCorrBlockRsiGap && snap.regime != REGIME_TREND)
      return true;

   return false;
}

int GetCorrelationProxyDirection(double &rsiOut)
{
   rsiOut = 0.0;
   string symbols[4] = {InpCorrSymbol1, InpCorrSymbol2, "USDJPY", "EURUSD"};

   for(int i=0; i<4; i++)
   {
      string sym = symbols[i];
      if(sym == "")
         continue;

      if(!SymbolSelect(sym, true))
         continue;

      int h = iRSI(sym, PERIOD_H1, 14, PRICE_CLOSE);
      if(h == INVALID_HANDLE)
         continue;

      double rsi = 0.0;
      bool ok = CopyOne(h, 0, 0, rsi);
      IndicatorRelease(h);

      if(ok)
      {
         rsiOut = rsi;
         if(sym == "EURUSD")
         {
            if(rsi > 55.0) return -1;
            if(rsi < 45.0) return 1;
            return 0;
         }
         if(rsi > 55.0) return 1;
         if(rsi < 45.0) return -1;
         return 0;
      }
   }

   if(tf[TF_D1].rsi > 55.0 && tf[TF_M5].rsi < 45.0)
      return -1;
   if(tf[TF_D1].rsi < 45.0 && tf[TF_M5].rsi > 55.0)
      return 1;

   return 0;
}

bool IsHolidayBlock()
{
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   if((dt.mon == 12 && dt.day >= 15) || (dt.mon == 1 && dt.day <= 15))
      return true;
   return false;
}

int GetSession()
{
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);

   if(dt.day_of_week == 0 || dt.day_of_week == 6)
      return 0;

   int hour = dt.hour;

   if(hour >= 0 && hour < 7)
      return (InpTradeAsia == QQ_ON ? 1 : 0);

   if(hour >= 7 && hour < 14)
      return (InpTradeLondon == QQ_ON ? 2 : 0);

   if(hour >= 14 && hour < 22)
      return (InpTradeNewYork == QQ_ON ? 3 : 0);

   return 0;
}

bool IsNewM1Bar()
{
   datetime t = iTime(_Symbol, PERIOD_M1, 0);
   if(t <= 0)
      return false;

   if(t != g_lastM1Bar)
   {
      g_lastM1Bar = t;
      return true;
   }
   return false;
}

void ResetDailyCounterIfNeeded()
{
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   if(dt.day_of_year != g_dayOfYear)
   {
      g_dayOfYear = dt.day_of_year;
      g_tradesToday = 0;
      g_dayStartBalance = AccountInfoDouble(ACCOUNT_BALANCE);
      if(g_emergencyPaused && GetDrawdownPct() < InpMicroDDValue * 0.25)
         g_emergencyPaused = false;
   }
}

bool IsMicroAccount()
{
   return (AccountInfoDouble(ACCOUNT_BALANCE) < InpMicroLimit);
}

bool IsMicroSurvivalAccount()
{
   if(InpMicroSurvival == QQ_OFF)
      return false;
   return (AccountInfoDouble(ACCOUNT_BALANCE) <= InpMicroSurvivalLimit);
}

bool IsMicroDailyLossBreached()
{
   if(g_dayStartBalance <= 0.0)
      return false;

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double lossPct = MathMax(0.0, (g_dayStartBalance - equity) / g_dayStartBalance * 100.0);
   return (lossPct >= InpMicroDailyLossPct);
}

//+------------------------------------------------------------------+
//| Position helpers                                                  |
//+------------------------------------------------------------------+
void DetectExistingBasket()
{
   int buyCount = CountMainPositions(1);
   int sellCount = CountMainPositions(-1);

   if(buyCount + sellCount <= 0)
   {
      if(basket.active)
         ResetBasket(true);
      return;
   }

   if(!basket.active)
   {
      basket.active = true;
      basket.direction = (buyCount >= sellCount ? 1 : -1);
      basket.strategyId = 0;
      basket.session = snap.session;
      basket.firstTradeTime = OldestPositionTime(InpMagicNumber, basket.direction);
      basket.lastGridTime = 0;
      basket.baseLot = SmallestPositionLot(InpMagicNumber, basket.direction);
      basket.basketTP = CalculateBasketTarget(MathMax(basket.baseLot, SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN)));
      basket.peakProfit = GetBasketProfit(InpMagicNumber, basket.direction);
      basket.cycleMFE = MathMax(0.0, basket.peakProfit);
      basket.cycleMAE = MathMin(0.0, basket.peakProfit);
      basket.maxFloatingLoss = MathMax(0.0, -basket.peakProfit);
      basket.gridCount = MathMax(0, CountMainPositions(basket.direction) - 1);
      basket.partialClosed = false;
      basket.defensivePartialDone = false;
      basket.trailingActive = false;
      basket.recoveryActive = (CountRecoveryPositions(0) > 0);
      Print("Existing basket detected and adopted.");
   }
}

int CountMainPositions(const int dir)
{
   return CountPositionsByMagic(InpMagicNumber, dir);
}

int CountRecoveryPositions(const int dir)
{
   return CountPositionsByMagic(g_recoveryMagic, dir);
}

int CountPositionsByMagic(const int magic, const int dir)
{
   int count = 0;
   for(int i=PositionsTotal()-1; i>=0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)
         continue;
      if((int)PositionGetInteger(POSITION_MAGIC) != magic)
         continue;

      ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      if(dir == 0 || (dir == 1 && type == POSITION_TYPE_BUY) || (dir == -1 && type == POSITION_TYPE_SELL))
         count++;
   }
   return count;
}

double GetBasketProfit(const int magic, const int dir)
{
   double profit = 0.0;
   for(int i=PositionsTotal()-1; i>=0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)
         continue;
      if((int)PositionGetInteger(POSITION_MAGIC) != magic)
         continue;

      ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      if(dir == 0 || (dir == 1 && type == POSITION_TYPE_BUY) || (dir == -1 && type == POSITION_TYPE_SELL))
      {
         profit += PositionGetDouble(POSITION_PROFIT);
         profit += PositionGetDouble(POSITION_SWAP);
      }
   }
   return profit;
}

double GetBasketVolume(const int magic, const int dir)
{
   double volume = 0.0;
   for(int i=PositionsTotal()-1; i>=0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)
         continue;
      if((int)PositionGetInteger(POSITION_MAGIC) != magic)
         continue;

      ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      if(dir == 0 || (dir == 1 && type == POSITION_TYPE_BUY) || (dir == -1 && type == POSITION_TYPE_SELL))
         volume += PositionGetDouble(POSITION_VOLUME);
   }
   return volume;
}

double GetWorstPrice(const int dir)
{
   double worst = (dir == 1 ? DBL_MAX : 0.0);
   bool found = false;

   for(int i=PositionsTotal()-1; i>=0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)
         continue;
      if((int)PositionGetInteger(POSITION_MAGIC) != InpMagicNumber)
         continue;

      ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      double price = PositionGetDouble(POSITION_PRICE_OPEN);
      if(dir == 1 && type == POSITION_TYPE_BUY)
      {
         worst = MathMin(worst, price);
         found = true;
      }
      else if(dir == -1 && type == POSITION_TYPE_SELL)
      {
         worst = MathMax(worst, price);
         found = true;
      }
   }

   if(!found)
      return 0.0;

   return worst;
}

bool FindHeaviestPosition(const int magic, const int dir, ulong &ticketOut, double &volumeOut)
{
   ticketOut = 0;
   volumeOut = 0.0;

   for(int i=PositionsTotal()-1; i>=0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)
         continue;
      if((int)PositionGetInteger(POSITION_MAGIC) != magic)
         continue;

      ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      if(dir != 0 && !((dir == 1 && type == POSITION_TYPE_BUY) || (dir == -1 && type == POSITION_TYPE_SELL)))
         continue;

      double vol = PositionGetDouble(POSITION_VOLUME);
      if(vol > volumeOut)
      {
         volumeOut = vol;
         ticketOut = ticket;
      }
   }

   return (ticketOut > 0 && volumeOut > 0.0);
}

datetime OldestPositionTime(const int magic, const int dir)
{
   datetime oldest = TimeCurrent();
   bool found = false;

   for(int i=PositionsTotal()-1; i>=0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)
         continue;
      if((int)PositionGetInteger(POSITION_MAGIC) != magic)
         continue;

      ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      if(dir != 0 && !((dir == 1 && type == POSITION_TYPE_BUY) || (dir == -1 && type == POSITION_TYPE_SELL)))
         continue;

      datetime t = (datetime)PositionGetInteger(POSITION_TIME);
      if(!found || t < oldest)
      {
         oldest = t;
         found = true;
      }
   }

   return oldest;
}

double SmallestPositionLot(const int magic, const int dir)
{
   double smallest = DBL_MAX;
   bool found = false;

   for(int i=PositionsTotal()-1; i>=0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)
         continue;
      if((int)PositionGetInteger(POSITION_MAGIC) != magic)
         continue;

      ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      if(dir != 0 && !((dir == 1 && type == POSITION_TYPE_BUY) || (dir == -1 && type == POSITION_TYPE_SELL)))
         continue;

      double vol = PositionGetDouble(POSITION_VOLUME);
      smallest = MathMin(smallest, vol);
      found = true;
   }

   if(!found)
      return SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);

   return smallest;
}

void ClosePositionsByMagic(const int magic, const int dir)
{
   trade.SetExpertMagicNumber(magic);
   trade.SetDeviationInPoints(InpSlippage);

   for(int i=PositionsTotal()-1; i>=0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;
      if(PositionGetString(POSITION_SYMBOL) != _Symbol)
         continue;
      if((int)PositionGetInteger(POSITION_MAGIC) != magic)
         continue;

      ENUM_POSITION_TYPE type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      if(dir != 0 && !((dir == 1 && type == POSITION_TYPE_BUY) || (dir == -1 && type == POSITION_TYPE_SELL)))
         continue;

      if(!trade.PositionClose(ticket, InpSlippage))
         Print("Close failed ticket=", ticket, " retcode=", trade.ResultRetcode(), " ", trade.ResultRetcodeDescription());
   }
}

double NormalizeLot(const double rawLot)
{
   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double maxLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   double step = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);

   if(step <= 0.0 || minLot <= 0.0 || maxLot <= 0.0)
      return 0.0;

   double lot = MathFloor(rawLot / step) * step;
   lot = MathMax(minLot, MathMin(maxLot, lot));

   int digits = 2;
   if(step < 0.01) digits = 3;
   if(step < 0.001) digits = 4;

   return NormalizeDouble(lot, digits);
}


//+------------------------------------------------------------------+
//| Behavioral twin engines                                           |
//+------------------------------------------------------------------+
void QQInitializeEngines()
{
   g_firstSeenTime = TimeCurrent();
   QQInitializeStrategyMatrix();
   QQProfessionalSuiteInitialize();
   QQUpdateCapitalState();
   g_profile = QQBuildProfile();
   QQUpdateCapitalState();
   QQUpdateEnvironmentState();
   QQUpdateDiagnostics();
   g_lastBlockReason = "Initialized";
   QQLogEvent("INIT", "Behavioral twin engines initialized", 0, 0.0, 0.0);
}

void QQRefreshControlState()
{
   QQUpdateCapitalState();
   g_profile = QQBuildProfile();
   QQUpdateCapitalState();
   QQUpdateEnvironmentState();
   QQBuildCapitalTuning();
   QQRefreshProfitabilityOptimizer();
}

QQProfileState QQBuildProfile()
{
   QQProfileState p;
   p.profile = InpQQProfile;
   if(p.profile == QQ_PROFILE_AUTO)
      p.profile = QQAutoProfileFromInputs();

   p.name = "IC/VT RAW Medium";
   p.brokerHint = "IC Markets / VT Markets RAW";
   p.hiddenSpreadCap = QQ_HIDDEN_MAX_SPREAD_POINTS;
   p.softSpreadCap = 24;
   p.maxCyclesPerDay = MathMax(1, InpMaxCyclesPerDay);
   p.cooldownMinutes = MathMax(15, InpMinMinutesBetweenCycles);
   p.minEntryScore = MathMax(5, InpMinEntryScore);
   p.maxGridLevels = MathMax(1, InpMaxGridLevels);
   p.holdingMinMinutes = 30;
   p.holdingMaxMinutes = 120;
   p.lotDivisorScale = 1.00;
   p.gridSpacingScale = 1.00;
   p.gridAtrScale = 1.00;
   p.targetScale = 1.00;
   p.trailAggression = 1.00;
   p.maxDepositLoadPct = InpGrowthMaxDepositLoad;
   p.maxEquityDDPct = InpDDValue;
   p.maxDailyLossPct = InpMaxDailyLossPct;
   p.maxWeeklyLossPct = InpMaxWeeklyLossPct;
   p.longBiasTargetPct = InpLongBiasTargetPct;
   p.allowGrid = true;
   p.allowRecovery = true;
   p.allowHighRisk = false;
   p.allowStrategy4 = false;
   p.allowStrategy5 = false;
   p.preferLongs = true;
   p.microFirst = false;
   p.strictEnvironment = true;
   p.warning = "Medium profile follows the public QQ v3.52 default behavior target.";

   if(p.profile == QQ_PROFILE_IC_VT_RAW_LOW)
   {
      p.name = "IC/VT RAW Low";
      p.maxCyclesPerDay = MathMin(p.maxCyclesPerDay, 3);
      p.cooldownMinutes = MathMax(p.cooldownMinutes, 90);
      p.minEntryScore = MathMax(p.minEntryScore, 7);
      p.maxGridLevels = MathMin(p.maxGridLevels, 3);
      p.lotDivisorScale = 1.35;
      p.gridSpacingScale = 1.28;
      p.gridAtrScale = 1.20;
      p.targetScale = 0.88;
      p.trailAggression = 1.20;
      p.maxDepositLoadPct = 24.0;
      p.maxEquityDDPct = MathMin(p.maxEquityDDPct, 8.0);
      p.warning = "Low profile prioritizes capital preservation and lower activity.";
   }
   else if(p.profile == QQ_PROFILE_IC_RAW_HIGH)
   {
      p.name = "IC RAW High";
      p.maxCyclesPerDay = MathMax(p.maxCyclesPerDay, 7);
      p.cooldownMinutes = MathMin(p.cooldownMinutes, 30);
      p.minEntryScore = MathMax(4, p.minEntryScore - 1);
      p.maxGridLevels = MathMax(p.maxGridLevels, 4);
      p.lotDivisorScale = 0.78;
      p.gridSpacingScale = 0.86;
      p.gridAtrScale = 0.88;
      p.targetScale = 1.18;
      p.trailAggression = 0.85;
      p.maxDepositLoadPct = InpICMaxDepositLoadTarget;
      p.maxEquityDDPct = MathMax(p.maxEquityDDPct, 14.0);
      p.allowHighRisk = true;
      p.allowStrategy4 = true;
      p.allowStrategy5 = true;
      p.warning = "High risk is aggressive; Strategy 4 and 5 are enabled as in the public v3.5 changelog.";
   }
   else if(p.profile == QQ_PROFILE_ROBOFOREX_ECN)
   {
      p.name = "Roboforex ECN";
      p.brokerHint = "Roboforex ECN";
      p.softSpreadCap = 22;
      p.lotDivisorScale = 1.12;
      p.gridSpacingScale = 1.10;
      p.gridAtrScale = 1.08;
      p.targetScale = 1.05;
      p.maxDepositLoadPct = 30.0;
      p.warning = "Roboforex ECN profile compensates for execution and commission variance.";
   }
   else if(p.profile == QQ_PROFILE_FUSION_ZERO)
   {
      p.name = "Fusion Zero";
      p.brokerHint = "Fusion Zero";
      p.softSpreadCap = 20;
      p.lotDivisorScale = 1.08;
      p.gridSpacingScale = 1.04;
      p.gridAtrScale = 1.02;
      p.targetScale = 1.03;
      p.maxDepositLoadPct = 30.0;
      p.warning = "Fusion Zero profile targets low spread with commission-aware exits.";
   }
   else if(p.profile == QQ_PROFILE_MICRO_SAFE)
   {
      p.name = "Micro Safe";
      p.brokerHint = "Any compatible XAUUSD micro/cent account";
      p.maxCyclesPerDay = MathMin(p.maxCyclesPerDay, 2);
      p.cooldownMinutes = MathMax(p.cooldownMinutes, 180);
      p.minEntryScore = MathMax(p.minEntryScore, 8);
      p.maxGridLevels = 1;
      p.lotDivisorScale = 2.20;
      p.gridSpacingScale = 1.75;
      p.gridAtrScale = 1.55;
      p.targetScale = 0.70;
      p.trailAggression = 1.45;
      p.maxDepositLoadPct = InpMicroMaxDepositLoad;
      p.maxEquityDDPct = MathMin(InpMicroDDValue, 4.0);
      p.allowGrid = false;
      p.allowRecovery = false;
      p.microFirst = true;
      p.warning = "Micro Safe is not public QQ behavior; it is the survival layer for very small balances.";
   }
   else if(p.profile == QQ_PROFILE_VT_FAST)
   {
      p.name = "VT Fast";
      p.brokerHint = "VT Markets RAW ECN";
      p.maxCyclesPerDay = MathMax(p.maxCyclesPerDay, 8);
      p.cooldownMinutes = MathMin(p.cooldownMinutes, 20);
      p.minEntryScore = MathMax(5, p.minEntryScore);
      p.maxGridLevels = MathMin(MathMax(p.maxGridLevels, 3), 5);
      p.lotDivisorScale = 0.92;
      p.gridSpacingScale = 0.92;
      p.gridAtrScale = 0.95;
      p.targetScale = 0.82;
      p.trailAggression = 0.72;
      p.maxDepositLoadPct = InpVTMaxDepositLoadTarget;
      p.maxEquityDDPct = MathMax(p.maxEquityDDPct, 12.0);
      p.allowStrategy5 = true;
      p.warning = "VT Fast calibrates toward the public VT signal holding-time profile.";
   }

   if(g_capital.tier <= TIER_LOW || AccountInfoDouble(ACCOUNT_BALANCE) < 500.0)
   {
      p.profile = QQ_PROFILE_MICRO_SAFE;
      p.name = "Micro Safe Auto";
      p.maxCyclesPerDay = MathMin(p.maxCyclesPerDay, 2);
      p.cooldownMinutes = MathMax(p.cooldownMinutes, 180);
      p.minEntryScore = MathMax(p.minEntryScore, 8);
      p.maxGridLevels = MathMin(p.maxGridLevels, (g_capital.tier == TIER_LOW ? 3 : 1));
      p.allowRecovery = (g_capital.tier >= TIER_LOW && g_isHedging);
      p.allowGrid = (g_capital.tier >= TIER_SMALL);
      p.microFirst = true;
      p.maxDepositLoadPct = g_capital.maxDepositLoad;
      p.maxEquityDDPct = MathMin(p.maxEquityDDPct, InpMicroDDValue);
      p.warning = "Auto micro layer active because capital is below public QQ minimum.";
   }

   return p;
}

ENUM_QQ_PROFILE QQAutoProfileFromInputs()
{
   if(AccountInfoDouble(ACCOUNT_BALANCE) < 500.0)
      return QQ_PROFILE_MICRO_SAFE;
   if(InpSets == SET_RAW_LOW)
      return QQ_PROFILE_IC_VT_RAW_LOW;
   if(InpSets == SET_RAW_HIGH)
      return QQ_PROFILE_IC_RAW_HIGH;
   if(InpSets == SET_ROBO_ECN)
      return QQ_PROFILE_ROBOFOREX_ECN;
   if(InpSets == SET_FUSION_ZERO)
      return QQ_PROFILE_FUSION_ZERO;
   return QQ_PROFILE_IC_VT_RAW_MEDIUM;
}

void QQUpdateCapitalState()
{
   g_capital.balance = AccountInfoDouble(ACCOUNT_BALANCE);
   g_capital.equity = AccountInfoDouble(ACCOUNT_EQUITY);
   g_capital.freeMargin = AccountInfoDouble(ACCOUNT_MARGIN_FREE);
   g_capital.minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   g_capital.maxLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   g_capital.lotStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   g_capital.tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   g_capital.tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   g_capital.leverage = (double)AccountInfoInteger(ACCOUNT_LEVERAGE);

   if(g_capital.balance < 50.0)
      g_capital.tier = TIER_NANO;
   else if(g_capital.balance < 100.0)
      g_capital.tier = TIER_MICRO;
   else if(g_capital.balance < 300.0)
      g_capital.tier = TIER_SMALL;
   else if(g_capital.balance < 500.0)
      g_capital.tier = TIER_LOW;
   else if(g_capital.balance < 1000.0)
      g_capital.tier = TIER_STANDARD;
   else
      g_capital.tier = TIER_GROWTH;

   g_capital.tierName = QQCapitalTierName(g_capital.tier);
   g_capital.maxDepositLoad = QQTierMaxDepositLoad(g_capital.tier);
   g_capital.maxCycleLossBudget = g_capital.balance * QQTierCycleLossPct(g_capital.tier) / 100.0;
   g_capital.projectedDepositLoad = QQProjectedDepositLoad(g_capital.minLot);
   g_capital.canTradeMinLot = QQCanTradeMinimumLot();
   g_capital.lotStepFeasibility = QQLotStepFeasibilityScore();
   g_capital.capitalSurvivalScore = QQCapitalSurvivalScore();
   g_capital.gridAllowed = QQTierAllowsGrid(g_capital.tier);
   g_capital.recoveryAllowed = QQTierAllowsRecovery(g_capital.tier) && g_isHedging;
   g_capital.blockReason = "";

   if(!g_capital.canTradeMinLot)
   {
      g_capital.tradeMode = (g_capital.balance < 500.0 ? TRADE_MODE_CENT_ACCOUNT_REQUIRED : TRADE_MODE_MONITOR_ONLY);
      g_capital.blockReason = "Minimum lot is not feasible for current capital";
   }
   else if(g_capital.tier == TIER_NANO && InpAllowNanoTrading == QQ_OFF)
   {
      g_capital.tradeMode = TRADE_MODE_MONITOR_ONLY;
      g_capital.blockReason = "Nano trading disabled; monitor-only survival mode";
   }
   else if(g_capital.tier <= TIER_LOW)
      g_capital.tradeMode = TRADE_MODE_MICRO_SURVIVAL;
   else
      g_capital.tradeMode = TRADE_MODE_FULL;

   g_capital.tradeModeName = QQTradeModeName(g_capital.tradeMode);
}

void QQUpdateEnvironmentState()
{
   string sym = _Symbol;
   StringToUpper(sym);
   g_env.symbolOk = (StringFind(sym, "XAU") >= 0 || StringFind(sym, "GOLD") >= 0);
   g_env.digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   g_env.digitsOk = (g_env.digits == 2);
   g_env.hedgingOk = g_isHedging;
   g_env.leverage = AccountInfoInteger(ACCOUNT_LEVERAGE);
   g_env.leverageOk = (g_env.leverage >= 100);
   g_env.tradingAllowed = ((bool)TerminalInfoInteger(TERMINAL_TRADE_ALLOWED) && (bool)MQLInfoInteger(MQL_TRADE_ALLOWED) && (bool)AccountInfoInteger(ACCOUNT_TRADE_ALLOWED));
   g_env.connected = (bool)TerminalInfoInteger(TERMINAL_CONNECTED);
   g_env.broker = AccountInfoString(ACCOUNT_SERVER);
   g_env.accountCompany = AccountInfoString(ACCOUNT_COMPANY);
   g_env.brokerOk = QQBrokerHealthScore() >= 35.0;
   g_env.vpsLikelyOk = true;
   g_env.propFirmBlocked = QQIsPropFirmAccount();
   g_env.reason = "OK";

   if(!g_env.symbolOk) g_env.reason = "Symbol must be XAUUSD/GOLD";
   else if(!g_env.digitsOk) g_env.reason = "Gold must be 2 digits";
   else if(!g_env.hedgingOk) g_env.reason = "Hedging account required";
   else if(!g_env.leverageOk) g_env.reason = "Leverage below 1:100";
   else if(!g_env.tradingAllowed) g_env.reason = "Algo/account trading disabled";
   else if(!g_env.connected) g_env.reason = "Terminal disconnected";
   else if(g_env.propFirmBlocked) g_env.reason = "Prop-firm style account blocked";

   g_env.allOk = (g_env.symbolOk && g_env.digitsOk && g_env.hedgingOk && g_env.leverageOk && g_env.tradingAllowed && g_env.connected && !g_env.propFirmBlocked);
}

void QQUpdateDiagnostics()
{
   g_diag.brokerHealthScore = QQBrokerHealthScore();
   g_diag.executionHealthScore = QQExecutionHealthScore();
   g_diag.longBiasScore = QQLongBiasScore();
   g_diag.lastProjectedMargin = QQProjectedDepositLoad(MathMax(g_capital.minLot, basket.baseLot));
   g_diag.lastAuditText = QQBacktestDiagnosticsText();
   if(g_diag.weekStartTime <= 0)
   {
      g_diag.weekStartTime = TimeCurrent();
      g_diag.weekStartBalance = AccountInfoDouble(ACCOUNT_BALANCE);
   }
}

bool QQGateNewCycle()
{
   if(!g_env.allOk)
   {
      QQSetBlockReason(g_env.reason);
      return false;
   }
   if(g_capital.tradeMode == TRADE_MODE_MONITOR_ONLY || g_capital.tradeMode == TRADE_MODE_CENT_ACCOUNT_REQUIRED || g_capital.tradeMode == TRADE_MODE_ENV_BLOCKED)
   {
      QQSetBlockReason(g_capital.blockReason);
      return false;
   }
   if(QQEmergencyRiskLock())
      return false;
   if(InpUseNewsGuard == QQ_ON && QQNewsGuardBlocked())
   {
      QQSetBlockReason("News/rollover guard window active");
      return false;
   }
   if(snap.spread > QQEffectiveSpreadCap())
   {
      QQSetBlockReason("Hidden spread cap 30 exceeded");
      return false;
   }
   if(g_capital.projectedDepositLoad > g_capital.maxDepositLoad)
   {
      QQSetBlockReason("Projected deposit load above tier budget");
      return false;
   }
   if(!QQProfessionalSuiteAllowsNewCycle())
      return false;
   QQSetBlockReason("Waiting for high-probability alignment");
   return true;
}

int QQEffectiveSpreadCap()
{
   int cap = (InpUseHiddenSpread30 == QQ_ON ? QQ_HIDDEN_MAX_SPREAD_POINTS : InpHardSpreadCap);
   if(g_profile.hiddenSpreadCap > 0)
      cap = MathMin(cap, g_profile.hiddenSpreadCap);
   if(g_capital.tier <= TIER_LOW)
      cap = MathMin(cap, InpMicroHardSpreadCap);
   return MathMax(5, cap);
}

int QQEffectiveMaxCyclesPerDay()
{
   if(InpUseCapitalAutoTune == QQ_ON && g_tune.maxCyclesPerDay > 0)
      return g_tune.maxCyclesPerDay;
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW)
      return 2;
   if(mode == CAP_MEDIAN)
      return 4;
   if(mode == CAP_HIGH)
      return 5;
   return MathMax(1, MathMin(InpMaxCyclesPerDay, g_profile.maxCyclesPerDay));
}

int QQEffectiveMinEntryScore(const int strategyId)
{
   if(InpUseCapitalAutoTune == QQ_ON && g_tune.minMatrixScore > 0.0)
   {
      int tuned = (int)MathRound(g_tune.minMatrixScore);
      if(strategyId == 11 && (QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_LOW))
         tuned = MathMax(6, tuned - 1);
      if(strategyId == 4 || strategyId == 5)
         tuned += (QQHighRiskStrategiesAllowed() ? 0 : 2);
      return tuned;
   }
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW)
      return 7;
   if(mode == CAP_MEDIAN)
      return 6;
   if(mode == CAP_HIGH)
      return MathMax(5, InpMinEntryScore);

   int s = MathMax(InpMinEntryScore, g_profile.minEntryScore);
   if(g_capital.tier <= TIER_SMALL)
      s = MathMax(s, 8);
   if(strategyId == 4 || strategyId == 5)
      s += (g_profile.allowHighRisk ? 0 : 3);
   if(strategyId == 11 && g_capital.tier <= TIER_LOW)
      s = MathMax(7, s - 1);
   return s;
}

bool QQStrategyEnabled(const int id)
{
   if(id < 1 || id > STRATEGY_TOTAL)
      return false;

   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW)
      return (id == 1 || id == 6 || id == 11);
   if(mode == CAP_MEDIAN)
      return (id >= 1 && id <= 9);

   if(InpClosedLogicMode == QQ_OFF)
      return true;
   if(id == 4)
      return g_profile.allowStrategy4;
   if(id == 5)
      return (g_profile.allowStrategy5 || g_profile.allowHighRisk);
   if(id == 12 && !g_profile.allowRecovery)
      return false;
   if(id == 3 && g_capital.tier <= TIER_MICRO)
      return false;
   return true;
}

bool QQRuntimeGoldOnlyOk(string &reason)
{
   string symbolName = _Symbol;
   StringToUpper(symbolName);
   if(StringFind(symbolName, "XAU") < 0 && StringFind(symbolName, "GOLD") < 0)
   {
      reason = "XAUUSD/GOLD only runtime lock";
      return false;
   }
   return true;
}

bool QQPreTradeGuard(const int dir, const double lot, const int magic, string &reason)
{
   reason = "OK";
   if(!QQRuntimeGoldOnlyOk(reason))
      return false;
   if(!g_env.allOk)
   {
      reason = g_env.reason;
      return false;
   }
   if(lot < g_capital.minLot || lot > g_capital.maxLot)
   {
      reason = "Lot outside symbol limits";
      return false;
   }
   if(snap.spread > QQEffectiveSpreadCap())
   {
      reason = "Spread above hidden cap";
      return false;
   }
   if(QQProjectedDepositLoad(lot) > g_capital.maxDepositLoad)
   {
      reason = "Projected deposit load above tier cap";
      return false;
   }
   if(dir == -1 && g_profile.preferLongs && IsDangerousShortSetup())
   {
      reason = "Short blocked by public long-bias normalizer";
      return false;
   }
   if(!QQLotLossBudgetFeasible(dir, lot))
   {
      reason = "Minimum adverse move exceeds cycle loss budget";
      return false;
   }
   return true;
}

double QQCapitalAdjustedLot(const double proposed, const int gridLevel, const bool rescue)
{
   double lot = proposed;
   if(g_capital.tier == TIER_NANO)
      lot = g_capital.minLot;
   else if(g_capital.tier == TIER_MICRO)
      lot = MathMin(lot, g_capital.minLot);
   else if(g_capital.tier == TIER_SMALL)
      lot = MathMin(lot, g_capital.minLot * 1.5);
   else if(g_capital.tier == TIER_LOW)
      lot = MathMin(lot, g_capital.minLot * 2.0);
   if(gridLevel > 0 && g_capital.tier <= TIER_LOW)
      lot = MathMin(lot, g_capital.minLot);
   if(rescue && !g_capital.recoveryAllowed)
      lot = 0.0;
   return NormalizeLot(lot);
}

double QQProjectedDepositLoad(const double lot)
{
   double price = (snap.ask > 0.0 ? snap.ask : SymbolInfoDouble(_Symbol, SYMBOL_ASK));
   double margin = 0.0;
   if(price <= 0.0 || lot <= 0.0)
      return 0.0;
   if(!OrderCalcMargin(ORDER_TYPE_BUY, _Symbol, lot, price, margin))
      return 1000.0;
   if(g_capital.equity <= 0.0)
      return 1000.0;
   return margin / g_capital.equity * 100.0;
}

bool QQCanTradeMinimumLot()
{
   if(g_capital.minLot <= 0.0 || g_capital.balance <= 0.0)
      return false;
   double load = QQProjectedDepositLoad(g_capital.minLot);
   if(load <= 0.0 || load > g_capital.maxDepositLoad)
      return false;
   double stress = QQProjectedCycleDD(1, g_capital.minLot, 0);
   if(stress > QQTierCycleLossPct(g_capital.tier) * 1.35)
      return false;
   return true;
}

bool QQLotLossBudgetFeasible(const int dir, const double lot)
{
   double projected = QQProjectedCycleDD(dir, lot, CountMainPositions(dir));
   return (projected <= QQTierCycleLossPct(g_capital.tier) * 1.35);
}

double QQProjectedCycleDD(const int dir, const double lot, const int gridLevel)
{
   double points = MathMax(120.0, SafePoints(tf[TF_M5].atr) * (1.0 + gridLevel * 0.65));
   double tickVal = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSz = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickVal <= 0.0 || tickSz <= 0.0 || g_capital.balance <= 0.0)
      return 100.0;
   double money = points * _Point / tickSz * tickVal * lot;
   return money / g_capital.balance * 100.0;
}

bool QQTierAllowsGrid(const ENUM_QQ_CAPITAL_TIER tier)
{
   if(!g_profile.allowGrid)
      return false;
   if(tier == TIER_NANO || tier == TIER_MICRO)
      return false;
   return true;
}

bool QQTierAllowsRecovery(const ENUM_QQ_CAPITAL_TIER tier)
{
   if(!g_profile.allowRecovery)
      return false;
   return (tier >= TIER_LOW);
}

double QQTierMaxDepositLoad(const ENUM_QQ_CAPITAL_TIER tier)
{
   if(tier == TIER_NANO) return InpNanoMaxDepositLoad;
   if(tier == TIER_MICRO) return InpMicroMaxDepositLoad;
   if(tier == TIER_SMALL) return InpSmallMaxDepositLoad;
   if(tier == TIER_LOW) return InpLowMaxDepositLoad;
   if(tier == TIER_STANDARD) return InpStandardMaxDepositLoad;
   return InpGrowthMaxDepositLoad;
}

double QQTierCycleLossPct(const ENUM_QQ_CAPITAL_TIER tier)
{
   if(tier == TIER_NANO) return 1.2;
   if(tier == TIER_MICRO) return 1.8;
   if(tier == TIER_SMALL) return 2.5;
   if(tier == TIER_LOW) return 3.5;
   if(tier == TIER_STANDARD) return 5.0;
   return MathMax(5.0, InpCycleLossPct);
}

double QQCapitalSurvivalScore()
{
   double score = 100.0;
   score -= MathMax(0.0, QQProjectedDepositLoad(g_capital.minLot) - g_capital.maxDepositLoad) * 3.0;
   score -= MathMax(0.0, GetDrawdownPct() - QQTierCycleLossPct(g_capital.tier)) * 5.0;
   score += (g_capital.leverage >= 500.0 ? 8.0 : (g_capital.leverage >= 100.0 ? 3.0 : -15.0));
   if(g_capital.balance < 50.0 && InpAllowNanoTrading == QQ_OFF)
      score -= 35.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQLotStepFeasibilityScore()
{
   if(g_capital.lotStep <= 0.0 || g_capital.minLot <= 0.0)
      return 0.0;
   double granularity = g_capital.minLot / g_capital.lotStep;
   double load = QQProjectedDepositLoad(g_capital.minLot);
   double score = 100.0 - load * 2.0;
   if(granularity <= 1.0)
      score -= 10.0;
   return MathMax(0.0, MathMin(100.0, score));
}

bool QQEmergencyRiskLock()
{
   double dd = GetDrawdownPct();
   if(dd > g_profile.maxEquityDDPct)
   {
      QQSetBlockReason("Profile equity DD limit reached");
      return true;
   }
   if(g_dayStartBalance > 0.0)
   {
      double dailyLoss = MathMax(0.0, (g_dayStartBalance - AccountInfoDouble(ACCOUNT_EQUITY)) / g_dayStartBalance * 100.0);
      if(dailyLoss > g_profile.maxDailyLossPct)
      {
         QQSetBlockReason("Daily loss limit reached");
         return true;
      }
   }
   if(g_diag.weekStartBalance > 0.0)
   {
      double weeklyLoss = MathMax(0.0, (g_diag.weekStartBalance - AccountInfoDouble(ACCOUNT_EQUITY)) / g_diag.weekStartBalance * 100.0);
      if(weeklyLoss > g_profile.maxWeeklyLossPct)
      {
         QQSetBlockReason("Weekly loss limit reached");
         return true;
      }
   }
   return false;
}

ENUM_QQ_CAPITAL_MODE QQEffectiveCapitalMode()
{
   if(InpCapitalMode != CAP_MANUAL)
      return InpCapitalMode;

   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   if(bal > 0.0 && bal <= 200.0)
      return CAP_LOW;
   if(bal > 200.0 && bal <= 600.0)
      return CAP_MEDIAN;
   if(bal > 600.0)
      return CAP_HIGH;

   return CAP_MANUAL;
}

string QQCapitalModeName()
{
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW) return "LOW";
   if(mode == CAP_MEDIAN) return "MEDIAN";
   if(mode == CAP_HIGH) return "HIGH";
   return "MANUAL";
}

int QQEffectiveCapitalGridLevels()
{
   if(InpUseCapitalAutoTune == QQ_ON)
      return MathMax(0, g_tune.maxGridLevels);
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW)
      return 0;
   if(mode == CAP_MEDIAN)
      return 1;
   if(mode == CAP_HIGH)
      return 3;
   if(g_capital.tier == TIER_SMALL)
      return 1;
   return MathMax(1, InpMaxGridLevels);
}

double QQEffectiveBasketTargetPct()
{
   if(InpUseCapitalAutoTune == QQ_ON && g_tune.targetPct > 0.0)
      return g_tune.targetPct;
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW)
      return 0.30;
   if(mode == CAP_MEDIAN)
      return 0.20;
   if(mode == CAP_HIGH)
      return 0.18;
   return (IsMicroAccount() ? InpMicroTargetPct : InpBasketTargetPct);
}

double QQEffectiveMinBasketTarget()
{
   double base = MathMax(InpMinBasketTarget, 1.50);
   if(QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_SMALL)
      base = MathMax(base, 0.85);
   if(QQEffectiveCapitalMode() == CAP_HIGH || g_capital.tier >= TIER_GROWTH)
      base = MathMax(base, 2.00);
   return base;
}

double QQEffectiveBreakEvenTriggerPct()
{
   if(InpUseCapitalAutoTune == QQ_ON && g_tune.breakEvenTrigger > 0.0)
      return g_tune.breakEvenTrigger;
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW)
      return 60.0;
   if(mode == CAP_MEDIAN)
      return 45.0;
   if(g_capital.tier == TIER_NANO || g_capital.tier == TIER_MICRO)
      return 62.0;
   return InpBreakEvenTriggerPct;
}

double QQEffectiveDDLimit()
{
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW)
      return 6.0;
   if(mode == CAP_MEDIAN)
      return 10.0;
   if(mode == CAP_HIGH)
      return 12.0;
   return (IsMicroAccount() ? InpMicroDDValue : InpDDValue);
}

double QQEffectiveRecoveryLotPct()
{
   ENUM_QQ_CAPITAL_MODE mode = QQEffectiveCapitalMode();
   if(mode == CAP_LOW)
      return 0.0;
   if(mode == CAP_MEDIAN)
      return 15.0;
   if(mode == CAP_HIGH)
      return 30.0;
   return InpRecoveryLotPct;
}

double QQSpreadCostTargetFloor(const double lot)
{
   double tickVal = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSz = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickVal <= 0.0 || tickSz <= 0.0 || lot <= 0.0)
      return InpMinBasketTarget;

   double spreadMoney = snap.spread * _Point / tickSz * tickVal * lot;
   double slipMoney = MathMax(1.0, InpSlippage * 0.10) * _Point / tickSz * tickVal * lot;
   double floorValue = spreadMoney * 1.50 + slipMoney;

   if(QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_MICRO)
      floorValue = MathMax(floorValue, AccountInfoDouble(ACCOUNT_BALANCE) * 0.25 / 100.0);

   return MathMax(InpMinBasketTarget, floorValue);
}

bool QQDynamicVelocityNewsBlocked()
{
   double m1AtrPts = SafePoints(tf[TF_M1].atr);
   bool spreadShock = (snap.spread > QQEffectiveSpreadCap() * 0.70 && snap.volVelocity > 1.35);
   bool candleShock = (m1AtrPts > 0.0 && snap.m1RangePoints > m1AtrPts * 2.80);
   bool velocityShock = (snap.volVelocity > 2.15 && tf[TF_M1].candleBodyPct > 62.0);

   if(spreadShock || candleShock || velocityShock)
   {
      QQSetBlockReason("Dynamic news/velocity guard");
      return true;
   }
   return false;
}

bool QQUsdCalendarWindowBlocked()
{
   if(QQUsdCalendarWindowRisk() >= 70.0)
   {
      QQSetBlockReason("USD high-impact calendar window");
      return true;
   }
   return false;
}

double QQUsdCalendarWindowRisk()
{
   datetime nowGmt = TimeGMT();
   MqlDateTime dt;
   TimeToStruct(nowGmt, dt);
   if(dt.day_of_week < 1 || dt.day_of_week > 5)
      return 0.0;

   int d1330 = QQMinuteDistanceUtc(nowGmt, 13, 30);
   int d1400 = QQMinuteDistanceUtc(nowGmt, 14, 0);
   int nearest = MathMin(d1330, d1400);
   int hardBuffer = MathMax(InpUsdNewsBufferBeforeMin, InpUsdNewsBufferAfterMin);
   int softBuffer = hardBuffer + 30;
   if(nearest <= hardBuffer)
      return 85.0;
   if(nearest <= softBuffer)
      return 45.0;
   return 0.0;
}

int QQMinuteDistanceUtc(const datetime t, const int hour, const int minute)
{
   MqlDateTime dt;
   TimeToStruct(t, dt);
   dt.hour = hour;
   dt.min = minute;
   dt.sec = 0;
   datetime eventTime = StructToTime(dt);
   return (int)MathAbs((double)(t - eventTime) / 60.0);
}

bool QQNewsGuardBlocked()
{
   if(InpUseDynamicNewsGuard == QQ_ON)
   {
      if(QQNewsRiskScore() >= 70.0)
      {
         QQSetBlockReason("Layered news risk guard");
         return true;
      }
   }

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   if(dt.day_of_week == 5 && dt.hour >= 20)
      return true;
   if(dt.hour == 21 || dt.hour == 22)
      return true;
   if((dt.hour == 12 || dt.hour == 13 || dt.hour == 14) && dt.min <= InpNewsGuardMinutes)
   {
      if(snap.volVelocity > 1.65 || tf[TF_M1].candleBodyPct > 72.0)
         return true;
   }
   return false;
}

double QQNewsRiskScore()
{
   if(InpUseNewsGuard == QQ_OFF && InpUseDynamicNewsGuard == QQ_OFF)
      return 0.0;

   double risk = 0.0;
   double m1AtrPts = SafePoints(tf[TF_M1].atr);
   if(snap.spread > QQEffectiveSpreadCap() * 0.70)
      risk += 18.0;
   if(snap.spread > QQEffectiveSpreadCap() * 0.90)
      risk += 18.0;
   if(snap.volVelocity > 1.45)
      risk += 18.0;
   if(snap.volVelocity > 2.15)
      risk += 22.0;
   if(m1AtrPts > 0.0 && snap.m1RangePoints > m1AtrPts * 2.35)
      risk += 22.0;
   if(tf[TF_M1].candleBodyPct > 68.0)
      risk += 12.0;
   risk += QQUsdCalendarWindowRisk();

   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   if(dt.day_of_week == 5 && dt.hour >= 20)
      risk += 35.0;
   if(dt.hour == 21 || dt.hour == 22)
      risk += 25.0;

   return MathMax(0.0, MathMin(100.0, risk));
}

bool QQTrendThesisAlive(const int dir)
{
   if(dir == 0 || snap.extremeBlocked)
      return false;
   if(snap.regime == REGIME_EXTREME_VOL || snap.regime == REGIME_BLOCKED)
      return false;
   if(dir == 1)
   {
      int confirming = 0;
      if(snap.macroBias >= 0) confirming++;
      if(tf[TF_M5].bias >= 0) confirming++;
      if(tf[TF_H1].bias >= 0) confirming++;
      return (confirming >= 2);
   }
   int bearConfirm = 0;
   if(snap.macroBias <= 0) bearConfirm++;
   if(tf[TF_M5].bias <= 0) bearConfirm++;
   if(!IsDangerousShortSetup()) bearConfirm++;
   return (bearConfirm >= 2);
}

bool QQGridCompressionGuard(const int level, const bool rescue)
{
   double spacing = CalculateGridSpacingPoints(level, rescue);
   double atrPts = SafePoints(tf[TF_M5].atr);
   if(spacing < MathMax(90.0, atrPts * 0.45))
   {
      QQSetBlockReason("Grid compression guard blocked level");
      return false;
   }
   if(QQProjectedDepositLoad(CalculateDynamicLot(level, rescue)) > g_capital.maxDepositLoad)
   {
      QQSetBlockReason("Grid projected deposit load too high");
      return false;
   }
   return true;
}

int QQCycleHealth(const double totalProfit)
{
   double dd = GetDrawdownPct();
   if(dd >= g_profile.maxEquityDDPct * 0.90 || totalProfit <= -g_capital.maxCycleLossBudget)
      return CYCLE_HEALTH_EMERGENCY;
   if(dd >= g_profile.maxEquityDDPct * 0.65 || totalProfit <= -g_capital.maxCycleLossBudget * 0.70)
      return CYCLE_HEALTH_DANGER;
   if(dd >= g_profile.maxEquityDDPct * 0.40 || totalProfit < 0.0)
      return CYCLE_HEALTH_PRESSED;
   return CYCLE_HEALTH_HEALTHY;
}

bool QQTrendInvalidationExit(const double totalProfit)
{
   if(!basket.active)
      return false;
   if(QQTrendThesisAlive(basket.direction))
      return false;
   double hardLossFloor = basket.basketTP * 0.65;
   if(totalProfit >= -MathMax(2.5, hardLossFloor))
      return true;
   if(basket.cycleHealth >= CYCLE_HEALTH_DANGER && CountMainPositions(0) <= 1)
      return true;
   return false;
}

double QQSwingStructureScore(const int idx)
{
   double h1 = iHigh(_Symbol, tf[idx].period, 1);
   double h2 = iHigh(_Symbol, tf[idx].period, 2);
   double l1 = iLow(_Symbol, tf[idx].period, 1);
   double l2 = iLow(_Symbol, tf[idx].period, 2);
   double c0 = iClose(_Symbol, tf[idx].period, 0);
   double score = 0.0;
   if(h1 > h2 && l1 > l2 && c0 > h2) score += 1.0;
   if(h1 < h2 && l1 < l2 && c0 < l2) score -= 1.0;
   if(tf[idx].adx > 22.0) score *= 1.25;
   return score;
}

double QQBrokerHealthScore()
{
   double score = 100.0;
   if(snap.spread > 0.0)
      score -= MathMax(0.0, snap.spread - g_profile.softSpreadCap) * 2.0;
   if(snap.spread > QQEffectiveSpreadCap() * 0.85)
      score -= 18.0;
   if(snap.volVelocity > 2.0 && snap.spread > QQEffectiveSpreadCap() * 0.60)
      score -= 15.0;
   if(g_env.leverage > 0 && g_env.leverage < 100)
      score -= 35.0;
   if(!g_isHedging)
      score -= 40.0;
   if(!TerminalInfoInteger(TERMINAL_CONNECTED))
      score -= 30.0;
   long freeze = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_FREEZE_LEVEL);
   long stops = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   if(freeze > 0) score -= MathMin(12.0, (double)freeze * 0.15);
   if(stops > 0) score -= MathMin(12.0, (double)stops * 0.12);
   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   if(g_capital.balance < 300.0 && minLot > 0.01)
      score -= 25.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQExecutionHealthScore()
{
   double score = 100.0;
   long freeze = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_FREEZE_LEVEL);
   long stops = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   if(freeze > 0) score -= MathMin(20.0, (double)freeze * 0.25);
   if(stops > 0) score -= MathMin(20.0, (double)stops * 0.20);
   if(snap.spread > QQEffectiveSpreadCap() * 0.80) score -= 25.0;
   if(GetMarginLevelPct() > 0.0 && GetMarginLevelPct() < InpMarginWarnPct) score -= 30.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQLongBiasScore()
{
   int buyVotes = 0;
   int sellVotes = 0;
   for(int i=0; i<TF_TOTAL; i++)
   {
      if(tf[i].bias > 0) buyVotes++;
      if(tf[i].bias < 0) sellVotes++;
   }
   double raw = 50.0 + (buyVotes - sellVotes) * 6.25;
   if(tf[TF_D1].bias > 0) raw += 8.0;
   if(tf[TF_H1].bias > 0) raw += 6.0;
   if(tf[TF_D1].bias < 0) raw -= 8.0;
   if(tf[TF_H1].bias < 0) raw -= 6.0;
   return MathMax(0.0, MathMin(100.0, raw));
}

bool QQIsPropFirmAccount()
{
   if(InpUsePropFirmGuard == QQ_OFF)
      return false;
   string s = AccountInfoString(ACCOUNT_COMPANY) + " " + AccountInfoString(ACCOUNT_SERVER);
   StringToUpper(s);
   if(StringFind(s, "FTMO") >= 0) return true;
   if(StringFind(s, "FUND") >= 0) return true;
   if(StringFind(s, "PROP") >= 0) return true;
   if(StringFind(s, "CHALLENGE") >= 0) return true;
   return false;
}

void QQRunCalibrationAudit()
{
   int count = MathMin(QQ_DIAGNOSTIC_RULES_MAX, MathMax(1, InpCalibrationRules));
   double score = 0.0;
   int evaluated = 0;
   for(int i=1; i<=count; i++)
   {
      score += QQCalibrationRuleValue(i);
      evaluated++;
   }
   g_diag.auditRulesEvaluated = evaluated;
   g_diag.calibrationScore = (evaluated > 0 ? score / evaluated * 100.0 : 0.0);
   g_diag.lastAuditTime = TimeCurrent();
   g_diag.lastAuditText = StringFormat("rules=%d score=%.1f longBias=%.1f broker=%.1f exec=%.1f matrix=%s", evaluated, g_diag.calibrationScore, g_diag.longBiasScore, g_diag.brokerHealthScore, g_diag.executionHealthScore, QQBacktestDiagnosticsText());
}

string QQBacktestDiagnosticsText()
{
   int candidates = 0;
   int blocked = 0;
   int entries = 0;
   int buys = 0;
   int sells = 0;
   for(int i=1; i<=STRATEGY_TOTAL; i++)
   {
      candidates += g_strategyAudit[i].candidateCount;
      blocked += g_strategyAudit[i].blockedCount;
      entries += g_strategyAudit[i].entryCount;
      if(g_strategyAudit[i].lastDirection > 0) buys++;
      if(g_strategyAudit[i].lastDirection < 0) sells++;
   }
   double days = 1.0;
   if(g_firstSeenTime > 0)
      days = MathMax(1.0 / 24.0, (double)(TimeCurrent() - g_firstSeenTime) / 86400.0);
   double tradesPerWeek = (days > 0.0 ? entries / days * 7.0 : 0.0);
   double longRatio = (buys + sells > 0 ? buys * 100.0 / (buys + sells) : 0.0);
   return StringFormat("phase=%s best=S%02d macro=%d setup=%d timing=%d score=%.1f news=%.1f c=%d b=%d tpw=%.1f long=%.1f",
                       g_matrix.phase, g_matrix.bestStrategy, g_matrix.macroDir, g_matrix.setupDir, g_matrix.timingDir,
                       g_matrix.entryScore, g_matrix.newsRiskScore, candidates, blocked, tradesPerWeek, longRatio);
}

double QQCalibrationRuleValue(const int ruleId)
{
   switch(ruleId)
   {
      case 1:
      {
         double v = 0.0;
         v += (tf[0].ready ? 0.35 : -0.25);
         v += (tf[0].bias == 1 ? 0.45 : -0.12);
         v += (QQStrategyEnabled(1) ? 0.30 : -0.10);
         v += (g_capital.capitalSurvivalScore / 100.0) * 0.64;
         v += (g_profile.longBiasTargetPct / 100.0) * 0.80;
         v -= (snap.spread / MathMax(1.0, (double)QQEffectiveSpreadCap())) * 0.18;
         v -= MathMax(0.0, GetDrawdownPct() - g_profile.maxEquityDDPct * 0.35) * 0.025;
         return v;
      }
      case 2:
      {
         double v = 0.0;
