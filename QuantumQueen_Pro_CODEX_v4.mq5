enum ENUM_QQ_SWITCH
{
   QQ_OFF = 0,
   QQ_ON  = 1
};

enum ENUM_QQ_LOT_METHOD
{
   LOT_DYNAMIC_CYCLE  = 0,
   LOT_FIXED          = 1,
   LOT_FIXED_BALANCE  = 2,
