string QQBuildOrderComment(const string phase, const int session, const int strategyId, const int level, const string reason)
{
   if(InpCommentMode == COMMENT_MODE_MINIMAL)
      return StringFormat("Q%d%02d%d", session, strategyId, level);
   if(InpCommentMode == COMMENT_MODE_NEUTRAL)
      return StringFormat("MS[%s/%d/%02d/%d]", phase, session, strategyId, level);
   return StringFormat("QQv6[%s/T%d/S%02d/L%d] %s", phase, session, strategyId, level, reason);
}

string QQSanitizeOrderComment(const string comment)
{
   string c = comment;
   if(StringLen(c) > 31)
      c = StringSubstr(c, 0, 31);
   return c;
}

void QQSetBlockReason(const string reason)
{
   if(reason == "")
      return;
   g_lastBlockReason = reason;
   g_diag.lastBlockReason = reason;
}

void QQNotify(const string title, const string body)
{
   if(InpUseNotifications == QQ_OFF)
      return;
   if(TimeCurrent() - g_lastNotifyTime < 20)
      return;
   string msg = StringFormat("%s | %s | %s", title, _Symbol, body);
   SendNotification(msg);
   g_lastNotifyTime = TimeCurrent();
   g_diag.sentNotifications++;
}

void QQLogEvent(const string eventType, const string message, const int dir, const double lot, const double profit)
{
   string row = StringFormat("%s,%s,%s,%d,%.2f,%.2f,%.2f,%.2f,%s,%s", TimeToString(TimeCurrent(), TIME_DATE|TIME_SECONDS), eventType, _Symbol, dir, lot, profit, GetDrawdownPct(), snap.spread, g_profile.name, message);
   Print(row);
   if(InpUseFileLogs == QQ_OFF)
      return;
   int h = FileOpen(QQ_LOG_FILE, FILE_READ|FILE_WRITE|FILE_CSV|FILE_ANSI);
   if(h == INVALID_HANDLE)
      return;
   FileSeek(h, 0, SEEK_END);
   FileWrite(h, TimeToString(TimeCurrent(), TIME_DATE|TIME_SECONDS), eventType, _Symbol, dir, lot, profit, GetDrawdownPct(), snap.spread, g_profile.name, message);
   FileClose(h);
   g_diag.logRows++;
}

void QQSavePersistentState(const string reason)
{
   if(InpUsePersistence == QQ_OFF)
      return;
   if(TimeCurrent() - g_lastPersistTime < 5 && reason == "timer")
      return;
   string key = QQPersistenceKey();
   GlobalVariableSet(key + "cycleId", (double)basket.cycleId);
   GlobalVariableSet(key + "active", basket.active ? 1.0 : 0.0);
   GlobalVariableSet(key + "direction", (double)basket.direction);
   GlobalVariableSet(key + "strategy", (double)basket.strategyId);
   GlobalVariableSet(key + "firstTime", (double)basket.firstTradeTime);
   GlobalVariableSet(key + "lastExit", (double)basket.lastExitTime);
   GlobalVariableSet(key + "baseLot", basket.baseLot);
   GlobalVariableSet(key + "target", basket.basketTP);
   GlobalVariableSet(key + "peak", basket.peakProfit);
   GlobalVariableSet(key + "lock", basket.lockProfit);
   GlobalVariableSet(key + "nextCycle", (double)g_nextCycleId);
   GlobalVariableSet(key + "tradesToday", (double)g_tradesToday);
   GlobalVariableSet(key + "dayStart", g_dayStartBalance);
   GlobalVariableSet(key + "weekStartTime", (double)g_diag.weekStartTime);
   GlobalVariableSet(key + "weekStartBalance", g_diag.weekStartBalance);
   g_lastPersistTime = TimeCurrent();
}

void QQRestorePersistentState()
{
   if(InpUsePersistence == QQ_OFF)
      return;
   string key = QQPersistenceKey();
   if(!GlobalVariableCheck(key + "nextCycle"))
      return;
   g_nextCycleId = (long)GlobalVariableGet(key + "nextCycle");
   g_tradesToday = (int)GlobalVariableGet(key + "tradesToday");
   g_dayStartBalance = GlobalVariableGet(key + "dayStart");
   g_diag.weekStartTime = (datetime)GlobalVariableGet(key + "weekStartTime");
   g_diag.weekStartBalance = GlobalVariableGet(key + "weekStartBalance");
   if(GlobalVariableGet(key + "active") > 0.5)
   {
      basket.cycleId = (long)GlobalVariableGet(key + "cycleId");
      basket.direction = (int)GlobalVariableGet(key + "direction");
      basket.strategyId = (int)GlobalVariableGet(key + "strategy");
      basket.firstTradeTime = (datetime)GlobalVariableGet(key + "firstTime");
      basket.lastExitTime = (datetime)GlobalVariableGet(key + "lastExit");
      basket.baseLot = GlobalVariableGet(key + "baseLot");
      basket.basketTP = GlobalVariableGet(key + "target");
      basket.peakProfit = GlobalVariableGet(key + "peak");
      basket.lockProfit = GlobalVariableGet(key + "lock");
   }
}

string QQPersistenceKey()
{
   return QQ_GLOBAL_PREFIX + IntegerToString(InpMagicNumber) + "_" + _Symbol + "_";
}

string QQAdvancedPanelText()
{
   string text = "";
   if(InpSimplePanel == QQ_ON)
   {
      double dayPnl = AccountInfoDouble(ACCOUNT_EQUITY) - g_dayStartBalance;
      text += StringFormat("\nMode: %s | Capital: %.2f | Day P/L: %.2f | DD: %.2f%%",
                           QQCapitalModeName(), AccountInfoDouble(ACCOUNT_EQUITY), dayPnl, GetDrawdownPct());
      text += StringFormat("\nCycle: %s | Profit: %.2f | Risk: %s",
                           (basket.active ? "ACTIVE" : "WAIT"),
                           (basket.active ? GetBasketProfit(InpMagicNumber, basket.direction) : 0.0),
                           g_lastBlockReason);
      return text;
   }

   text += StringFormat("\nProfile: %s | Tier: %s | Mode: %s | Health: %s", g_profile.name, g_capital.tierName, g_capital.tradeModeName, QQCycleHealthName(basket.cycleHealth));
   text += StringFormat("\nHiddenSpreadCap: %d | DepositLoad: %.1f/%.1f | Survival: %.1f | LotFeasible: %.1f", QQEffectiveSpreadCap(), g_capital.projectedDepositLoad, g_capital.maxDepositLoad, g_capital.capitalSurvivalScore, g_capital.lotStepFeasibility);
   text += StringFormat("\nEnv: %s | Broker: %.1f | Exec: %.1f | LongBias: %.1f target %.1f", (g_env.allOk ? "OK" : g_env.reason), g_diag.brokerHealthScore, g_diag.executionHealthScore, g_diag.longBiasScore, g_profile.longBiasTargetPct);
   text += StringFormat("\nCycle: #%I64d first=%.2f projectedDD=%.2f%% reason=%s", basket.cycleId, basket.firstPrice, basket.projectedDD, basket.entryReason);
   text += StringFormat("\nLast block: %s", g_lastBlockReason);
   if(InpUseCalibrationAudit == QQ_ON)
      text += StringFormat("\nCalibration: %s", g_diag.lastAuditText);
   return text;
}

string QQCapitalTierName(const ENUM_QQ_CAPITAL_TIER tier)
{
   switch(tier)
   {
      case TIER_NANO: return "NANO $12-$50";
      case TIER_MICRO: return "MICRO $50-$100";
      case TIER_SMALL: return "SMALL $100-$300";
      case TIER_LOW: return "LOW $300-$500";
      case TIER_STANDARD: return "STANDARD $500-$1000";
      case TIER_GROWTH: return "GROWTH $1000+";
   }
   return "UNKNOWN";
}

string QQTradeModeName(const ENUM_QQ_TRADE_MODE mode)
{
   switch(mode)
   {
      case TRADE_MODE_FULL: return "FULL";
      case TRADE_MODE_MICRO_SURVIVAL: return "MICRO_SURVIVAL";
      case TRADE_MODE_MONITOR_ONLY: return "MONITOR_ONLY";
      case TRADE_MODE_CENT_ACCOUNT_REQUIRED: return "CENT_ACCOUNT_REQUIRED";
      case TRADE_MODE_ENV_BLOCKED: return "ENV_BLOCKED";
   }
   return "UNKNOWN";
}

string QQCycleHealthName(const int h)
{
   if(h == CYCLE_HEALTH_HEALTHY) return "HEALTHY";
   if(h == CYCLE_HEALTH_PRESSED) return "PRESSED";
   if(h == CYCLE_HEALTH_DANGER) return "DANGER";
   if(h == CYCLE_HEALTH_EMERGENCY) return "EMERGENCY";
   return "NONE";
}

void QQDeleteRealPanel()
{
   for(int i=ObjectsTotal(0)-1; i>=0; i--)
   {
      string name = ObjectName(0, i);
      if(StringFind(name, QQ_PANEL_PREFIX) == 0)
         ObjectDelete(0, name);
   }
}

void QQPanelRect(const string id, const int x, const int y, const int w, const int h, const color bg, const color border)
{
   string name = QQ_PANEL_PREFIX + id;
   if(ObjectFind(0, name) < 0)
      ObjectCreate(0, name, OBJ_RECTANGLE_LABEL, 0, 0, 0);
   ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
   ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
   ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
   ObjectSetInteger(0, name, OBJPROP_XSIZE, w);
   ObjectSetInteger(0, name, OBJPROP_YSIZE, h);
   ObjectSetInteger(0, name, OBJPROP_BGCOLOR, bg);
   ObjectSetInteger(0, name, OBJPROP_COLOR, border);
   ObjectSetInteger(0, name, OBJPROP_BACK, false);
}

void QQPanelLabel(const string id, const string text, const int x, const int y, const int size, const color clr, const string font="Arial")
{
   string name = QQ_PANEL_PREFIX + id;
   if(ObjectFind(0, name) < 0)
      ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
   ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
   ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
   ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
   ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
   ObjectSetInteger(0, name, OBJPROP_FONTSIZE, size);
   ObjectSetString(0, name, OBJPROP_FONT, font);
   ObjectSetString(0, name, OBJPROP_TEXT, text);
}

void QQPanelButton(const string id, const string text, const int x, const int y, const int w, const int h)
{
   string name = QQ_PANEL_PREFIX + id;
   if(ObjectFind(0, name) < 0)
      ObjectCreate(0, name, OBJ_BUTTON, 0, 0, 0);
   ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
   ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
   ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
   ObjectSetInteger(0, name, OBJPROP_XSIZE, w);
   ObjectSetInteger(0, name, OBJPROP_YSIZE, h);
   ObjectSetInteger(0, name, OBJPROP_BGCOLOR, clrMidnightBlue);
   ObjectSetInteger(0, name, OBJPROP_COLOR, clrWhite);
   ObjectSetInteger(0, name, OBJPROP_BORDER_COLOR, clrWhite);
   ObjectSetInteger(0, name, OBJPROP_FONTSIZE, 8);
   ObjectSetString(0, name, OBJPROP_FONT, "Arial");
   ObjectSetString(0, name, OBJPROP_TEXT, text);
}

string QQRealSetName()
{
   if(InpSets == SET_RAW_LOW) return "IC Markets - RAW - LOW RISK";
   if(InpSets == SET_RAW_HIGH) return "IC Markets - RAW - HIGH RISK";
   if(InpSets == SET_ROBO_ECN) return "Roboforex - ECN";
   if(InpSets == SET_FUSION_ZERO) return "Fusion Markets - ZERO";
   return "IC Markets - RAW - MEDIUM RISK";
}

string QQStrategyPanelStatus(const int id)
{
   string status = g_strategyAudit[id].status;
   if(status == "")
      status = (QQStrategyEnabled(id) ? "ON | Awaiting signals ..." : "OFF | Awaiting signals ...");
   if(basket.active && basket.strategyId == id)
      status = "ON | Active cycle ...";
   return StringFormat("[Strategy %d]  %s", id, status);
}

void QQDrawRealPanel()
{
   int x = 4;
   int y = 4;
   int w = 640;
   int h = 462;
   color blue = (color)0x551B1B;

   QQPanelRect("bg", x, y, w, h, clrBlack, blue);
   QQPanelRect("titlebar", x, y, w, 20, blue, blue);
   QQPanelLabel("title", StringFormat("Quantum Queen MT5 v3.52 (17/03/2026) [%s]", _Symbol), x+2, y+2, 8, clrWhite);
   QQPanelLabel("min", "-", x+w-38, y+1, 10, clrWhite);
   QQPanelLabel("close", "x", x+w-18, y+2, 8, clrWhite);

   QQPanelButton("pause_btn", (g_emergencyPaused ? "RESUME EA" : "PAUSE EA"), x+2, y+25, 308, 18);
   QQPanelButton("close_btn", "CLOSE ALL TRADES", x+318, y+25, 312, 18);
   QQPanelRect("info_bar", x+2, y+49, w-12, 18, blue, clrWhite);
   QQPanelLabel("info", "INFORMATION", x+278, y+51, 8, clrWhite);

   double mainProfit = (basket.active ? GetBasketProfit(InpMagicNumber, basket.direction) : 0.0);
   double recProfit = (basket.active ? GetBasketProfit(g_recoveryMagic, -basket.direction) : 0.0);
   double totalProfit = mainProfit + recProfit;
   double marginPct = GetMarginLevelPct();
   double marginCurr = AccountInfoDouble(ACCOUNT_MARGIN);
   double totalVolume = GetBasketVolume(InpMagicNumber, 0) + GetBasketVolume(g_recoveryMagic, 0);

   int lx = x + 4;
   int ly = y + 80;
   int step = 15;
   QQPanelLabel("l1",  "Lot Calculation Method: Automatic", lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l2",  StringFormat("Auto Lots Risk Level: %s", QQCapitalModeName()), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l3",  StringFormat("Fixed: %.2f", InpLotsFixed), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l4",  StringFormat("Fixed per Balance: %.0f", InpLotsFixedBalance), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l5",  StringFormat("DD. Control Mode: %s", (InpDDMode == DD_OFF ? "OFF" : "ON")), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l6",  StringFormat("DD. Value: %.1f", QQEffectiveDDLimit()), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l7",  StringFormat("Magic Number: %d", InpMagicNumber), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l8",  StringFormat("Comment: %s", InpPanelComment), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l9",  StringFormat("MQID Push Notif. [DD/TP/SL]: %s", (InpUseNotifications == QQ_ON ? "ON" : "OFF")), lx, ly, 8, clrWhite); ly += step + 10;
   QQPanelLabel("l10", StringFormat("Set: %s", QQRealSetName()), lx, ly, 8, clrWhite); ly += step + 16;
   QQPanelLabel("l11", StringFormat("Total P/L: %.2f USD", totalProfit), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l12", StringFormat("Balance: %.2f USD", AccountInfoDouble(ACCOUNT_BALANCE)), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l13", StringFormat("Equity: %.2f USD", AccountInfoDouble(ACCOUNT_EQUITY)), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l14", StringFormat("Margin Curr.: %.0f %%", marginCurr), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l15", StringFormat("Margin Call: %.0f %%", marginPct > 0.0 ? marginPct : 40.0), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l16", StringFormat("Margin StopOut: %.0f %%", InpMarginStopPct > 0.0 ? 20.0 : 20.0), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l17", StringFormat("Total Volume: %.2f Lots", totalVolume), lx, ly, 8, clrWhite); ly += step + 15;
   QQPanelLabel("l18", StringFormat("Name: %s", AccountInfoString(ACCOUNT_NAME)), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l19", StringFormat("Broker: %s | %s", AccountInfoString(ACCOUNT_COMPANY), TimeToString(TimeCurrent(), TIME_SECONDS)), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l20", StringFormat("Account & Server: %I64d / %s", AccountInfoInteger(ACCOUNT_LOGIN), AccountInfoString(ACCOUNT_SERVER)), lx, ly, 8, clrWhite); ly += step;
   QQPanelLabel("l21", StringFormat("Leverage & Currency: %d:1 / %s", (int)AccountInfoInteger(ACCOUNT_LEVERAGE), AccountInfoString(ACCOUNT_CURRENCY)), lx, ly, 8, clrWhite);

   int rx = x + 318;
   int ry = y + 80;
   for(int i=1; i<=12; i++)
   {
      QQPanelLabel("s" + IntegerToString(i), QQStrategyPanelStatus(i), rx, ry, 8, clrWhite);
      ry += 31;
   }

   ChartRedraw(0);
}

//+------------------------------------------------------------------+
//| Panel                                                             |
//+------------------------------------------------------------------+
void UpdatePanel()
{
   if(InpShowPanel == QQ_OFF)
      return;

   QQDrawRealPanel();
   return;
}

string RegimeToString(const ENUM_MARKET_REGIME r)
{
   switch(r)
   {
      case REGIME_BLOCKED:     return "BLOCKED";
      case REGIME_RANGE:       return "RANGE";
      case REGIME_TREND:       return "TREND";
      case REGIME_HIGH_VOL:    return "HIGH_VOL";
      case REGIME_LOW_VOL:     return "LOW_VOL";
      case REGIME_EXTREME_VOL: return "EXTREME_VOL";
      case REGIME_TRANSITION:  return "TRANSITION";
   }
   return "UNKNOWN";
}
