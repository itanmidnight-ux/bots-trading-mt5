         v += (QQVolatilityTimeSweetSpotScore() / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1485:
      {
         double v = 0.50;
         v += (basket.lossStreak == 0 ? 0.10 : -0.12);
         v += (g_tradesToday < QQEffectiveMaxCyclesPerDay() ? 0.10 : -0.20);
         v += (QQCycleMemoryScore() / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1486:
      {
         double v = 0.50;
         v += (g_matrix.timingDir != 0 ? 0.10 : -0.06);
         v += (tf[TF_M1].candleBodyPct < 82.0 ? 0.08 : -0.12);
         v += (QQEntryPrecisionScore() / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1487:
      {
         double v = 0.50;
         v += (g_profile.preferLongs && g_matrix.macroDir == 1 ? 0.10 : 0.0);
         v += (g_matrix.macroDir == -1 && !IsDangerousShortSetup() ? 0.08 : -0.02);
         v += (QQDirectionQualityScore(g_matrix.macroDir) / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1488:
      {
         double v = 0.50;
         v += (g_opt.edgeQualityScore >= g_tune.minEdgeScore ? 0.16 : -0.16);
         v += (g_pro.professionalReadiness >= g_tune.minReadiness ? 0.10 : -0.10);
         v += (QQExpectedValueScore() / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1489:
      {
         double v = 0.50;
         v += (tf[0].bias == g_matrix.macroDir && g_matrix.macroDir != 0 ? 0.16 : -0.06);
         v += (tf[0].adx > 18.0 ? 0.08 : -0.03);
         v += (g_opt.mtfConsensusScore / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1490:
      {
         double v = 0.50;
         v += (QQNewsRiskScore() <= g_tune.maxNewsRisk ? 0.16 : -0.20);
         v += (g_pro.timeHealthScore > 55.0 ? 0.08 : -0.10);
         v += (g_opt.volatilityTimeScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1491:
      {
         double v = 0.50;
         v += (snap.spread <= QQEffectiveSpreadCap() * 0.60 ? 0.15 : -0.16);
         v += (g_pro.liquidityScore / 100.0) * 0.12;
         v += (g_diag.executionHealthScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1492:
      {
         double v = 0.50;
         v += (QQStrategyEnabled(4) ? 0.12 : -0.10);
         v += (g_strategyAudit[4].lastScore >= QQMatrixMinScore(4) ? 0.12 : -0.03);
         v += (QQStrategyWinRate(4) >= 62.0 || g_strategyPerf[4].entries < 3 ? 0.10 : -0.10);
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1493:
      {
         double v = 0.50;
         v += (g_capital.projectedDepositLoad <= g_capital.maxDepositLoad * 0.62 ? 0.16 : -0.18);
         v += (QQLossAvoidanceScore() / 100.0) * 0.14;
         v -= GetDrawdownPct() * 0.008;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1494:
      {
         double v = 0.50;
         v += (snap.regime == REGIME_TREND ? 0.16 : (snap.regime == REGIME_TRANSITION ? 0.06 : -0.04));
         v += (g_matrix.macroDir == g_matrix.setupDir && g_matrix.macroDir != 0 ? 0.12 : -0.04);
         v += (QQEntryPrecisionScore() / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1495:
      {
         double v = 0.50;
         v += (g_capital.canTradeMinLot ? 0.13 : -0.28);
         v += (g_capital.tier <= TIER_SMALL ? QQLossAvoidanceScore() : QQExpectedValueScore()) / 100.0 * 0.12;
         v += (g_pro.brokerMicroScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1496:
      {
         double v = 0.50;
         v += (tf[7].atrSlope > -0.10 && tf[7].atrSlope < 0.65 ? 0.10 : -0.06);
         v += (tf[7].bbWidthPct > 0.02 ? 0.06 : -0.04);
         v += (QQVolatilityTimeSweetSpotScore() / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1497:
      {
         double v = 0.50;
         v += (basket.lossStreak == 0 ? 0.10 : -0.12);
         v += (g_tradesToday < QQEffectiveMaxCyclesPerDay() ? 0.10 : -0.20);
         v += (QQCycleMemoryScore() / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1498:
      {
         double v = 0.50;
         v += (g_matrix.timingDir != 0 ? 0.10 : -0.06);
         v += (tf[TF_M1].candleBodyPct < 82.0 ? 0.08 : -0.12);
         v += (QQEntryPrecisionScore() / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1499:
      {
         double v = 0.50;
         v += (g_profile.preferLongs && g_matrix.macroDir == 1 ? 0.10 : 0.0);
         v += (g_matrix.macroDir == -1 && !IsDangerousShortSetup() ? 0.08 : -0.02);
         v += (QQDirectionQualityScore(g_matrix.macroDir) / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1500:
      {
         double v = 0.50;
         v += (g_opt.edgeQualityScore >= g_tune.minEdgeScore ? 0.16 : -0.16);
         v += (g_pro.professionalReadiness >= g_tune.minReadiness ? 0.10 : -0.10);
         v += (QQExpectedValueScore() / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
   }
   return 0.50;
}

