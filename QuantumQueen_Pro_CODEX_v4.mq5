      case 1180:
      {
         double v = 0.50;
         v += (g_capital.canTradeMinLot ? 0.14 : -0.30);
         v += (g_capital.tier >= TIER_STANDARD || QQEffectiveCapitalMode() != CAP_LOW ? 0.08 : -0.02);
         v += (g_capital.capitalSurvivalScore / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1181:
      {
         double v = 0.50;
         v += (tf[4].ready ? 0.18 : -0.35);
         v += (tf[4].bias == g_matrix.macroDir && g_matrix.macroDir != 0 ? 0.17 : -0.06);
         v += (g_pro.timeHealthScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1182:
      {
         double v = 0.50;
         v += (QQStrategyEnabled(6) ? 0.16 : -0.18);
         v += (g_strategyAudit[6].lastScore > 0.0 ? MathMin(0.16, g_strategyAudit[6].lastScore / 60.0) : -0.04);
         v += (g_pro.noTradePatienceScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1183:
      {
         double v = 0.50;
         v += (snap.spread <= QQEffectiveSpreadCap() * 0.55 ? 0.18 : -0.18);
         v += (snap.volVelocity >= 0.65 && snap.volVelocity <= 1.90 ? 0.14 : -0.08);
         v += (g_pro.liquidityScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1184:
      {
         double v = 0.50;
         v += (g_capital.projectedDepositLoad <= g_capital.maxDepositLoad * 0.65 ? 0.18 : -0.20);
         v += (GetDrawdownPct() <= QQEffectiveDDLimit() * 0.35 ? 0.14 : -0.18);
         v += (g_pro.adaptiveExposureScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1185:
      {
         double v = 0.50;
         v += (snap.regime == REGIME_TREND ? 0.18 : (snap.regime == REGIME_TRANSITION ? 0.04 : -0.10));
         v += (g_matrix.macroDir == g_matrix.setupDir && g_matrix.macroDir != 0 ? 0.16 : -0.06);
         v += (g_pro.volatilityBalanceScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1186:
      {
         double v = 0.50;
         v += (QQNewsRiskScore() < 35.0 ? 0.18 : -0.22);
         v += (g_pro.timeHealthScore > 55.0 ? 0.10 : -0.12);
         v += (g_pro.sessionQualityScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1187:
      {
         double v = 0.50;
         v += (tf[2].adx > 18.0 ? 0.10 : -0.04);
         v += (tf[2].atrSlope > -0.12 ? 0.10 : -0.08);
         v += (g_diag.executionHealthScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1188:
      {
         double v = 0.50;
         v += (g_isHedging ? 0.10 : -0.20);
         v += (g_env.tradingAllowed ? 0.12 : -0.35);
         v += (g_pro.brokerMicroScore / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1189:
      {
         double v = 0.50;
         v += (QQStrategyWinRate(1) >= 60.0 || g_strategyPerf[1].entries < 3 ? 0.10 : -0.12);
         v += (QQStrategyProfitFactor(1) >= 1.20 || g_strategyPerf[1].entries < 3 ? 0.10 : -0.10);
         v += (g_pro.cycleMemoryScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1190:
      {
         double v = 0.50;
         v += (g_capital.canTradeMinLot ? 0.14 : -0.30);
         v += (g_capital.tier >= TIER_STANDARD || QQEffectiveCapitalMode() != CAP_LOW ? 0.08 : -0.02);
         v += (g_capital.capitalSurvivalScore / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1191:
      {
         double v = 0.50;
         v += (tf[6].ready ? 0.18 : -0.35);
         v += (tf[6].bias == g_matrix.macroDir && g_matrix.macroDir != 0 ? 0.17 : -0.06);
         v += (g_pro.timeHealthScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1192:
      {
         double v = 0.50;
         v += (QQStrategyEnabled(4) ? 0.16 : -0.18);
         v += (g_strategyAudit[4].lastScore > 0.0 ? MathMin(0.16, g_strategyAudit[4].lastScore / 60.0) : -0.04);
         v += (g_pro.noTradePatienceScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1193:
      {
         double v = 0.50;
         v += (snap.spread <= QQEffectiveSpreadCap() * 0.55 ? 0.18 : -0.18);
         v += (snap.volVelocity >= 0.65 && snap.volVelocity <= 1.90 ? 0.14 : -0.08);
         v += (g_pro.liquidityScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1194:
      {
         double v = 0.50;
         v += (g_capital.projectedDepositLoad <= g_capital.maxDepositLoad * 0.65 ? 0.18 : -0.20);
         v += (GetDrawdownPct() <= QQEffectiveDDLimit() * 0.35 ? 0.14 : -0.18);
         v += (g_pro.adaptiveExposureScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1195:
      {
         double v = 0.50;
         v += (snap.regime == REGIME_TREND ? 0.18 : (snap.regime == REGIME_TRANSITION ? 0.04 : -0.10));
         v += (g_matrix.macroDir == g_matrix.setupDir && g_matrix.macroDir != 0 ? 0.16 : -0.06);
         v += (g_pro.volatilityBalanceScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1196:
      {
         double v = 0.50;
         v += (QQNewsRiskScore() < 35.0 ? 0.18 : -0.22);
         v += (g_pro.timeHealthScore > 55.0 ? 0.10 : -0.12);
         v += (g_pro.sessionQualityScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1197:
      {
         double v = 0.50;
         v += (tf[4].adx > 18.0 ? 0.10 : -0.04);
         v += (tf[4].atrSlope > -0.12 ? 0.10 : -0.08);
         v += (g_diag.executionHealthScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1198:
      {
         double v = 0.50;
         v += (g_isHedging ? 0.10 : -0.20);
         v += (g_env.tradingAllowed ? 0.12 : -0.35);
         v += (g_pro.brokerMicroScore / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1199:
      {
         double v = 0.50;
         v += (QQStrategyWinRate(11) >= 60.0 || g_strategyPerf[11].entries < 3 ? 0.10 : -0.12);
         v += (QQStrategyProfitFactor(11) >= 1.20 || g_strategyPerf[11].entries < 3 ? 0.10 : -0.10);
         v += (g_pro.cycleMemoryScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 1200:
      {
         double v = 0.50;
         v += (g_capital.canTradeMinLot ? 0.14 : -0.30);
         v += (g_capital.tier >= TIER_STANDARD || QQEffectiveCapitalMode() != CAP_LOW ? 0.08 : -0.02);
         v += (g_capital.capitalSurvivalScore / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
   }
   return 0.50;
}

