double QQIndicatorEnsembleScore(const int strategyId, const int dir)
{
   QQBuildSessionLevels();
   g_ens.lastRefresh = TimeCurrent();
   g_ens.rsiScore = QQRSIEnsembleScore(dir);
   g_ens.emaScore = QQEMAEnsembleScore(dir);
   g_ens.macdScore = QQMACDEnsembleScore(dir);
   g_ens.adxScore = QQADXEnsembleScore(dir);
   g_ens.atrScore = QQATREnsembleScore();
   g_ens.bandScore = QQBandEnsembleScore(strategyId, dir);
   g_ens.stochScore = QQStochEnsembleScore(dir);
   g_ens.candleScore = (IsCandleConfirming(dir) ? 100.0 : 0.0);
   g_ens.divergenceScore = QQDivergenceEnsembleScore(strategyId, dir);
   g_ens.levelScore = QQKeyLevelScore(dir);
   g_ens.totalScore = g_ens.rsiScore * 0.12 + g_ens.emaScore * 0.18 + g_ens.macdScore * 0.13 +
                      g_ens.adxScore * 0.12 + g_ens.atrScore * 0.10 + g_ens.bandScore * 0.10 +
                      g_ens.stochScore * 0.07 + g_ens.candleScore * 0.08 + g_ens.divergenceScore * 0.05 +
                      g_ens.levelScore * 0.05;
   g_ens.lastReport = StringFormat("ens=%.1f rsi=%.1f ema=%.1f macd=%.1f adx=%.1f atr=%.1f band=%.1f candle=%.1f level=%.1f",
                                   g_ens.totalScore, g_ens.rsiScore, g_ens.emaScore, g_ens.macdScore,
                                   g_ens.adxScore, g_ens.atrScore, g_ens.bandScore, g_ens.candleScore, g_ens.levelScore);
   return MathMax(0.0, MathMin(100.0, g_ens.totalScore));
}

bool QQIndicatorEnsembleAllowsEntry(const int strategyId, const int dir, const double score)
{
   double minScore = QQEnsembleMinScore();
   if(strategyId == 11) minScore -= 3.0;
   if(strategyId == 4 || strategyId == 5) minScore += 2.0;
   if(score < minScore)
   {
      g_ens.lastBlock = StringFormat("S%02d ensemble %.1f < %.1f", strategyId, score, minScore);
      return false;
   }
   if(IsAgainstKeyLevel(dir))
   {
      g_ens.lastBlock = "Key level guard";
      return false;
   }
   return true;
}

double QQEnsembleMinScore()
{
   if(QQEffectiveCapitalMode() == CAP_LOW || g_capital.tier <= TIER_SMALL)
      return InpLowCapitalMinEnsembleScore;
   if(QQEffectiveCapitalMode() == CAP_MEDIAN || g_capital.tier <= TIER_STANDARD)
      return InpMedianCapitalMinEnsembleScore;
   return InpHighCapitalMinEnsembleScore;
}

double QQEnsembleBoost(const double score)
{
   if(score >= 90.0) return 1.20;
   if(score >= 82.0) return 0.80;
   if(score >= 74.0) return 0.45;
   return 0.0;
}

double QQRSIEnsembleScore(const int dir)
{
   double score = 50.0;
   if(dir == 1)
   {
      if(tf[TF_M5].rsi > 52.0 && tf[TF_M5].rsi < 72.0) score += 22.0;
      if(tf[TF_M15].rsi > 50.0 && tf[TF_M15].rsi < 74.0) score += 18.0;
      if(tf[TF_H1].rsi >= 48.0) score += 10.0;
   }
   else if(dir == -1)
   {
      if(tf[TF_M5].rsi < 48.0 && tf[TF_M5].rsi > 28.0) score += 22.0;
      if(tf[TF_M15].rsi < 50.0 && tf[TF_M15].rsi > 26.0) score += 18.0;
      if(tf[TF_H1].rsi <= 52.0) score += 10.0;
   }
   return MathMax(0.0, MathMin(100.0, score));
}

double QQEMAEnsembleScore(const int dir)
{
   double score = 40.0;
   int votes = 0;
   if(tf[TF_M5].bias == dir) votes++;
   if(tf[TF_M12].bias == dir) votes++;
   if(tf[TF_M15].bias == dir) votes++;
   if(tf[TF_M20].bias == dir) votes++;
   if(tf[TF_H1].bias == dir) votes++;
   score += votes * 10.0;
   if(dir == 1 && tf[TF_H1].close0 > tf[TF_H1].emaTrend) score += 10.0;
   if(dir == -1 && tf[TF_H1].close0 < tf[TF_H1].emaTrend) score += 10.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQMACDEnsembleScore(const int dir)
{
   int votes = 0;
   if((dir == 1 && tf[TF_M5].macdMain > tf[TF_M5].macdSignal) || (dir == -1 && tf[TF_M5].macdMain < tf[TF_M5].macdSignal)) votes++;
   if((dir == 1 && tf[TF_M15].macdMain > tf[TF_M15].macdSignal) || (dir == -1 && tf[TF_M15].macdMain < tf[TF_M15].macdSignal)) votes++;
   if((dir == 1 && tf[TF_M20].macdMain > tf[TF_M20].macdSignal) || (dir == -1 && tf[TF_M20].macdMain < tf[TF_M20].macdSignal)) votes++;
   if((dir == 1 && tf[TF_H1].macdMain > tf[TF_H1].macdSignal) || (dir == -1 && tf[TF_H1].macdMain < tf[TF_H1].macdSignal)) votes++;
   return MathMin(100.0, 35.0 + votes * 16.0);
}

double QQADXEnsembleScore(const int dir)
{
   double score = 45.0;
   if(tf[TF_M15].adx > 18.0) score += 15.0;
   if(tf[TF_H1].adx > 20.0) score += 18.0;
   if(tf[TF_M5].adx > 18.0) score += 10.0;
   if(snap.regime == REGIME_TREND && g_matrix.macroDir == dir) score += 12.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQATREnsembleScore()
{
   double score = 55.0;
   if(snap.m5AtrPoints >= InpMinATRPointsM5) score += 18.0;
   if(snap.volVelocity >= 0.70 && snap.volVelocity <= 1.85) score += 18.0;
   if(snap.volVelocity > 2.35) score -= 30.0;
   if(snap.extremeBlocked) score -= 45.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQBandEnsembleScore(const int strategyId, const int dir)
{
   double score = 55.0;
   if(strategyId == 3)
   {
      if(dir == 1 && tf[TF_M5].close0 <= tf[TF_M5].bbLower) score += 28.0;
      if(dir == -1 && tf[TF_M5].close0 >= tf[TF_M5].bbUpper) score += 28.0;
   }
   else
   {
      if(dir == 1 && tf[TF_M5].close0 > tf[TF_M5].bbMiddle) score += 16.0;
      if(dir == -1 && tf[TF_M5].close0 < tf[TF_M5].bbMiddle) score += 16.0;
      if(snap.bbWidthM20 > 0.0 && snap.bbWidthM20 < 0.0060) score += 10.0;
   }
   return MathMax(0.0, MathMin(100.0, score));
}

double QQStochEnsembleScore(const int dir)
{
   double score = 55.0;
   if(dir == 1 && tf[TF_M1].stochMain > tf[TF_M1].stochSignal) score += 22.0;
   if(dir == -1 && tf[TF_M1].stochMain < tf[TF_M1].stochSignal) score += 22.0;
   if(tf[TF_M1].stochMain > 15.0 && tf[TF_M1].stochMain < 85.0) score += 8.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQDivergenceEnsembleScore(const int strategyId, const int dir)
{
   bool bull = HasBullishDivergence(TF_M5, 5) || HasBullishDivergence(TF_M15, 5);
   bool bear = HasBearishDivergence(TF_M5, 5) || HasBearishDivergence(TF_M15, 5);
   double score = 60.0;
   if(dir == 1 && bull) score += 28.0;
   if(dir == -1 && bear) score += 28.0;
   if((strategyId == 2 || strategyId == 3) && ((dir == 1 && bull) || (dir == -1 && bear))) score += 10.0;
   return MathMax(0.0, MathMin(100.0, score));
}

void QQBuildSessionLevels()
{
   if(InpUseAsiaSessionLevels == QQ_OFF)
      return;
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   dt.hour = 0; dt.min = 0; dt.sec = 0;
   datetime dayStart = StructToTime(dt);
   double high = 0.0;
   double low = DBL_MAX;
   for(int i=0; i<420; i++)
   {
      int bar = iBarShift(_Symbol, PERIOD_M1, dayStart + i * 60, false);
      if(bar < 0) continue;
      double h = iHigh(_Symbol, PERIOD_M1, bar);
      double l = iLow(_Symbol, PERIOD_M1, bar);
      if(h > high) high = h;
      if(l < low) low = l;
   }
   if(high > 0.0 && low < DBL_MAX)
   {
      g_ens.asiaHigh = high;
      g_ens.asiaLow = low;
   }
}

double QQKeyLevelScore(const int dir)
{
   if(InpUseAsiaSessionLevels == QQ_OFF || g_ens.asiaHigh <= 0.0 || g_ens.asiaLow <= 0.0)
      return 70.0;
   if(IsAgainstKeyLevel(dir))
      return 25.0;
   double price = (dir == 1 ? snap.ask : snap.bid);
   double range = MathMax(g_ens.asiaHigh - g_ens.asiaLow, _Point);
   if(price > g_ens.asiaHigh && dir == 1) return 88.0;
   if(price < g_ens.asiaLow && dir == -1) return 88.0;
   if(price > g_ens.asiaLow && price < g_ens.asiaHigh) return 65.0;
   return 72.0;
}

bool IsAgainstKeyLevel(const int dir)
{
   if(InpUseAsiaSessionLevels == QQ_OFF || g_ens.asiaHigh <= 0.0 || g_ens.asiaLow <= 0.0)
      return false;
   double price = (dir == 1 ? snap.ask : snap.bid);
   double buffer = MathMax(tf[TF_M5].atr * InpKeyLevelATRBuffer, 80.0 * _Point);
   if(dir == 1 && MathAbs(price - g_ens.asiaHigh) < buffer && price < g_ens.asiaHigh)
      return true;
   if(dir == -1 && MathAbs(price - g_ens.asiaLow) < buffer && price > g_ens.asiaLow)
      return true;
   return false;
}

//+------------------------------------------------------------------+
//| Professional support, simulation and monitoring suite             |
//+------------------------------------------------------------------+
void QQProfessionalSuiteInitialize()
{
   g_pro.lastRefresh = 0;
   g_pro.lastSimulation = 0;
   g_pro.timeHealthScore = 100.0;
   g_pro.sessionQualityScore = 100.0;
   g_pro.brokerMicroScore = 100.0;
   g_pro.adaptiveExposureScore = 100.0;
   g_pro.simulationScore = 100.0;
   g_pro.professionalReadiness = 100.0;
   g_pro.noTradePatienceScore = 100.0;
   g_pro.liquidityScore = 100.0;
   g_pro.volatilityBalanceScore = 100.0;
   g_pro.cycleMemoryScore = 100.0;
   g_pro.lastSimulationText = "Professional suite boot";
   g_pro.lastProfessionalBlock = "";
   g_pro.lastSupportReport = "";
   for(int i=0; i<=STRATEGY_TOTAL; i++)
   {
      g_strategyPerf[i].entries = 0;
      g_strategyPerf[i].wins = 0;
      g_strategyPerf[i].losses = 0;
      g_strategyPerf[i].blocks = 0;
      g_strategyPerf[i].grossProfit = 0.0;
      g_strategyPerf[i].grossLoss = 0.0;
      g_strategyPerf[i].bestProfit = 0.0;
      g_strategyPerf[i].worstProfit = 0.0;
      g_strategyPerf[i].averageHoldMinutes = 0.0;
      g_strategyPerf[i].lastOutcome = "none";
   }
}

void QQProfessionalSuiteRefresh()
{
   if(InpUseProfessionalSuite == QQ_OFF)
      return;
   g_pro.lastRefresh = TimeCurrent();
   g_pro.timeHealthScore = QQTimeHealthScore();
   g_pro.sessionQualityScore = QQSessionQualityScore();
   g_pro.brokerMicroScore = QQBrokerMicroScore();
   g_pro.adaptiveExposureScore = QQAdaptiveExposureScore();
   g_pro.noTradePatienceScore = QQNoTradePatienceScore();
   g_pro.liquidityScore = QQLiquidityScore();
   g_pro.volatilityBalanceScore = QQVolatilityBalanceScore();
   g_pro.cycleMemoryScore = QQCycleMemoryScore();
   if(InpUseInternalSimulation == QQ_ON && (TimeCurrent() - g_pro.lastSimulation > 60 || g_pro.lastSimulation <= 0))
      QQRunInternalSimulation();
   g_pro.professionalReadiness = QQProfessionalReadinessScore();
   g_pro.lastSupportReport = QQProfessionalSupportReport();
}

bool QQProfessionalSuiteAllowsNewCycle()
{
   if(InpUseProfessionalSuite == QQ_OFF)
      return true;
   double minReady = (InpUseCapitalAutoTune == QQ_ON ? g_tune.minReadiness : (g_capital.tier <= TIER_SMALL || QQEffectiveCapitalMode() == CAP_LOW ? InpMicroMinProfessionalReadiness : InpMinProfessionalReadiness));
   if(InpUseTimeHealthGuard == QQ_ON && g_pro.timeHealthScore < InpMinTimeHealthScore)
   {
      g_pro.hardBlocks++;
      g_pro.lastProfessionalBlock = "Professional time health guard";
      QQSetBlockReason(g_pro.lastProfessionalBlock);
      return false;
   }
   if(InpUseSessionQualityGuard == QQ_ON && g_pro.sessionQualityScore < InpMinSessionQualityScore)
   {
      g_pro.softBlocks++;
      g_pro.lastProfessionalBlock = "Professional session quality guard";
      QQSetBlockReason(g_pro.lastProfessionalBlock);
      return false;
   }
   if(InpUseAdaptiveExposureGuard == QQ_ON && g_pro.adaptiveExposureScore < 45.0)
   {
      g_pro.hardBlocks++;
      g_pro.lastProfessionalBlock = "Professional exposure guard";
      QQSetBlockReason(g_pro.lastProfessionalBlock);
      return false;
   }
   if(InpUseProfitabilityOptimizer == QQ_ON && QQNewsRiskScore() > g_tune.maxNewsRisk)
   {
      g_pro.hardBlocks++;
      g_pro.lastProfessionalBlock = "Optimizer news risk block";
      QQSetBlockReason(g_pro.lastProfessionalBlock);
      return false;
   }
   if(g_pro.professionalReadiness < minReady)
   {
      g_pro.softBlocks++;
      g_pro.lastProfessionalBlock = "Professional readiness below tier threshold";
      QQSetBlockReason(g_pro.lastProfessionalBlock);
      if(g_opt.expectedValueScore < 70.0 || g_opt.edgeQualityScore < 70.0)
         return false;
   }
   return true;
}

double QQTimeHealthScore()
{
   MqlDateTime dt;
   TimeToStruct(TimeCurrent(), dt);
   double score = 100.0;
   if(dt.day_of_week == 0 || dt.day_of_week == 6) score -= 80.0;
   if(dt.day_of_week == 5 && dt.hour >= 18) score -= 35.0;
   if(dt.hour == 21 || dt.hour == 22) score -= 28.0;
   if(dt.hour >= 0 && dt.hour <= 1 && snap.spread > QQEffectiveSpreadCap() * 0.55) score -= 14.0;
   if(QQUsdCalendarWindowRisk() > 0.0) score -= QQUsdCalendarWindowRisk() * 0.45;
   if(snap.session == 0) score -= 20.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQSessionQualityScore()
{
   double score = 55.0;
   if(snap.session > 0) score += 20.0;
   if(InpTradeLondon == QQ_ON && snap.session == 2) score += 10.0;
   if(InpTradeNewYork == QQ_ON && snap.session == 3) score += 10.0;
   if(snap.spread < QQEffectiveSpreadCap() * 0.45) score += 8.0;
   if(snap.volVelocity > 0.70 && snap.volVelocity < 1.85) score += 8.0;
   if(snap.regime == REGIME_LOW_VOL) score -= 18.0;
   if(snap.regime == REGIME_EXTREME_VOL) score -= 42.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQBrokerMicroScore()
{
   double score = QQBrokerHealthScore();
   if(g_capital.balance <= 200.0)
   {
      if(g_capital.minLot <= 0.01) score += 10.0; else score -= 30.0;
      if(g_capital.canTradeMinLot) score += 8.0; else score -= 35.0;
      if(g_capital.projectedDepositLoad > g_capital.maxDepositLoad * 0.75) score -= 22.0;
   }
   return MathMax(0.0, MathMin(100.0, score));
}

double QQAdaptiveExposureScore()
{
   double score = 100.0;
   double loadRatio = (g_capital.maxDepositLoad > 0.0 ? g_capital.projectedDepositLoad / g_capital.maxDepositLoad : 1.0);
   score -= MathMax(0.0, loadRatio - 0.45) * 90.0;
   score -= GetDrawdownPct() * 2.2;
   if(basket.lossStreak > 0) score -= MathMin(28.0, basket.lossStreak * 7.0);
   if(g_tradesToday >= QQEffectiveMaxCyclesPerDay()) score -= 45.0;
   if(g_capital.tier <= TIER_SMALL && CountMainPositions(0) > 0) score -= 20.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQNoTradePatienceScore()
{
   double score = 100.0;
   if(g_matrix.entryScore > 0.0 && g_matrix.entryScore < 7.0) score -= 18.0;
   if(g_matrix.macroDir == 0) score -= 12.0;
   if(g_matrix.setupDir == 0) score -= 12.0;
   if(g_matrix.timingDir == 0 && g_capital.tier <= TIER_SMALL) score -= 12.0;
   if(snap.regime == REGIME_TRANSITION) score -= 7.0;
   if(snap.regime == REGIME_TREND && g_matrix.macroDir == g_matrix.setupDir && g_matrix.setupDir == g_matrix.timingDir) score += 8.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQLiquidityScore()
{
   double score = 100.0;
   score -= MathMax(0.0, snap.spread - g_profile.softSpreadCap) * 2.4;
   if(snap.session == 0) score -= 22.0;
   if(snap.volVelocity < 0.50) score -= 15.0;
   if(snap.volVelocity > 2.40) score -= 20.0;
   if(QQNewsRiskScore() > 45.0) score -= 20.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQVolatilityBalanceScore()
{
   double score = 70.0;
   if(snap.m5AtrPoints >= InpMinATRPointsM5) score += 12.0; else score -= 20.0;
   if(snap.volVelocity >= 0.70 && snap.volVelocity <= 1.80) score += 14.0;
   if(snap.volVelocity > 2.20) score -= 24.0;
   if(tf[TF_M20].bbWidthPct > 0.05 && tf[TF_M20].bbWidthPct < 0.55) score += 8.0;
   if(snap.extremeBlocked) score -= 50.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQCycleMemoryScore()
{
   double score = 100.0;
   if(basket.lastCycleProfit < 0.0) score -= 18.0;
   if(basket.lossStreak > 0) score -= MathMin(35.0, basket.lossStreak * 9.0);
   if(basket.lastExitTime > 0 && TimeCurrent() - basket.lastExitTime < InpMinMinutesBetweenCycles * 60) score -= 25.0;
   if(g_tradesToday == 0 && snap.regime == REGIME_TREND) score += 5.0;
   return MathMax(0.0, MathMin(100.0, score));
}

double QQProfessionalReadinessScore()
{
   double score = 0.0;
   score += g_pro.timeHealthScore * 0.12;
   score += g_pro.sessionQualityScore * 0.12;
   score += g_pro.brokerMicroScore * 0.14;
   score += g_pro.adaptiveExposureScore * 0.16;
   score += g_pro.simulationScore * 0.16;
   score += g_pro.noTradePatienceScore * 0.10;
   score += g_pro.liquidityScore * 0.10;
   score += g_pro.volatilityBalanceScore * 0.06;
   score += g_pro.cycleMemoryScore * 0.04;
   return MathMax(0.0, MathMin(100.0, score));
}

void QQRunInternalSimulation()
{
   int count = MathMin(QQ_SIMULATION_RULES_MAX, MathMax(1, InpSimulationRules));
   double total = 0.0;
   int warnings = 0;
   int blocks = 0;
   for(int i=1; i<=count; i++)
   {
      double v = QQSimulationRuleValue(i);
      total += v;
      if(v < 0.45) warnings++;
      if(v < 0.20) blocks++;
   }
   g_pro.simulationRulesEvaluated = count;
   g_pro.simulationWarnings = warnings;
   g_pro.simulationBlocks = blocks;
   g_pro.simulationScore = (count > 0 ? MathMax(0.0, MathMin(100.0, total / count * 100.0)) : 0.0);
   g_pro.lastSimulation = TimeCurrent();
   g_pro.lastSimulationText = StringFormat("rules=%d score=%.1f warn=%d block=%d", count, g_pro.simulationScore, warnings, blocks);
}

string QQProfessionalSupportReport()
{
   return StringFormat("ready=%.1f time=%.1f session=%.1f broker=%.1f exposure=%.1f sim=%.1f liq=%.1f vol=%.1f memory=%.1f opt=%.1f edge=%.1f ev=%.1f",
                       g_pro.professionalReadiness, g_pro.timeHealthScore, g_pro.sessionQualityScore, g_pro.brokerMicroScore,
                       g_pro.adaptiveExposureScore, g_pro.simulationScore, g_pro.liquidityScore, g_pro.volatilityBalanceScore, g_pro.cycleMemoryScore,
                       g_opt.optimizerScore, g_opt.edgeQualityScore, g_opt.expectedValueScore);
}

void QQStrategyPerformanceMarkEntry(const int id)
{
   if(id < 1 || id > STRATEGY_TOTAL) return;
   g_strategyPerf[id].entries++;
   g_strategyPerf[id].lastEntry = TimeCurrent();
   g_strategyPerf[id].lastOutcome = "open";
}

void QQStrategyPerformanceMarkExit(const int id, const double profit)
{
   if(id < 1 || id > STRATEGY_TOTAL) return;
   if(profit >= 0.0) { g_strategyPerf[id].wins++; g_strategyPerf[id].grossProfit += profit; g_strategyPerf[id].lastOutcome = "win"; }
   else { g_strategyPerf[id].losses++; g_strategyPerf[id].grossLoss += MathAbs(profit); g_strategyPerf[id].lastOutcome = "loss"; }
   g_strategyPerf[id].bestProfit = MathMax(g_strategyPerf[id].bestProfit, profit);
   g_strategyPerf[id].worstProfit = MathMin(g_strategyPerf[id].worstProfit, profit);
   if(g_strategyPerf[id].lastEntry > 0)
   {
      double hold = (double)(TimeCurrent() - g_strategyPerf[id].lastEntry) / 60.0;
      int closed = g_strategyPerf[id].wins + g_strategyPerf[id].losses;
      g_strategyPerf[id].averageHoldMinutes = ((g_strategyPerf[id].averageHoldMinutes * MathMax(0, closed - 1)) + hold) / MathMax(1, closed);
   }
   g_strategyPerf[id].lastExit = TimeCurrent();
}

double QQStrategyProfitFactor(const int id)
{
   if(id < 1 || id > STRATEGY_TOTAL) return 0.0;
   if(g_strategyPerf[id].grossLoss <= 0.0) return (g_strategyPerf[id].grossProfit > 0.0 ? 99.0 : 0.0);
   return g_strategyPerf[id].grossProfit / g_strategyPerf[id].grossLoss;
}

double QQStrategyWinRate(const int id)
{
   if(id < 1 || id > STRATEGY_TOTAL) return 0.0;
   int closed = g_strategyPerf[id].wins + g_strategyPerf[id].losses;
   if(closed <= 0) return 0.0;
   return g_strategyPerf[id].wins * 100.0 / closed;
}

double QQSimulationRuleValue(const int ruleId)
{
   switch(ruleId)
   {

      case 1:
      {
         double v = 0.50;
         v += (tf[0].ready ? 0.18 : -0.35);
         v += (tf[0].bias == g_matrix.macroDir && g_matrix.macroDir != 0 ? 0.17 : -0.06);
         v += (g_pro.timeHealthScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 2:
      {
         double v = 0.50;
         v += (QQStrategyEnabled(2) ? 0.16 : -0.18);
         v += (g_strategyAudit[2].lastScore > 0.0 ? MathMin(0.16, g_strategyAudit[2].lastScore / 60.0) : -0.04);
         v += (g_pro.noTradePatienceScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 3:
      {
         double v = 0.50;
         v += (snap.spread <= QQEffectiveSpreadCap() * 0.55 ? 0.18 : -0.18);
         v += (snap.volVelocity >= 0.65 && snap.volVelocity <= 1.90 ? 0.14 : -0.08);
         v += (g_pro.liquidityScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 4:
      {
         double v = 0.50;
         v += (g_capital.projectedDepositLoad <= g_capital.maxDepositLoad * 0.65 ? 0.18 : -0.20);
         v += (GetDrawdownPct() <= QQEffectiveDDLimit() * 0.35 ? 0.14 : -0.18);
         v += (g_pro.adaptiveExposureScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 5:
      {
         double v = 0.50;
         v += (snap.regime == REGIME_TREND ? 0.18 : (snap.regime == REGIME_TRANSITION ? 0.04 : -0.10));
         v += (g_matrix.macroDir == g_matrix.setupDir && g_matrix.macroDir != 0 ? 0.16 : -0.06);
         v += (g_pro.volatilityBalanceScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 6:
      {
         double v = 0.50;
         v += (QQNewsRiskScore() < 35.0 ? 0.18 : -0.22);
         v += (g_pro.timeHealthScore > 55.0 ? 0.10 : -0.12);
         v += (g_pro.sessionQualityScore / 100.0) * 0.08;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 7:
      {
         double v = 0.50;
         v += (tf[6].adx > 18.0 ? 0.10 : -0.04);
         v += (tf[6].atrSlope > -0.12 ? 0.10 : -0.08);
         v += (g_diag.executionHealthScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 8:
      {
         double v = 0.50;
         v += (g_isHedging ? 0.10 : -0.20);
         v += (g_env.tradingAllowed ? 0.12 : -0.35);
         v += (g_pro.brokerMicroScore / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 9:
      {
         double v = 0.50;
         v += (QQStrategyWinRate(9) >= 60.0 || g_strategyPerf[9].entries < 3 ? 0.10 : -0.12);
         v += (QQStrategyProfitFactor(9) >= 1.20 || g_strategyPerf[9].entries < 3 ? 0.10 : -0.10);
         v += (g_pro.cycleMemoryScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 10:
      {
         double v = 0.50;
         v += (g_capital.canTradeMinLot ? 0.14 : -0.30);
         v += (g_capital.tier >= TIER_STANDARD || QQEffectiveCapitalMode() != CAP_LOW ? 0.08 : -0.02);
         v += (g_capital.capitalSurvivalScore / 100.0) * 0.12;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 11:
      {
         double v = 0.50;
         v += (tf[2].ready ? 0.18 : -0.35);
         v += (tf[2].bias == g_matrix.macroDir && g_matrix.macroDir != 0 ? 0.17 : -0.06);
         v += (g_pro.timeHealthScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 12:
      {
         double v = 0.50;
         v += (QQStrategyEnabled(12) ? 0.16 : -0.18);
         v += (g_strategyAudit[12].lastScore > 0.0 ? MathMin(0.16, g_strategyAudit[12].lastScore / 60.0) : -0.04);
         v += (g_pro.noTradePatienceScore / 100.0) * 0.10;
         return MathMax(0.0, MathMin(1.0, v));
      }
      case 13:
      {
